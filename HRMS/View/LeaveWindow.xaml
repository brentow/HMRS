<UserControl x:Class="HRMS.View.LeaveWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             Background="White">
    <UserControl.Resources>
        <Color x:Key="PrimaryColor">#1E4368</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="SoftBlueBrush" Color="#F2F7FD" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="BorderBrush" Value="#E5EDF7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoftButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E9F1FB" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#2E9D5B" />
        </Style>

        <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#B9831A" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#D84343" />
        </Style>

        <Style x:Key="DateFieldBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="#F8FBFF" />
            <Setter Property="BorderBrush" Value="#D5E3F5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F2F7FD" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#E3ECF8" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,0,10,0" />
            <Setter Property="Height" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0,10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Left" />
            <Setter Property="TextBlock.VerticalAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="GridCellCenterStyle" TargetType="DataGridCell" BasedOn="{StaticResource GridCellStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="52" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#1E4368" />
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F1FC" />
                    <Setter Property="Foreground" Value="#1E4368" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="CalendarClockOutline"
                                             Width="34"
                                             Height="32"
                                             Margin="0,0,10,0"
                                             Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="Leave Administration"
                               FontSize="25"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
                <TextBlock Margin="0,2,0,0"
                           Foreground="#5B6A7A"
                           Text="File leave, review approvals, maintain balances, and manage leave attachments." />
            </StackPanel>

            <Button Grid.Column="1"
                    Width="140"
                    Height="42"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,8,0" />
                    <TextBlock Text="Refresh" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="7" Margin="0,0,0,12">
            <Border Margin="6" Style="{StaticResource CardStyle}" Background="#F5FBFF"><StackPanel><TextBlock Text="Requests" Foreground="#6A7684" /><TextBlock Text="{Binding TotalRequests}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" /></StackPanel></Border>
            <Border Margin="6" Style="{StaticResource CardStyle}" Background="#FFF8EC"><StackPanel><TextBlock Text="Pending" Foreground="#6A7684" /><TextBlock Text="{Binding PendingRequests}" FontSize="28" FontWeight="Bold" Foreground="#B9831A" /></StackPanel></Border>
            <Border Margin="6" Style="{StaticResource CardStyle}" Background="#F2FBF5"><StackPanel><TextBlock Text="Approved" Foreground="#6A7684" /><TextBlock Text="{Binding ApprovedRequests}" FontSize="28" FontWeight="Bold" Foreground="#2E9D5B" /></StackPanel></Border>
            <Border Margin="6" Style="{StaticResource CardStyle}" Background="#FFF5F5"><StackPanel><TextBlock Text="Rejected" Foreground="#6A7684" /><TextBlock Text="{Binding RejectedRequests}" FontSize="28" FontWeight="Bold" Foreground="#D84343" /></StackPanel></Border>
            <Border Margin="6" Style="{StaticResource CardStyle}" Background="#F5FBFF"><StackPanel><TextBlock Text="Leave Types" Foreground="#6A7684" /><TextBlock Text="{Binding LeaveTypes}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" /></StackPanel></Border>
            <Border Margin="6" Style="{StaticResource CardStyle}" Background="#F5FBFF"><StackPanel><TextBlock Text="With Balances" Foreground="#6A7684" /><TextBlock Text="{Binding EmployeesWithBalances}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" /></StackPanel></Border>
            <Border Margin="6" Style="{StaticResource CardStyle}" Background="#F5FBFF"><StackPanel><TextBlock Text="Attachments" Foreground="#6A7684" /><TextBlock Text="{Binding AttachmentsCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" /></StackPanel></Border>
        </UniformGrid>

        <TabControl Grid.Row="2" Margin="6,0,6,8">
            <TabItem Header="Leave Requests">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- request filter -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,10,0" Padding="10,6" Background="#F2F7FD" BorderBrush="#E0EAF6" BorderThickness="1" CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Margin="0,0,8,0" Foreground="#7A8FA5" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#5B6A7A" Text="{Binding RequestSearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Search employee, leave type, status, or reason" />
                            </Grid>
                        </Border>

                        <ComboBox Grid.Column="1" Height="40" ItemsSource="{Binding RequestStatusFilters}" SelectedItem="{Binding SelectedRequestStatusFilter}" />
                    </Grid>

                    <!-- file leave -->
                    <Border Grid.Row="1" Margin="0,0,0,10" Padding="12" Style="{StaticResource CardStyle}" Background="#F9FBFF">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.45*" />
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="278" />
                                <ColumnDefinition Width="1.3*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Employee" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Leave Type" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="10,0,0,6" />
                            <Grid Grid.Row="0" Grid.Column="2" Margin="10,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="130" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Date From" Foreground="#5B6A7A" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Date To" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="8,0,0,0" />
                            </Grid>
                            <Grid Grid.Row="0" Grid.Column="3" Margin="10,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Days" Foreground="#5B6A7A" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Reason" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="8,0,0,0" />
                            </Grid>

                            <ComboBox Grid.Row="1"
                                      Grid.Column="0"
                                      Height="40"
                                      IsEnabled="{Binding IsAdminOrHrMode}"
                                      ItemsSource="{Binding EmployeeOptions}"
                                      SelectedValuePath="EmployeeId"
                                      DisplayMemberPath="DisplayText"
                                      SelectedValue="{Binding SelectedFileEmployeeId}" />
                            <ComboBox Grid.Row="1" Grid.Column="1" Height="40" Margin="10,0,0,0" ItemsSource="{Binding LeaveTypeOptions}" SelectedValuePath="LeaveTypeId" DisplayMemberPath="DisplayText" SelectedValue="{Binding SelectedFileLeaveTypeId}" />
                            <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                                <Border Width="130" Style="{StaticResource DateFieldBorderStyle}">
                                    <DatePicker BorderThickness="0"
                                                Padding="8,0"
                                                VerticalContentAlignment="Center"
                                                Background="Transparent"
                                                Language="en-GB"
                                                SelectedDateFormat="Short"
                                                SelectedDate="{Binding FileDateFrom}" />
                                </Border>
                                <Border Width="130" Margin="8,0,0,0" Style="{StaticResource DateFieldBorderStyle}">
                                    <DatePicker BorderThickness="0"
                                                Padding="8,0"
                                                VerticalContentAlignment="Center"
                                                Background="Transparent"
                                                Language="en-GB"
                                                SelectedDateFormat="Short"
                                                SelectedDate="{Binding FileDateTo}" />
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" Margin="10,0,0,0">
                                <TextBox Width="80" Height="40" VerticalContentAlignment="Center" Text="{Binding FileDaysRequested}" />
                                <TextBox Margin="8,0,0,0" Height="40" VerticalContentAlignment="Center" Text="{Binding FileReason}" />
                            </StackPanel>
                            <Button Grid.Row="1"
                                    Grid.Column="4"
                                    Margin="10,0,0,0"
                                    Height="40"
                                    MinWidth="132"
                                    IsEnabled="{Binding CanFileLeaveRequest}"
                                    Command="{Binding FileLeaveCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="15" Height="15" Margin="0,0,6,0" />
                                    <TextBlock Text="File Leave" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- employee validation -->
                    <Border Grid.Row="2"
                            Margin="0,0,0,10"
                            Padding="12"
                            Style="{StaticResource CardStyle}"
                            Background="#F9FBFF"
                            Visibility="{Binding IsEmployeeMode, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.6*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Balance Preview"
                                           Foreground="#5B6A7A"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="{Binding FileBalancePreviewText}"
                                           TextWrapping="Wrap"
                                           Foreground="#1E4368" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <TextBlock Text="Validation"
                                           Foreground="#5B6A7A"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="{Binding FileValidationText}"
                                           Foreground="{Binding FileValidationBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- decision -->
                    <Border Grid.Row="3"
                            Margin="0,0,0,10"
                            Padding="12"
                            Style="{StaticResource CardStyle}"
                            Visibility="{Binding IsAdminOrHrMode, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.8*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Selected Request" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                                <TextBlock Text="{Binding SelectedRequest.EmployeeNo, TargetNullValue='-'}" Foreground="#5B6A7A" />
                                <TextBlock Text="{Binding SelectedRequest.EmployeeName, TargetNullValue='-'}" Foreground="#5B6A7A" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Decision reason / notes" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBox Height="40" VerticalContentAlignment="Center" Text="{Binding DecisionRemarks}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                                <Button Command="{Binding RecommendRequestCommand}" CommandParameter="{Binding SelectedRequest}" Style="{StaticResource WarningButtonStyle}"><TextBlock Text="Recommend" /></Button>
                                <Button Margin="8,0,0,0" Command="{Binding ApproveRequestCommand}" CommandParameter="{Binding SelectedRequest}" Style="{StaticResource SuccessButtonStyle}"><TextBlock Text="Approve" /></Button>
                                <Button Margin="8,0,0,0" Command="{Binding RejectRequestCommand}" CommandParameter="{Binding SelectedRequest}" Style="{StaticResource DangerButtonStyle}"><TextBlock Text="Reject" /></Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- employee selected request panel -->
                    <Border Grid.Row="3"
                            Margin="0,0,0,10"
                            Padding="12"
                            Style="{StaticResource CardStyle}"
                            Visibility="{Binding IsEmployeeMode, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.6*" />
                                <ColumnDefinition Width="2.2*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Selected Request" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                                <TextBlock Text="{Binding SelectedRequest.EmployeeNo, TargetNullValue='-'}" Foreground="#5B6A7A" />
                                <TextBlock Text="{Binding SelectedRequest.EmployeeName, TargetNullValue='-'}" Foreground="#5B6A7A" />
                                <TextBlock Margin="0,2,0,0"
                                           Foreground="#5B6A7A"
                                           Text="{Binding SelectedRequest.Status, TargetNullValue='-'}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Timeline" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding SelectedRequestTimeline}"
                                           Foreground="#1E4368"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="Decision remarks"
                                           Foreground="#5B6A7A"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedRequest.DecisionRemarks, TargetNullValue='-'}"
                                           Foreground="#1E4368"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    MinWidth="150"
                                    Height="40"
                                    IsEnabled="{Binding CanCancelSelectedRequest}"
                                    Command="{Binding CancelMyRequestCommand}"
                                    CommandParameter="{Binding SelectedRequest}"
                                    Style="{StaticResource DangerButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Cancel" Width="14" Height="14" Margin="0,0,6,0" />
                                    <TextBlock Text="Cancel Pending" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- request grid -->
                    <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0">
                        <DataGrid ItemsSource="{Binding LeaveRequests}" SelectedItem="{Binding SelectedRequest}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeaderWidth="0" ColumnHeaderStyle="{StaticResource GridHeaderStyle}" CellStyle="{StaticResource GridCellStyle}" RowStyle="{StaticResource GridRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding LeaveApplicationId}" Width="70" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Emp No" Binding="{Binding EmployeeNo}" Width="95" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="220" />
                                <DataGridTextColumn Header="Leave Type" Binding="{Binding LeaveTypeName}" Width="160" />
                                <DataGridTextColumn Header="From" Binding="{Binding DateFromText}" Width="118" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="To" Binding="{Binding DateToText}" Width="118" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Days" Binding="{Binding DaysRequestedText}" Width="70" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="220" />
                                <DataGridTextColumn Header="Decision Remarks" Binding="{Binding DecisionRemarks}" Width="220" />
                                <DataGridTemplateColumn Header="Status" Width="128">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="106" Height="30" Background="{Binding StatusBrush}" CornerRadius="15" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Action" Width="152">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="130"
                                                    Height="32"
                                                    IsEnabled="{Binding CanCancelPending}"
                                                    Command="{Binding DataContext.CancelMyRequestCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Visibility="{Binding DataContext.IsEmployeeMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Cancel" Width="14" Height="14" Margin="0,0,6,0" />
                                                    <TextBlock Text="Cancel" FontSize="12" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Filed At" Binding="{Binding FiledAtText}" Width="160" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Decision At" Binding="{Binding DecisionAtText}" Width="160" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Docs" Binding="{Binding AttachmentCount}" Width="60" CellStyle="{StaticResource GridCellCenterStyle}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Leave Balances">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,10,0" Padding="10,6" Background="#F2F7FD" BorderBrush="#E0EAF6" BorderThickness="1" CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Margin="0,0,8,0" Foreground="#7A8FA5" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#5B6A7A" Text="{Binding BalanceSearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Search employee or leave type" />
                            </Grid>
                        </Border>

                        <ComboBox Grid.Column="1" Height="40" ItemsSource="{Binding BalanceYearOptions}" SelectedItem="{Binding SelectedBalanceYearFilter}" />
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,0,0,10"
                            Padding="12"
                            Style="{StaticResource CardStyle}"
                            Background="#F9FBFF"
                            Visibility="{Binding IsAdminOrHrMode, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.6*" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Employee" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Leave Type" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="10,0,0,6" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Year" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="10,0,0,6" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="As of date" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="10,0,0,6" />

                            <ComboBox Grid.Row="1" Grid.Column="0" Height="40" ItemsSource="{Binding EmployeeOptions}" SelectedValuePath="EmployeeId" DisplayMemberPath="DisplayText" SelectedValue="{Binding SelectedBalanceEmployeeId}" />
                            <ComboBox Grid.Row="1" Grid.Column="1" Height="40" Margin="10,0,0,0" ItemsSource="{Binding LeaveTypeOptions}" SelectedValuePath="LeaveTypeId" DisplayMemberPath="DisplayText" SelectedValue="{Binding SelectedBalanceLeaveTypeId}" />
                            <TextBox Grid.Row="1" Grid.Column="2" Height="40" Margin="10,0,0,0" VerticalContentAlignment="Center" Text="{Binding BalanceYear}" />
                            <Border Grid.Row="1"
                                    Grid.Column="3"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource DateFieldBorderStyle}">
                                <DatePicker BorderThickness="0"
                                            Padding="8,0"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            Language="en-GB"
                                            SelectedDateFormat="Short"
                                            SelectedDate="{Binding BalanceAsOfDate}" />
                            </Border>
                            <Button Grid.Row="1" Grid.Column="4" Margin="10,0,0,0" Height="40" MinWidth="120" Command="{Binding SaveBalanceCommand}" Style="{StaticResource PrimaryButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSaveOutline" Width="15" Height="15" Margin="0,0,6,0" />
                                    <TextBlock Text="Save" />
                                </StackPanel>
                            </Button>

                            <Grid Grid.Row="2" Grid.ColumnSpan="5" Margin="0,10,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Opening Credits" Foreground="#5B6A7A" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Earned" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="10,0,0,0" />
                                <TextBlock Grid.Column="2" Text="Used" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="10,0,0,0" />
                                <TextBlock Grid.Column="3" Text="Adjustments" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="10,0,0,0" />
                            </Grid>

                            <Grid Grid.Row="3" Grid.ColumnSpan="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" Height="40" VerticalContentAlignment="Center" Text="{Binding BalanceOpeningCredits}" />
                                <TextBox Grid.Column="1" Height="40" Margin="10,0,0,0" VerticalContentAlignment="Center" Text="{Binding BalanceEarned}" />
                                <TextBox Grid.Column="2" Height="40" Margin="10,0,0,0" VerticalContentAlignment="Center" Text="{Binding BalanceUsed}" />
                                <TextBox Grid.Column="3" Height="40" Margin="10,0,0,0" VerticalContentAlignment="Center" Text="{Binding BalanceAdjustments}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                        <DataGrid ItemsSource="{Binding LeaveBalances}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeaderWidth="0" ColumnHeaderStyle="{StaticResource GridHeaderStyle}" CellStyle="{StaticResource GridCellStyle}" RowStyle="{StaticResource GridRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Emp No" Binding="{Binding EmployeeNo}" Width="100" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="240" />
                                <DataGridTextColumn Header="Leave Type" Binding="{Binding LeaveTypeName}" Width="170" />
                                <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="75" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Opening" Binding="{Binding OpeningCredits, StringFormat={}{0:0.##}}" Width="95" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Earned" Binding="{Binding Earned, StringFormat={}{0:0.##}}" Width="95" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Used" Binding="{Binding Used, StringFormat={}{0:0.##}}" Width="95" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Adjust" Binding="{Binding Adjustments, StringFormat={}{0:0.##}}" Width="95" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Available" Binding="{Binding AvailableCredits, StringFormat={}{0:0.##}}" Width="100" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="As Of" Binding="{Binding AsOfDateText}" Width="130" CellStyle="{StaticResource GridCellCenterStyle}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Attachments">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Margin="0,0,0,10" Padding="12" Style="{StaticResource CardStyle}" Background="#F9FBFF">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0" Height="40" ItemsSource="{Binding LeaveRequestOptions}" SelectedValuePath="LeaveApplicationId" DisplayMemberPath="DisplayText" SelectedValue="{Binding SelectedAttachmentRequestId}" materialDesign:HintAssist.Hint="Leave Request" />
                            <TextBox Grid.Column="1" Margin="10,0,0,0" Height="40" VerticalContentAlignment="Center" Text="{Binding SelectedAttachmentFilePath}" materialDesign:HintAssist.Hint="Attachment file path" />

                            <Button Grid.Column="2" Margin="10,0,0,0" Height="40" MinWidth="110" Command="{Binding BrowseAttachmentCommand}" Style="{StaticResource SoftButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderOpenOutline" Width="15" Height="15" Margin="0,0,6,0" />
                                    <TextBlock Text="Browse" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="3" Margin="8,0,0,0" Height="40" MinWidth="110" Command="{Binding UploadAttachmentCommand}" Style="{StaticResource PrimaryButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Upload" Width="15" Height="15" Margin="0,0,6,0" />
                                    <TextBlock Text="Upload" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,10,0" Padding="10,6" Background="#F2F7FD" BorderBrush="#E0EAF6" BorderThickness="1" CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Margin="0,0,8,0" Foreground="#7A8FA5" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#5B6A7A" Text="{Binding AttachmentSearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" materialDesign:HintAssist.Hint="Search employee or file name/path" />
                            </Grid>
                        </Border>

                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="#6A7684" FontWeight="SemiBold" Text="{Binding AttachmentsCount, StringFormat=Total: {0}}" />
                    </Grid>

                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                        <DataGrid ItemsSource="{Binding LeaveAttachments}" SelectedItem="{Binding SelectedAttachment}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeaderWidth="0" ColumnHeaderStyle="{StaticResource GridHeaderStyle}" CellStyle="{StaticResource GridCellStyle}" RowStyle="{StaticResource GridRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Doc ID" Binding="{Binding LeaveDocumentId}" Width="90" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Req ID" Binding="{Binding LeaveApplicationId}" Width="90" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Emp No" Binding="{Binding EmployeeNo}" Width="95" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="220" />
                                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="210" />
                                <DataGridTextColumn Header="Path" Binding="{Binding FilePath}" Width="360" />
                                <DataGridTextColumn Header="Uploaded" Binding="{Binding UploadedAtText}" Width="170" CellStyle="{StaticResource GridCellCenterStyle}" />
                                <DataGridTemplateColumn Header="Action" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="96"
                                                    Height="32"
                                                    Command="{Binding DataContext.DeleteAttachmentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Visibility="{Binding DataContext.IsAdminOrHrMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14" Margin="0,0,6,0" />
                                                    <TextBlock Text="Delete" FontSize="12" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3" Margin="6,0,6,0" Padding="10,7" CornerRadius="10" BorderBrush="#E5EDF7" BorderThickness="1" Background="{StaticResource SoftBlueBrush}">
            <TextBlock Text="{Binding ActionMessage}" Foreground="{Binding ActionMessageBrush}" FontWeight="SemiBold" TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
