                                Background="Transparent"
                                BorderThickness="0"
                                ToolTip="Notifications"
                                Click="NotificationButton_OnClick"
                                FocusVisualStyle="{x:Null}"
                                Effect="{x:Null}"
                                VerticalAlignment="Center">
                            <Grid Width="24" Height="24">
                                <materialDesign:PackIcon Kind="BellOutline" Width="22" Height="22" Foreground="#4D6077" />
                            </Grid>
                        </Button>

                        <Border Grid.Column="6"
                                Width="18"
                                Height="18"
                                Margin="0,-2,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="#F14A48"
                                CornerRadius="9"
                                BorderBrush="White"
                                BorderThickness="1"
                                Panel.ZIndex="5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=DashboardNotificationsPopup, Path=DataContext.UnreadCount}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ElementName=DashboardNotificationsPopup, Path=DataContext.UnreadCount}"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="9"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        </Border>

                        <StackPanel Grid.Column="7" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TodayDayDisplay}" HorizontalAlignment="Right" FontSize="14" FontWeight="SemiBold" Foreground="#6B7B8D" />
                            <TextBlock Text="{Binding TodayDateDisplay}" Margin="0,2,0,0" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Foreground="#26384C" />
                        </StackPanel>

                        <Popup x:Name="DashboardNotificationsPopup"
                               PlacementTarget="{Binding ElementName=MainContentHost}"
                               Placement="Center"
                               HorizontalOffset="0"
                               VerticalOffset="0"
                               StaysOpen="True"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               IsOpen="False">
                        <Border x:Name="NotificationPopupCard"
                                Width="360"
                                MaxHeight="460"
                                Background="White"
                                CornerRadius="12"
                                BorderBrush="#DFE8F5"
                                BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Margin="12,10,12,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                        <TextBlock Text="Notifications"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                    <Border Grid.Column="1"
                                            Margin="8,0,8,0"
                                            Padding="8,2"
                                            Background="#ECF7E8"
                                            CornerRadius="10"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding UnreadCount}"
                                                   Foreground="#4B9E2F"
                                                   FontWeight="Bold"
                                                   FontSize="12" />
                                    </Border>
                                    <Button Grid.Column="2"
                                            Width="26"
                                            Height="26"
                                            Padding="0"
                                            BorderThickness="0"
                                            Background="#F2F5FA"
                                            Click="CloseNotificationsPopup_OnClick"
                                            ToolTip="Close"
                                            materialDesign:ButtonAssist.CornerRadius="13">
                                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" Foreground="#6A7684" />
                                    </Button>
                                </Grid>

                                <Border Grid.Row="1" BorderBrush="#EEF3FB" BorderThickness="0,1,0,1">
                                    <Grid>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding Notifications}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource NotificationItemButtonStyle}"
                                                                Command="{Binding ElementName=DashboardNotificationsPopup, Path=DataContext.OpenSourceCommand}"
                                                                CommandParameter="{Binding}"
                                                                Opacity="{Binding ItemOpacity}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Width="34"
                                                                        Height="34"
                                                                        Margin="0,2,10,0"
                                                                        Background="#EAF3FF"
                                                                        CornerRadius="17"
                                                                        VerticalAlignment="Top">
                                                                    <Grid>
                                                                        <materialDesign:PackIcon Kind="BellOutline"
                                                                                                 Width="16"
                                                                                                 Height="16"
                                                                                                 Foreground="{StaticResource PrimaryBrush}"
                                                                                                 HorizontalAlignment="Center"
                                                                                                 VerticalAlignment="Center" />
                                                                        <Ellipse Width="8"
                                                                                 Height="8"
                                                                                 Fill="#E84B4B"
                                                                                 Stroke="White"
                                                                                 StrokeThickness="1"
                                                                                 HorizontalAlignment="Right"
                                                                                 VerticalAlignment="Top"
                                                                                 Margin="0,-2,-2,0"
                                                                                 Visibility="{Binding UnreadDotVisibility}" />
                                                                    </Grid>
                                                                </Border>
                                                                <StackPanel Grid.Column="1">
                                                                    <DockPanel LastChildFill="False">
                                                                        <TextBlock Text="{Binding Title}"
                                                                                   Foreground="#2B3A4A"
                                                                                   FontWeight="{Binding TitleFontWeight}"
                                                                                   FontSize="14"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   DockPanel.Dock="Left"
                                                                                   Width="190" />
                                                                        <TextBlock Text="{Binding EventAtText}"
                                                                                   Foreground="#7A8696"
                                                                                   FontSize="11"
                                                                                   Margin="8,2,0,0"
                                                                                   DockPanel.Dock="Right" />
                                                                    </DockPanel>
                                                                    <TextBlock Text="{Binding Message}"
                                                                               Foreground="#4A5B6C"
                                                                               FontSize="13"
                                                                               TextWrapping="Wrap"
                                                                               MaxHeight="36"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Margin="0,2,0,4" />
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border Background="#EEF3FB"
                                                                                CornerRadius="8"
                                                                                Padding="6,1"
                                                                                Margin="0,0,6,0">
                                                                            <TextBlock Text="{Binding ModuleLabel}" FontSize="11" Foreground="#5A6A7A" />
                                                                        </Border>
                                                                        <Border Background="#EEF3FB"
                                                                                CornerRadius="8"
                                                                                Padding="6,1">
                                                                            <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{Binding StatusBrush}" />
                                                                        </Border>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="24"
                                                    IsHitTestVisible="False">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Notifications.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <materialDesign:PackIcon Kind="BellOutline"
                                                                     Width="36"
                                                                     Height="36"
                                                                     HorizontalAlignment="Center"
                                                                     Foreground="#8AA0BA" />
                                            <TextBlock Text="Notifications"
                                                       Margin="0,10,0,0"
                                                       HorizontalAlignment="Center"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="#31465D" />
                                            <TextBlock Text="{Binding StatusMessage}"
                                                       Margin="0,6,0,0"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Foreground="#677A8F"
                                                       MaxWidth="240" />
                                            <TextBlock Text="Click X to continue using the dashboard."
                                                       Margin="0,10,0,0"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Foreground="#7E8C9C"
                                                       FontSize="12" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="2" Margin="12,8,12,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding StatusMessage}"
                                               Foreground="{Binding StatusBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="1"
                                            Content="Refresh"
                                            Width="84"
                                            Height="30"
                                            Margin="10,0,0,0"
                                            Command="{Binding RefreshCommand}"
                                            Background="{StaticResource PrimaryBrush}"
                                            Foreground="White"
                                            BorderThickness="0"
                                            materialDesign:ButtonAssist.CornerRadius="8" />
                                </Grid>
                            </Grid>
                        </Border>
                        </Popup>
                    </Grid>
                </Border>

                <!-- Employee Dashboard (clean layout for Employee role) -->
                <Grid x:Name="EmployeeDashboardPanel"
                      Grid.Row="1"
                      Margin="0,8,0,0"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Welcome / Date header -->
                    <Border Grid.Row="0"
                            Margin="4"
                            Padding="28,22"
                            Background="#0F1D3A"
                            BorderBrush="#243C67"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding EmployeeGreeting}" FontSize="26" FontWeight="SemiBold" Foreground="White" />
                                <TextBlock Margin="0,6,0,0" FontSize="16" Foreground="#B0C4DE">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} — {1}">
                                            <Binding Path="TodayDayDisplay" />
                                            <Binding Path="TodayDateDisplay" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="SYSTEM READY" Margin="0,12,0,0" FontSize="16" FontWeight="Bold" Foreground="#1ED760" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Width="72"
                                    Height="72"
                                    Background="White"
                                    CornerRadius="36"
                                    VerticalAlignment="Center">
                                <Image Source="{Binding CompanyLogoPath}" Stretch="Uniform" Margin="8" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Main tiles for employee -->
                    <UniformGrid Grid.Row="1" Columns="3" Rows="2" Margin="0,4,0,4">
                        <Button x:Name="EmpQuickAttendanceButton"
                                Style="{StaticResource ReferenceDashboardTileStyle}"
                                Background="#F59E0B"
                                Click="AttendanceNavButton_OnClick">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CalendarCheckOutline" Width="44" Height="44" Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="MY ATTENDANCE" Margin="0,14,0,0" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="View your daily time record and clock-in history." Margin="0,8,0,0" FontSize="13" Foreground="#FFF5DE" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="EmpQuickLeaveButton"
                                Style="{StaticResource ReferenceDashboardTileStyle}"
                                Background="#14B8A6"
                                Click="LeaveNavButton_OnClick">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CalendarMonthOutline" Width="44" Height="44" Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="MY LEAVE" Margin="0,14,0,0" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="File leave requests and check your balances." Margin="0,8,0,0" FontSize="13" Foreground="#E4FFFC" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="EmpQuickPayrollButton"
                                Style="{StaticResource ReferenceDashboardTileStyle}"
                                Background="#22C55E"
                                Click="PayrollNavButton_OnClick">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CashMultiple" Width="44" Height="44" Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="MY PAYROLL" Margin="0,14,0,0" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="View your payslip and compensation details." Margin="0,8,0,0" FontSize="13" Foreground="#E4FFE9" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="EmpQuickAdjustmentsButton"
                                Style="{StaticResource ReferenceDashboardTileStyle}"
                                Background="#F97316"
                                Click="AdjustmentsNavButton_OnClick">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="FileEditOutline" Width="44" Height="44" Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="MY ADJUSTMENTS" Margin="0,14,0,0" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="File DTR corrections and view adjustment status." Margin="0,8,0,0" FontSize="13" Foreground="#FFF0E6" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="EmpQuickProfileButton"
                                Style="{StaticResource ReferenceDashboardTileStyle}"
                                Background="#6366F1"
                                Click="UserAccountSettingsButton_OnClick">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="AccountCircleOutline" Width="44" Height="44" Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="MY PROFILE" Margin="0,14,0,0" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="View and update your personal information." Margin="0,8,0,0" FontSize="13" Foreground="#E8EAFF" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="EmpQuickNotificationsButton"
                                Style="{StaticResource ReferenceDashboardTileStyle}"
                                Background="#3B82F6"
                                Click="NotificationButton_OnClick">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="BellOutline" Width="44" Height="44" Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="NOTIFICATIONS" Margin="0,14,0,0" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                                <TextBlock Text="Check alerts and important updates." Margin="0,8,0,0" FontSize="13" Foreground="#E1EDFF" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </UniformGrid>

                    <!-- Bottom quick actions -->
                    <Border Grid.Row="2"
                            Margin="4,2,4,0"
                            Padding="6"
                            Background="#111827"
                            CornerRadius="12">
                        <UniformGrid Columns="4">
                            <Button Style="{StaticResource ReferenceDashboardMiniTileStyle}"
                                    Background="#0F5A86"
                                    Click="AttendanceNavButton_OnClick">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="ClockOutline" Width="18" Height="18" Foreground="White" />
                                    <TextBlock Text="Attendance" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ReferenceDashboardMiniTileStyle}"
                                    Background="#13735B"
                                    Click="LeaveNavButton_OnClick">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="CalendarClock" Width="18" Height="18" Foreground="White" />
                                    <TextBlock Text="Leave" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ReferenceDashboardMiniTileStyle}"
                                    Background="#475569"
                                    Click="HelpHeaderButton_OnClick">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="HelpCircleOutline" Width="18" Height="18" Foreground="White" />
                                    <TextBlock Text="Help" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ReferenceDashboardMiniTileStyle}"
                                    Background="#13735B"
                                    Command="{Binding RefreshCommand}"
                                    Click="Button_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Foreground="White" />
                                    <TextBlock Text="Refresh" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </Border>
                </Grid>

                <!-- Admin Dashboard body inspired by the provided municipality tile dashboard -->
                <Grid x:Name="AdminDashboardPanel"
                      Grid.Row="1"
                      Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.12*" />
                        <RowDefinition Height="1.12*" />
                        <RowDefinition Height="1.08*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2.8*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="QuickEmployeesButton"
                            Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource ReferenceDashboardTileStyle}"
                            Background="#6366F1"
                            Click="EmployeesNavButton_OnClick">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="ViewDashboardOutline" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="EMPLOYEE MANAGEMENT" Margin="0,16,0,0" FontSize="20" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" />
                            <TextBlock Text="Employee records and workspace overview." Margin="0,8,0,0" FontSize="13" Foreground="#E8EAFF" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="QuickDocumentsButton"
                            Grid.Row="0"
                            Grid.Column="1"
                            Style="{StaticResource ReferenceDashboardTileStyle}"
                            Background="#0EA5E9"
                            Click="DocumentsNavButton_OnClick">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="FolderAccountOutline" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="{Binding DocumentsNavLabel, StringFormat={}{0}}" Margin="0,16,0,0" FontSize="20" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" />
                            <TextBlock Text="Browse records, files, and employee requirements." Margin="0,8,0,0" FontSize="13" Foreground="#E0F6FF" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="0"
                            Grid.Column="2"
                            Style="{StaticResource ReferenceDashboardTileStyle}"
                            Background="#10B981"
                            Click="RecruitmentNavButton_OnClick">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountPlusOutline" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="RECRUITMENT" Margin="0,16,0,0" FontSize="20" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" />
                            <TextBlock Text="Create new hiring entries and track applicants fast." Margin="0,8,0,0" FontSize="13" Foreground="#DFFFEF" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="QuickAttendanceButton"
                            Grid.Row="0"
                            Grid.Column="3"
                            Style="{StaticResource ReferenceDashboardTileStyle}"
                            Background="#F59E0B"
                            Click="AttendanceNavButton_OnClick">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="CalendarCheckOutline" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="ATTENDANCE / DTR" Margin="0,16,0,0" FontSize="20" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" />
                            <TextBlock Text="Track attendance logs, scans, and shift records." Margin="0,8,0,0" FontSize="13" Foreground="#FFF5DE" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>

                    <Border Grid.Row="0"
                            Grid.Column="4"
                            Margin="4"
                            Padding="18,14"
                            Background="White"
                            BorderBrush="#E7EDF5"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Image Grid.Row="0"
                                   Source="{Binding CompanyLogoPath}"
                                   MaxWidth="164"
                                   MaxHeight="86"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1"
                                       Text="{Binding CompanyAddress}"
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#6B7B8D"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="2"
                                       Text="{Binding CompanyName}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#20354D"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       LineHeight="22" />
                            <TextBlock Grid.Row="3"
                                       Text="Official Human Resource Management System"
                                       Margin="0,5,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#6B7B8D"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="4"
                            Padding="34,26"
                            Background="#0F1D3A"
                            BorderBrush="#243C67"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding TodayDayDisplay}" FontSize="34" FontWeight="Light" Foreground="White" />
                            <TextBlock Text="{Binding TodayDateDisplay}" Margin="0,6,0,0" FontSize="30" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="SYSTEM READY" Margin="0,16,0,0" FontSize="22" FontWeight="Bold" Foreground="#1ED760" />
                        </StackPanel>
                    </Border>

                    <Button Grid.Row="1"
                            Grid.Column="2"
                            Style="{StaticResource ReferenceDashboardTileStyle}"
                            Background="#8B5CF6"
                            Click="ReportsNavButton_OnClick">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="ChartBoxOutline" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="REPORTS" Margin="0,16,0,0" FontSize="20" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="Export summaries and printable reports." Margin="0,8,0,0" FontSize="13" Foreground="#ECE4FF" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="1"
                            Grid.Column="3"
                            Style="{StaticResource ReferenceDashboardTileStyle}"
                            Background="#64748B"
                            Click="UsersNavButton_OnClick">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountCogOutline" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="USERS" Margin="0,16,0,0" FontSize="20" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="Manage access, roles, and account health." Margin="0,8,0,0" FontSize="13" Foreground="#ECF2FA" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>

                    <Border Grid.Row="1"
                            Grid.Column="4"
                            Grid.RowSpan="2"
                            Margin="4"
                            Padding="18"
                            Background="#0F746D"
                            BorderBrush="#1B8A83"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Image Source="{Binding CompanyLogoPath}" Width="88" Height="64" Stretch="Uniform" />
                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Software Name and Trademark" FontSize="13" Foreground="#B1EDE8" />
                                    <TextBlock Text="{Binding CompanyAbbreviation}" Margin="0,3,0,0" FontSize="20" FontWeight="Bold" Foreground="White" />
                                    <TextBlock Text="Human Resources Management System" Margin="0,3,0,0" FontSize="13" Foreground="#D4FBF8" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>

                            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Employees" FontSize="12" Foreground="#B9ECE9" />
                                    <TextBlock Text="{Binding Stats.TotalEmployees}" FontSize="38" FontWeight="Bold" Foreground="White" />
                                </StackPanel>
                                <StackPanel Margin="12,0,0,0">
                                    <TextBlock Text="Present" FontSize="12" Foreground="#B9ECE9" />
                                    <TextBlock Text="{Binding Stats.PresentToday}" FontSize="38" FontWeight="Bold" Foreground="White" />
                                </StackPanel>
                                <StackPanel Margin="12,0,0,0">
                                    <TextBlock Text="Open Jobs" FontSize="12" Foreground="#B9ECE9" />
                                    <TextBlock Text="{Binding Stats.OpenJobs}" FontSize="38" FontWeight="Bold" Foreground="White" />
                                </StackPanel>
                            </UniformGrid>

                            <Button Grid.Row="2"
                                    Style="{StaticResource ReferenceDashboardTileStyle}"
                                    Margin="0,0,0,10"
                                    Padding="16,14"
                                    Background="#0C224B"
                                    Click="TransactionsNavButton_OnClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="TRANSACTIONS" FontSize="18" FontWeight="Bold" Foreground="#BFD4FF" />
                                        <TextBlock Text="Review transaction history and recent system activity." Margin="0,4,0,0" FontSize="12" Foreground="White" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <materialDesign:PackIcon Grid.Column="1" Kind="DatabaseCheckOutline" Width="34" Height="34" Foreground="#5CE1CF" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </Grid>
                            </Button>

                            <Grid Grid.Row="3" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="QuickTravelOrderButton"
                                        Grid.Column="0"
                                        Style="{StaticResource ReferenceDashboardTileStyle}"
                                        Margin="0,0,5,0"
                                        Padding="14"
                                        Background="#2D61AF"
                                        Click="TravelOrderNavButton_OnClick">
                                    <StackPanel>
                                        <materialDesign:PackIcon Kind="FileEditOutline" Width="28" Height="28" Foreground="White" />
                                        <TextBlock Text="TRAVEL ORDER" Margin="0,8,0,0" FontSize="16" FontWeight="Bold" Foreground="White" />
                                        <TextBlock Text="Record official travel and OB remarks." Margin="0,3,0,0" FontSize="12" Foreground="#DDE7FF" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>

                                <Border Grid.Column="1"
                                        Margin="5,0,0,0"
                                        Padding="14"
                                        Background="#15203F"
                                        BorderBrush="#2B436C"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <materialDesign:PackIcon Kind="DatabaseCogOutline" Width="28" Height="28" Foreground="White" />
                                        <TextBlock Text="DATABASE STATUS" Margin="0,8,0,0" FontSize="16" FontWeight="Bold" Foreground="White" />
                                        <TextBlock Text="{Binding SerialNumber}" Margin="0,3,0,0" FontSize="11" Foreground="#CFDAEB" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding LastUpdated, StringFormat='Updated {0:MMM dd, yyyy h:mm tt}'}" Margin="0,3,0,0" FontSize="11" Foreground="#CFDAEB" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Button Grid.Row="2"
                            Grid.Column="0"
                            Style="{StaticResource ReferenceDashboardTileStyle}"
                            Background="#F97316"
                            Click="AttendanceLogsNavButton_OnClick">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="History" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="LOGS" Margin="0,16,0,0" FontSize="20" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="Review check-in and check-out history." Margin="0,8,0,0" FontSize="13" Foreground="#FFF0E6" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="QuickLeaveButton"
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource ReferenceDashboardTileStyle}"
                            Background="#14B8A6"
                            Click="LeaveNavButton_OnClick">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="CalendarMonthOutline" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="LEAVE" Margin="0,16,0,0" FontSize="20" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="Manage leave requests, balances, and schedules." Margin="0,8,0,0" FontSize="13" Foreground="#E4FFFC" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="QuickPayrollButton"
                            Grid.Row="2"
                            Grid.Column="2"
                            Style="{StaticResource ReferenceDashboardTileStyle}"
                            Background="#22C55E"
                            Click="PayrollNavButton_OnClick">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="CashMultiple" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="PAYROLL" Margin="0,16,0,0" FontSize="20" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="Handle releases, deductions, and payroll periods." Margin="0,8,0,0" FontSize="13" Foreground="#E4FFE9" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="2"
                            Grid.Column="3"
                            Style="{StaticResource ReferenceDashboardTileStyle}"
                            Background="#3B82F6"
                            Click="DocumentVerificationNavButton_OnClick">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="ShieldCheckOutline" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="VERIFY" Margin="0,16,0,0" FontSize="20" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="Approve pending records and document checks." Margin="0,8,0,0" FontSize="13" Foreground="#E1EDFF" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>

                    <Border Grid.Row="3"
                            Grid.ColumnSpan="5"
                            Margin="4,6,4,0"
                            Padding="6"
                            Background="#111827"
                            CornerRadius="12">
                        <UniformGrid Columns="8">
                            <Button Style="{StaticResource ReferenceDashboardMiniTileStyle}"
                                    Background="#0F5A86"
                                    Click="DepartmentsNavButton_OnClick">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Domain" Width="18" Height="18" Foreground="White" />
                                    <TextBlock Text="Departments" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ReferenceDashboardMiniTileStyle}"
                                    Background="#83420B"
                                    Click="AdjustmentsNavButton_OnClick">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="FileEditOutline" Width="18" Height="18" Foreground="White" />
                                    <TextBlock Text="Adjustments" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource ReferenceDashboardMiniTileStyle}"
                                    Background="#2558A6"
                                    Click="BeneficiariesNavButton_OnClick">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="AccountMultiplePlus" Width="18" Height="18" Foreground="White" />
                                    <TextBlock Text="Beneficiaries" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="QuickHolidaysButton"
                                    Style="{StaticResource ReferenceDashboardMiniTileStyle}"
                                    Background="#3158A5"
                                    Click="HolidaysNavButton_OnClick">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="CalendarMonthOutline" Width="18" Height="18" Foreground="White" />
                                    <TextBlock Text="Holidays" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="QuickProfileButton"
                                    Style="{StaticResource ReferenceDashboardMiniTileStyle}"
                                    Background="#475569"
                                    Click="UserAccountSettingsButton_OnClick">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="CogOutline" Width="18" Height="18" Foreground="White" />
                                    <TextBlock Text="Settings" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="QuickNotificationsButton"
                                    Style="{StaticResource ReferenceDashboardMiniTileStyle}"
                                    Background="#275767"
                                    Click="NotificationButton_OnClick">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="BellOutline" Width="18" Height="18" Foreground="#7AF3E4" />
                                    <TextBlock Text="Notifications" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="QuickHelpButton"
                                    Style="{StaticResource ReferenceDashboardMiniTileStyle}"
                                    Background="#4C5A6A"
                                    Click="HelpHeaderButton_OnClick">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="HelpCircleOutline" Width="18" Height="18" Foreground="White" />
                                    <TextBlock Text="Help" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="QuickRefreshButton"
                                    Style="{StaticResource ReferenceDashboardMiniTileStyle}"
                                    Background="#13735B"
                                    Command="{Binding RefreshCommand}"
                                    Click="Button_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Foreground="White" />
                                    <TextBlock Text="Refresh" Margin="8,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </Border>

                    <scottPlot:WpfPlot x:Name="AttendanceCoveragePlot"
                                       Width="0"
                                       Height="0"
                                       Visibility="Collapsed"
                                       IsHitTestVisible="False" />
                </Grid>
            </Grid>

            <!-- Development (Training + Performance) -->
            <Grid Grid.Row="2" Margin="20">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTrainingVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsPerformanceVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <local:DevelopmentWindow x:Name="DevelopmentModule" />
            </Grid>

            <!-- Employees -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsEmployeesVisible, Converter={StaticResource BoolToVis}}">
                <local:EmployeesWindow x:Name="EmployeesModule" />
            </Grid>

            <!-- Departments & Positions -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsDepartmentsVisible, Converter={StaticResource BoolToVis}}">
                <local:DepartmentAndPositionsWindow x:Name="DepartmentsModule" />
            </Grid>

            <!-- Attendance -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsAttendanceVisible, Converter={StaticResource BoolToVis}}">
                <local:AttendanceWindow x:Name="AttendanceModule" />
            </Grid>

            <!-- Attendance Logs -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsAttendanceLogsVisible, Converter={StaticResource BoolToVis}}">
                <local:AttendanceLogsWindow x:Name="AttendanceLogsModule" />
            </Grid>

            <!-- Adjustments -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsAdjustmentsVisible, Converter={StaticResource BoolToVis}}">
                <local:AdjustmentsWindow x:Name="AdjustmentsModule" />
            </Grid>

            <!-- Leave -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsLeaveVisible, Converter={StaticResource BoolToVis}}">
                <local:LeaveWindow x:Name="LeaveModule" />
            </Grid>

            <!-- Payroll -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsPayrollVisible, Converter={StaticResource BoolToVis}}">
                <local:PayrollWindow x:Name="PayrollModule" />
            </Grid>

            <!-- Transactions -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsTransactionsVisible, Converter={StaticResource BoolToVis}}">
                <local:TransactionsWindow x:Name="TransactionsModule" />
            </Grid>

            <!-- Reports -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsReportsVisible, Converter={StaticResource BoolToVis}}">
                <local:ReportsWindow x:Name="ReportsModule" />
            </Grid>

            <!-- Documents -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsDocumentsVisible, Converter={StaticResource BoolToVis}}">
                <local:DocumentsWindow x:Name="DocumentsModule" />
            </Grid>

            <!-- Document Verification -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsDocumentVerificationVisible, Converter={StaticResource BoolToVis}}">
                <local:DocumentVerificationWindow x:Name="DocumentVerificationModule" />
            </Grid>

            <!-- Recruitment -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsRecruitmentVisible, Converter={StaticResource BoolToVis}}">
                <local:RecruitmentWindow x:Name="RecruitmentModule" />
            </Grid>

            <!-- Users & Roles -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsUsersVisible, Converter={StaticResource BoolToVis}}">
                <local:UsersRolesWindow x:Name="UsersRolesModule" />
            </Grid>

            <!-- Beneficiary Verification -->
            <Grid Grid.Row="2" Margin="20" Visibility="{Binding IsBeneficiariesVisible, Converter={StaticResource BoolToVis}}">
                <local:BeneficiaryVerificationWindow x:Name="BeneficiaryVerificationModule" />
            </Grid>


        </Grid>
    </Grid>
</Window>

