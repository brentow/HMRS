<Window x:Class="HRMS.View.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:HRMS.View"
        mc:Ignorable="d"
        Title="HRMS Dashboard"
        WindowStartupLocation="CenterScreen"
        Height="785"
        Width="1289"
        Background="White">

    <Window.Resources>
        <Color x:Key="PrimaryColor">#1E4368</Color>
        <Color x:Key="LightColor">#CBE9FE</Color>
        <Color x:Key="AccentColor">#FDBD55</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="LightBrush" Color="{StaticResource LightColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="#F7FAFC" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="BorderBrush" Value="#E5EDF7" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14 12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Margin" Value="0,3,0,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="6,2" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D5783" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#23456C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick action buttons: keep text centered and readable -->
        <Style x:Key="QuickActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="NavSelectableButtonStyleLocal" BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavColumn" Width="270" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left navigation -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel x:Name="NavStack" Margin="18,22">
                <StackPanel x:Name="NavHeaderPanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,28">
                    <Border Width="56"
                            Height="56"
                            Background="White"
                            CornerRadius="28"
                            Padding="8">
                        <Image Source="/Images/logo-v1-removebg-preview.png"
                               Stretch="Uniform" Margin="-8,-9,-9,-10" />
                    </Border>
                    <StackPanel Margin="10,0">
                        <TextBlock Text="HRMS" Foreground="White" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="Control Center" Foreground="#EAF2FB" FontSize="13" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="Modules" Foreground="#EAF2FB" FontWeight="Bold" Margin="4,0,0,8" x:Name="ModulesLabel"/>

                <Button x:Name="DashboardNavButton" Click="DashboardNavButton_OnClick">
                    <Button.Style>
                        <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDashboardVisible}" Value="True">
                                    <Setter Property="Background" Value="#2D5783"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <materialDesign:PackIcon Kind="ViewDashboardOutline" Width="20" Height="20" Margin="0,10,0,0"/>
                        <TextBlock Text="Dashboard" Margin="8,10,0,0" Tag="NavLabel" />
                    </StackPanel>
                </Button>
                <Button x:Name="EmployeesNavButton" Click="EmployeesNavButton_OnClick">
                    <Button.Style>
                        <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmployeesVisible}" Value="True">
                                    <Setter Property="Background" Value="#2D5783"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountGroupOutline" Width="20" Height="20" Margin="0,10,0,0" />
                        <TextBlock Text="Employees" Margin="8,10,0,0" Tag="NavLabel" />
                    </StackPanel>
                </Button>
                <Button x:Name="DepartmentsNavButton" Click="DepartmentsNavButton_OnClick">
                    <Button.Style>
                        <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDepartmentsVisible}" Value="True">
                                    <Setter Property="Background" Value="#2D5783"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Domain" Width="20" Height="20"  Margin="0,10,0,0" />
                        <TextBlock Text="Departments &amp; Positions" Margin="8,10,0,0" Tag="NavLabel" />
                    </StackPanel>
                </Button>
                <Button x:Name="AttendanceNavButton" Click="AttendanceNavButton_OnClick">
                    <Button.Style>
                        <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAttendanceVisible}" Value="True">
                                    <Setter Property="Background" Value="#2D5783"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ClockOutline" Width="20" Height="20"  Margin="0,10,0,0"/>
                        <TextBlock Text="Attendance" Margin="8,10,0,0" Tag="NavLabel" />
                    </StackPanel>
                </Button>
                <Button x:Name="LeaveNavButton" Click="LeaveNavButton_OnClick">
                    <Button.Style>
                        <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLeaveVisible}" Value="True">
                                    <Setter Property="Background" Value="#2D5783"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CalendarClock" Width="20" Height="20"  Margin="0,10,0,0"/>
                        <TextBlock Text="Leave" Margin="8,10,0,0" Tag="NavLabel" />
                    </StackPanel>
                </Button>
                <Button x:Name="RecruitmentNavButton" Click="RecruitmentNavButton_OnClick">
                    <Button.Style>
                        <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRecruitmentVisible}" Value="True">
                                    <Setter Property="Background" Value="#2D5783"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="BriefcaseAccount" Width="20" Height="20"  Margin="0,10,0,0"/>
                        <TextBlock Text="Recruitment" Margin="8,10,0,0" Tag="NavLabel" />
                    </StackPanel>
                </Button>
                <Button x:Name="PayrollNavButton" Click="PayrollNavButton_OnClick">
                    <Button.Style>
                        <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPayrollVisible}" Value="True">
                                    <Setter Property="Background" Value="#2D5783"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CashMultiple" Width="20" Height="20"  Margin="0,10,0,0" />
                        <TextBlock Text="Payroll" Margin="8,10,0,0" Tag="NavLabel" />
                    </StackPanel>
                </Button>
                <Button x:Name="PerformanceNavButton" Click="PerformanceNavButton_OnClick">
                    <Button.Style>
                        <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPerformanceVisible}" Value="True">
                                    <Setter Property="Background" Value="#2D5783"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChartLine" Width="20" Height="20"  Margin="0,10,0,0"/>
                        <TextBlock Text="Performance" Margin="8,10,0,0" Tag="NavLabel" />
                    </StackPanel>
                </Button>
                <Button x:Name="TrainingNavButton" Click="TrainingNavButton_OnClick">
                    <Button.Style>
                        <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTrainingVisible}" Value="True">
                                    <Setter Property="Background" Value="#2D5783"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="SchoolOutline" Width="20" Height="20"  Margin="0,10,0,0" />
                        <TextBlock Text="Training" Margin="8,10,0,0" Tag="NavLabel" />
                    </StackPanel>
                </Button>
                <Button x:Name="UsersNavButton" Click="UsersNavButton_OnClick">
                    <Button.Style>
                        <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUsersVisible}" Value="True">
                                    <Setter Property="Background" Value="#2D5783"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountLock" Width="20" Height="20" Margin="0,10,0,0" />
                        <TextBlock Text="Users &amp; Roles" Margin="8,10,0,0" Tag="NavLabel" />
                    </StackPanel>
                </Button>

                <Border x:Name="QuickHintBorder" Margin="0,2,0,0" Padding="14" Background="#2D5783" CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="Need quick changes?" Foreground="White" FontWeight="Bold" />
                        <TextBlock Text="Use the quick actions on the right." Foreground="#EAF2FB" FontSize="12" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="140" />
                <RowDefinition Height="310" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource LightBrush}">
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Human Resources Management System" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock Text="All modules in one view - stay ahead of people operations." Margin="0,4,0,0" Foreground="#4A5B6C" />
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Border Background="{StaticResource AccentBrush}" Padding="10,6" CornerRadius="8">
                                <TextBlock Text="Live" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" />
                            </Border>
                            <TextBlock Text="{Binding LastUpdated, StringFormat='Updated {0:MMM dd, yyyy h:mm tt}'}" Foreground="#4A5B6C" Margin="10,6,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Refresh"
                                    Command="{Binding RefreshCommand}"
                                    Padding="12,8"
                                    Width="120"
                                    Background="{StaticResource PrimaryBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    materialDesign:ButtonAssist.CornerRadius="10" Height="40" Click="Button_Click" />
                            <Button x:Name="ToggleNavButton"
                                    Width="48"
                                    Height="40"
                                    Margin="8,0,0,0"
                                    Background="{StaticResource PrimaryBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    materialDesign:ButtonAssist.CornerRadius="10"
                                    ToolTip="Collapse / expand navigation"
                                    Click="ToggleNavButton_OnClick">
                                <materialDesign:PackIcon Kind="ChevronLeft" Width="18" Height="18"/>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="Firebrick" TextWrapping="Wrap" Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Dashboard content -->
            <Grid Grid.Row="1" Margin="20,14,20,10" Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVis}}">
                <UniformGrid Columns="3" Rows="2" Margin="0,4">
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Total Employees" Foreground="#6A7684" />
                            <TextBlock Text="{Binding Stats.TotalEmployees}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                            <Rectangle Height="4" Fill="{StaticResource PrimaryBrush}" RadiusX="2" RadiusY="2" Margin="0,6,40,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Active Employees" Foreground="#6A7684" />
                            <TextBlock Text="{Binding Stats.ActiveEmployees}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                            <TextBlock Text="Present Today" Foreground="#6A7684" Margin="0,6,0,0" />
                            <TextBlock Text="{Binding Stats.PresentToday}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Structure" Foreground="#6A7684" />
                            <TextBlock Text="{Binding Stats.Departments, StringFormat='Departments: {0}'}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                            <TextBlock Text="{Binding Stats.Positions, StringFormat='Positions: {0}'}" Foreground="#6A7684" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Leave" Foreground="#6A7684" />
                            <TextBlock Text="{Binding Stats.PendingLeaves, StringFormat='Pending: {0}'}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="Requests waiting for approval" Foreground="#6A7684" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Recruitment" Foreground="#6A7684" />
                            <TextBlock Text="{Binding Stats.OpenJobs, StringFormat='Open Jobs: {0}'}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                            <TextBlock Text="{Binding Stats.ApplicantsInPipeline, StringFormat='Applicants: {0}'}" Foreground="#6A7684" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Performance &amp; Training" Foreground="#6A7684" />
                            <TextBlock Text="{Binding Stats.OpenPerformanceCycles, StringFormat='Open Cycles: {0}'}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                            <TextBlock Text="{Binding Stats.ActiveCourses, StringFormat='Active Courses: {0}'}" Foreground="#6A7684" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>

            <!-- Lower content -->
            <Grid Grid.Row="2" Margin="20,0,20,18" Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="455*" />
                    <ColumnDefinition Width="11*" />
                    <ColumnDefinition Width="444*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F9FCFF" CornerRadius="14" Padding="18" BorderBrush="#E5EDF7" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Quick Actions" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                            <Rectangle Width="6" Height="6" Fill="{StaticResource AccentBrush}" RadiusX="2" RadiusY="2" Margin="8,0,0,0" />
                        </StackPanel>
                        <UniformGrid Columns="2" Margin="0,12,0,0" Rows="3" HorizontalAlignment="Stretch">
                            <Button Style="{StaticResource QuickActionButtonStyle}"
                                    Content="Add Employee"
                                    Background="{StaticResource PrimaryBrush}"
                                    Foreground="White"
                                    Margin="8" />
                            <Button Style="{StaticResource QuickActionButtonStyle}"
                                    Content="Post Job"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="{StaticResource PrimaryBrush}"
                                    Margin="8" />
                            <Button Style="{StaticResource QuickActionButtonStyle}"
                                    Content="Log Attendance"
                                    Background="#E6F3FF"
                                    Foreground="{StaticResource PrimaryBrush}"
                                    Margin="8" />
                            <Button Style="{StaticResource QuickActionButtonStyle}"
                                    Content="Approve Leave"
                                    Background="#FFF3DD"
                                    Foreground="{StaticResource PrimaryBrush}"
                                    Margin="8" />
                            <Button Style="{StaticResource QuickActionButtonStyle}"
                                    Content="Generate Payroll"
                                    Background="#E6F3FF"
                                    Foreground="{StaticResource PrimaryBrush}"
                                    Margin="8" />
                            <Button Style="{StaticResource QuickActionButtonStyle}"
                                    Content="Assign Training"
                                    Background="#FFF3DD"
                                    Foreground="{StaticResource PrimaryBrush}"
                                    Margin="8" />
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#F9FCFF" CornerRadius="14" Padding="18" BorderBrush="#E5EDF7" BorderThickness="1" Margin="3,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="System Health" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                            <Rectangle Width="6" Height="6" Fill="{StaticResource AccentBrush}" RadiusX="2" RadiusY="2" Margin="8,0,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,12,0,0">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Active Users" Foreground="#6A7684" />
                                <ProgressBar Grid.Column="1" Height="12" Margin="12,0,0,0" Value="{Binding Stats.ActiveUsers}" Maximum="100" Foreground="{StaticResource PrimaryBrush}" Background="#E6F3FF" />
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Open Payroll Periods" Foreground="#6A7684" />
                                <ProgressBar Grid.Column="1" Height="12" Margin="12,0,0,0" Value="{Binding Stats.OpenPayrollPeriods}" Maximum="10" Foreground="{StaticResource AccentBrush}" Background="#FFF3DD" />
                            </Grid>

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Performance Cycles" Foreground="#6A7684" />
                                <ProgressBar Grid.Column="1" Height="12" Margin="12,0,0,0" Value="{Binding Stats.OpenPerformanceCycles}" Maximum="10" Foreground="{StaticResource PrimaryBrush}" Background="#E6F3FF" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Training content -->
            <Grid Grid.Row="1" Grid.RowSpan="2" Margin="20" Visibility="{Binding IsTrainingVisible, Converter={StaticResource BoolToVis}}">
                <local:TrainingWindow />
            </Grid>
            <!-- Recruitment content -->
            <Grid Grid.Row="1" Grid.RowSpan="2" Margin="20" Visibility="{Binding IsRecruitmentVisible, Converter={StaticResource BoolToVis}}">
                <local:RecruitmentWindow />
            </Grid>
            <!-- Performance content -->
            <Grid Grid.Row="1" Grid.RowSpan="2" Margin="20" Visibility="{Binding IsPerformanceVisible, Converter={StaticResource BoolToVis}}">
                <local:PerformanceWindow />
            </Grid>
            <!-- Users & Roles content -->
            <Grid Grid.Row="1" Grid.RowSpan="2" Margin="20" Visibility="{Binding IsUsersVisible, Converter={StaticResource BoolToVis}}">
                <local:UsersRolesWindow />
            </Grid>
            <!-- Employees -->
            <Grid Grid.Row="1" Grid.RowSpan="2" Margin="20" Visibility="{Binding IsEmployeesVisible, Converter={StaticResource BoolToVis}}">
                <local:EmployeesWindow />
            </Grid>
            <!-- Departments -->
            <Grid Grid.Row="1" Grid.RowSpan="2" Margin="20" Visibility="{Binding IsDepartmentsVisible, Converter={StaticResource BoolToVis}}">
                <local:DepartmentsWindow />
            </Grid>
            <!-- Attendance -->
            <Grid Grid.Row="1" Grid.RowSpan="2" Margin="20" Visibility="{Binding IsAttendanceVisible, Converter={StaticResource BoolToVis}}">
                <local:AttendanceWindow />
            </Grid>
            <!-- Leave -->
            <Grid Grid.Row="1" Grid.RowSpan="2" Margin="20" Visibility="{Binding IsLeaveVisible, Converter={StaticResource BoolToVis}}">
                <local:LeaveWindow />
            </Grid>
            <!-- Payroll -->
            <Grid Grid.Row="1" Grid.RowSpan="2" Margin="20" Visibility="{Binding IsPayrollVisible, Converter={StaticResource BoolToVis}}">
                <local:PayrollWindow />
            </Grid>
        </Grid>
    </Grid>
</Window>
