<Window x:Class="HRMS.View.LoginPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Login"
        Height="660"
        Width="1080"
        MinHeight="660"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{x:Null}"
        AllowsTransparency="True"
        WindowStyle="None"
        Loaded="LoginPage_OnLoaded"
        SizeChanged="LoginPage_OnSizeChanged"
        Style="{StaticResource MaterialDesignWindow}">

    <Window.Resources>
        <DropShadowEffect x:Key="LoginWindowShadow"
                          BlurRadius="26"
                          ShadowDepth="0"
                          Color="#66000000"
                          Opacity="0.45"/>

        <Style x:Key="LoginFieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#2F3A45"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SulopTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="13,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#233242"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#AEB7C1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#168FE0"/>
        </Style>

        <Style x:Key="SulopPasswordBoxStyle" TargetType="{x:Type PasswordBox}">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="13,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#233242"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#AEB7C1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ChromeIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#8D98A3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <materialDesign:Card
        UniformCornerRadius="0"
        Background="Transparent"
        Margin="36"
        ClipToBounds="True"
        Effect="{StaticResource LoginWindowShadow}"
        materialDesign:ElevationAssist.Elevation="Dp4">

        <materialDesign:DialogHost CloseOnClickAway="True"
                                   x:Name="DialogHost"
                                   materialDesign:TransitionAssist.DisableTransitions="True">

            <materialDesign:DialogHost.DialogContent>
                <Border Width="460"
                        Padding="20"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#DDE8F6"
                        BorderThickness="1">
                    <Border.Resources>
                        <Style x:Key="DbPopupInputStyle" TargetType="TextBox">
                            <Setter Property="Height" Value="42"/>
                            <Setter Property="BorderBrush" Value="#6C6C6C"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Background" Value="#FFFFFF"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="FontSize" Value="16"/>
                        </Style>
                    </Border.Resources>
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <materialDesign:PackIcon Grid.RowSpan="2"
                                                     Kind="DatabaseCogOutline"
                                                     Width="22"
                                                     Height="22"
                                                     Foreground="#1E4368"
                                                     VerticalAlignment="Top"
                                                     Margin="0,1,10,0"/>

                            <TextBlock Grid.Column="1"
                                       Grid.Row="0"
                                       Text="Database Connection"
                                       FontSize="19"
                                       FontWeight="Bold"
                                       Foreground="#1E4368"
                                       Margin="0,0,0,2"/>

                            <TextBlock x:Name="DbEndpointText"
                                       Grid.Column="1"
                                       Grid.Row="1"
                                       Foreground="#5B6A7A"
                                       FontSize="13"
                                       Visibility="Collapsed"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <RadioButton x:Name="LocalDbRadio"
                                         Content="Local"
                                         FontSize="15"
                                         Margin="0,0,18,0"
                                         Checked="DatabaseModeRadio_OnChecked"/>
                            <RadioButton x:Name="NetworkDbRadio"
                                         Content="Network (LAN)"
                                         FontSize="15"
                                         Margin="0,0,18,0"
                                         Checked="DatabaseModeRadio_OnChecked"/>
                            <RadioButton x:Name="RemoteDbRadio"
                                         Content="Remote"
                                         FontSize="15"
                                         Checked="DatabaseModeRadio_OnChecked"/>
                        </StackPanel>

                        <Border Background="#EAF4FF"
                                BorderBrush="#D6E8FF"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,0,0,12">
                            <TextBlock x:Name="DbModeHintText"
                                       Foreground="#2D5783"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Background="#F7FAFF"
                                BorderBrush="#D8E5F4"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <TextBlock Foreground="#5B6A7A"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Text="Detailed HRMS, GGMS, and CRS server credentials are hidden on the login screen. Use this setup only to switch the saved connection preset. Full database management stays inside the admin module after sign-in."/>
                        </Border>

                        <StackPanel Visibility="Collapsed">
                            <TextBlock Text="HRMS Database"
                                       Foreground="#1E4368"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Server / Host" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="DbHostTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0">
                                    <TextBlock Text="Port" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="DbPortTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Database" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="DbNameTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Username" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="DbUsernameTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Password" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="DbPasswordTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="GGMS Shared Database"
                                       Foreground="#1E4368"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,6"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="GGMS Host" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SulopHostTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0">
                                    <TextBlock Text="Port" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SulopPortTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Database" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SulopNameTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Username" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SulopUsernameTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Password" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SulopPasswordTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="CRS Shared Database"
                                       Foreground="#1E4368"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,6"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="CRS Host" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="CrsHostTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0">
                                    <TextBlock Text="Port" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="CrsPortTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Database" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="CrsNameTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Username" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="CrsUsernameTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Password" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="CrsPasswordTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Height="40"
                                    FontSize="14"
                                    Margin="0,0,8,0"
                                    Click="TestDatabaseConnectionButton_OnClick"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="DatabaseSearchOutline" Width="16" Height="16" Margin="0,0,5,0"/>
                                    <TextBlock Text="Test All 3"/>
                                </StackPanel>
                            </Button>
                                <Button Grid.Column="1"
                                    Height="40"
                                        FontSize="14"
                                    Foreground="White"
                                    Background="#1E4368"
                                    BorderThickness="0"
                                    Click="SaveDatabaseSettingsButton_OnClick"
                                    Style="{StaticResource MaterialDesignFlatMidBgButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16" Margin="0,0,5,0"/>
                                    <TextBlock Text="Save"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DbStatusText"
                                       Foreground="#4A5B6C"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Text="Not tested"/>
                            <Button Grid.Column="1"
                                    Content="Close"
                                    FontSize="14"
                                    Margin="10,0,0,0"
                                    Padding="10,0"
                                    Click="CloseDbDialogButton_OnClick"
                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </materialDesign:DialogHost.DialogContent>

            <Grid Background="#F8FFFFFF"
                  SnapsToDevicePixels="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="IdentityColumn" Width="1.02*" />
                    <ColumnDefinition x:Name="LoginColumn" Width="0.98*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="IdentityPanel"
                        Grid.Column="0"
                        Background="#168FE0"
                        ClipToBounds="True">
                    <Grid>
                        <Image Source="/Images/sulop_municipal_hall.jpg"
                               Stretch="UniformToFill"
                               Opacity="0.68"/>
                        <Rectangle Fill="#CC168FE0"/>
                        <Rectangle Height="5"
                                   Fill="#FFD21E"
                                   VerticalAlignment="Top"/>

                        <Viewbox Stretch="Uniform"
                                 StretchDirection="DownOnly"
                                 Margin="58,64,58,52"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center">
                            <StackPanel Width="430"
                                        HorizontalAlignment="Center">
                                <Border Width="132"
                                        Height="132"
                                        Background="White"
                                        BorderBrush="#EAF2FA"
                                        BorderThickness="1"
                                        HorizontalAlignment="Center">
                                    <Image Source="/Images/sulop_seal.jpg"
                                           Stretch="Uniform"
                                           Margin="8"/>
                                </Border>

                                <TextBlock Text="Republic of the Philippines"
                                           Foreground="#EAF7FF"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           Margin="0,22,0,2"/>
                                <TextBlock Text="Province of Davao del Sur"
                                           Foreground="#EAF7FF"
                                           FontSize="12"
                                           TextAlignment="Center"/>

                                <TextBlock Text="Municipality of Sulop"
                                           Foreground="White"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="Human Resource Management System"
                                           Foreground="#D9F0FF"
                                           FontSize="14"
                                           TextAlignment="Center"
                                           Margin="0,5,0,0"/>

                                <StackPanel Margin="0,34,0,0"
                                            HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,0,0,7">
                                        <materialDesign:PackIcon Kind="MapMarkerOutline"
                                                                 Width="15"
                                                                 Height="15"
                                                                 Foreground="#EAF7FF"
                                                                 Margin="0,0,8,0"/>
                                        <TextBlock Text="Josefa Ext., Sulop"
                                                   Foreground="#EAF7FF"
                                                   FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,0,0,7">
                                        <materialDesign:PackIcon Kind="EmailOutline"
                                                                 Width="15"
                                                                 Height="15"
                                                                 Foreground="#EAF7FF"
                                                                 Margin="0,0,8,0"/>
                                        <TextBlock Text="hr@sulop.gov.ph"
                                                   Foreground="#EAF7FF"
                                                   FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="PhoneOutline"
                                                                 Width="15"
                                                                 Height="15"
                                                                 Foreground="#EAF7FF"
                                                                 Margin="0,0,8,0"/>
                                        <TextBlock Text="(082) 000-0000"
                                                   Foreground="#EAF7FF"
                                                   FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Text="Empowering Sulop, Building Futures"
                                           Foreground="#CBEFFF"
                                           FontSize="13"
                                           FontStyle="Italic"
                                           TextAlignment="Center"
                                           Margin="0,36,0,0"/>
                            </StackPanel>
                        </Viewbox>
                    </Grid>
                </Border>

                <Grid Grid.Column="1"
                      Background="#FCFCFC">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,16,18,0">
                        <Button Style="{StaticResource ChromeIconButtonStyle}"
                                ToolTip="Minimize"
                                Click="MinimizeApp">
                            <materialDesign:PackIcon Kind="WindowMinimize"
                                                     Width="16"
                                                     Height="16"/>
                        </Button>
                        <Button Style="{StaticResource ChromeIconButtonStyle}"
                                ToolTip="Close"
                                Click="exitApp">
                            <materialDesign:PackIcon Kind="Close"
                                                     Width="16"
                                                     Height="16"/>
                        </Button>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid MinHeight="560">
                            <StackPanel Width="338"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="0,8,0,28">
                                <Border Width="104"
                                        Height="104"
                                        Background="#F2F8FE"
                                        BorderBrush="#E6F0FA"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,12">
                                    <Image Source="{Binding CompanyLogoPath}"
                                           Stretch="Uniform"
                                           Margin="14"/>
                                </Border>

                                <TextBlock Text="HRMS"
                                           Foreground="#168FE0"
                                           FontSize="27"
                                           FontWeight="Bold"
                                           TextAlignment="Center"/>
                                <TextBlock Text="Human Resources Management System"
                                           Foreground="#8B96A1"
                                           FontSize="12"
                                           TextAlignment="Center"
                                           Margin="0,1,0,32"/>

                                <TextBlock Text="Sign in to your account"
                                           Foreground="#2E3944"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Margin="0,0,0,14"/>

                                <Border Margin="0,0,0,18"
                                        Padding="12,10"
                                        Background="#F2F8FE"
                                        BorderBrush="#D9EAF8"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="Login credentials guide"
                                                   Foreground="#2F3A45"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,6"/>

                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="76"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Admin"
                                                       Foreground="#5E6A75"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1"
                                                       Foreground="#168FE0"
                                                       FontSize="12">
                                                <Run Text="admin"/>
                                                <Run Text=" / "/>
                                                <Run Text="admin"/>
                                            </TextBlock>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="76"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Employee"
                                                       Foreground="#5E6A75"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1"
                                                       Foreground="#168FE0"
                                                       FontSize="12">
                                                <Run Text="emp1"/>
                                                <Run Text=" / "/>
                                                <Run Text="admin123"/>
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Username"
                                           Style="{StaticResource LoginFieldLabelStyle}"/>
                                <TextBox x:Name="UsernameTextBox"
                                         Style="{StaticResource SulopTextBoxStyle}"
                                         TextChanged="UsernameTextBox_OnTextChanged"
                                         KeyDown="UsernameTextBox_OnKeyDown"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="Password"
                                           Style="{StaticResource LoginFieldLabelStyle}"
                                           Margin="0,18,0,6"/>
                                <PasswordBox x:Name="PasswordBox"
                                             Style="{StaticResource SulopPasswordBoxStyle}"
                                             PasswordChanged="PasswordBox_OnPasswordChanged"
                                             KeyDown="PasswordBox_OnKeyDown"/>

                                <TextBlock x:Name="LoginErrorText"
                                           Margin="0,10,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="#D32F2F"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed"/>

                                <Button x:Name="loginBtn"
                                        Margin="0,22,0,0"
                                        Height="48"
                                        Foreground="White"
                                        Background="#168FE0"
                                        BorderBrush="#168FE0"
                                        BorderThickness="0"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Command="{Binding LoginCommand}"
                                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                        materialDesign:ButtonAssist.CornerRadius="0"
                                        materialDesign:ElevationAssist.Elevation="Dp0"
                                        Content="SIGN IN"/>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,18,0,0">
                                    <TextBlock Text="Don't have an account?"
                                               VerticalAlignment="Center"
                                               Foreground="#8B96A1"
                                               FontSize="12"/>
                                    <Button x:Name="signupBtn"
                                            Content="Request here"
                                            Margin="4,0,0,0"
                                            Padding="4,0"
                                            MinWidth="0"
                                            Height="28"
                                            Foreground="#168FE0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Click="RequestAccessButton_OnClick"
                                            Style="{StaticResource MaterialDesignFlatButton}"/>
                                </StackPanel>

                                <Border x:Name="ConfigureEntryPanel"
                                        Margin="0,22,0,0"
                                        Padding="13,11"
                                        Background="#FFFFF8F0"
                                        BorderBrush="#F0A64C"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Need assistance?"
                                                       Foreground="#D87916"
                                                       FontWeight="Bold"
                                                       FontSize="12"/>
                                            <TextBlock Text="Configure the database connection."
                                                       Foreground="#8A673D"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Width="32"
                                                Height="32"
                                                Padding="0"
                                                Foreground="#D87916"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                ToolTip="Database setup"
                                                Click="OpenDatabaseDialogButton_OnClick"
                                                Style="{StaticResource MaterialDesignFlatButton}">
                                            <materialDesign:PackIcon Kind="CogOutline"
                                                                     Width="18"
                                                                     Height="18"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </materialDesign:DialogHost>
    </materialDesign:Card>
</Window>
