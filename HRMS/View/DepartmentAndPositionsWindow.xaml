<UserControl x:Class="HRMS.View.DepartmentAndPositionsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             Background="White">
    <UserControl.Resources>
        <Color x:Key="PrimaryColor">#1E4368</Color>
        <Color x:Key="LightColor">#CBE9FE</Color>
        <Color x:Key="AccentColor">#FDBD55</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="LightBrush" Color="{StaticResource LightColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5EDF7" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#F8FBFF" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.93" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#D93025" />
        </Style>

        <Style x:Key="SoftActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#EAF2FB" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
        </Style>

        <Style x:Key="ModuleDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="RowHeight" Value="44" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#F8FBFF" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E9F0FA" />
            <Setter Property="VerticalGridLinesBrush" Value="#E9F0FA" />
            <Setter Property="ColumnHeaderHeight" Value="42" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ColumnHeaderStyle" Value="{DynamicResource ModuleHeaderStyle}" />
            <Setter Property="RowStyle" Value="{DynamicResource ModuleRowStyle}" />
            <Setter Property="CellStyle" Value="{DynamicResource ModuleCellStyle}" />
        </Style>

        <Style x:Key="ModuleHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F2F7FD" />
            <Setter Property="Foreground" Value="#1E4368" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#E3ECF8" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,0,8,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ModuleCenteredHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModuleHeaderStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ModuleRowStyle" TargetType="DataGridRow">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#1E4368" />
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F1FC" />
                    <Setter Property="Foreground" Value="#1E4368" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModuleCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,0,8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="ModuleCellTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="CenterCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ModuleCellTextStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Background="White" Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Domain"
                                             Width="34"
                                             Height="32"
                                             Margin="0,0,10,0"
                                             Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="Department &amp; Position Administration"
                               FontSize="25"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
                <TextBlock Text="Monitor organizational structure health, staffing balance, and vacant slots."
                           Margin="0,2,0,0"
                           Foreground="#5B6A7A" />
                <TextBlock Text="{Binding LastRefreshed, StringFormat=Last refreshed: {0:MMM dd, yyyy h:mm tt}}"
                           Margin="0,4,0,0"
                           Foreground="#6A7684" />
            </StackPanel>

            <Button Grid.Column="1"
                    Width="140"
                    Height="42"
                    VerticalAlignment="Center"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="Refresh_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,8,0" />
                    <TextBlock Text="Refresh" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,12"
                Style="{StaticResource CardStyle}"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Kind="Magnify"
                                         Width="16"
                                         Height="16"
                                         Margin="0,0,6,0"
                                         Foreground="#7C8DA4"
                                         VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="14"
                         Foreground="#1E4368"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Search department, position, or status"
                         materialDesign:HintAssist.Hint="Search department, position, or status..." />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,12"
                Style="{StaticResource CardStyle}"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.5*" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="Department Management"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="Create or remove departments."
                               Foreground="#6A7684"
                               Margin="0,2,0,8" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DepartmentNameTextBox"
                                 Height="38"
                                 Margin="0,0,8,0"
                                 VerticalContentAlignment="Center"
                                 materialDesign:HintAssist.Hint="New department name" />
                        <Button Grid.Column="1"
                                Width="130"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="AddDepartment_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Add Department" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="DeleteDepartmentComboBox"
                                  Height="38"
                                  Margin="0,0,8,0"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Name"
                                  ItemsSource="{Binding DepartmentRows}"
                                  VerticalContentAlignment="Center" />
                        <Button Grid.Column="1"
                                Width="78"
                                Margin="0,0,8,0"
                                Style="{StaticResource SoftActionButtonStyle}"
                                Click="ClearDeleteDepartmentSelection_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CloseCircleOutline" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Clear" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2"
                                Width="130"
                                Style="{StaticResource DangerActionButtonStyle}"
                                Click="DeleteDepartment_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Delete Department" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="Position Management"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="Select a department, then add or delete positions."
                               Foreground="#6A7684"
                               Margin="0,2,0,8" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="PositionDepartmentComboBox"
                                  Height="38"
                                  Margin="0,0,8,0"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Name"
                                  ItemsSource="{Binding DepartmentRows}"
                                  SelectionChanged="PositionDepartmentComboBox_SelectionChanged"
                                  VerticalContentAlignment="Center" />
                        <Button Grid.Column="1"
                                Width="78"
                                Margin="0,0,8,0"
                                Style="{StaticResource SoftActionButtonStyle}"
                                Click="ClearAddPositionDepartmentSelection_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CloseCircleOutline" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Clear" />
                            </StackPanel>
                        </Button>
                        <TextBox Grid.Column="2"
                                 x:Name="PositionNameTextBox"
                                 Height="38"
                                 Margin="0,0,8,0"
                                 VerticalContentAlignment="Center"
                                 materialDesign:HintAssist.Hint="New position name" />
                        <Button Grid.Column="3"
                                Width="120"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="AddPosition_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Add Position" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ExistingPositionDepartmentComboBox"
                                  Height="38"
                                  Margin="0,0,8,0"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Name"
                                  ItemsSource="{Binding DepartmentRows}"
                                  SelectionChanged="ExistingPositionDepartmentComboBox_SelectionChanged"
                                  VerticalContentAlignment="Center" />
                        <Button Grid.Column="1"
                                Width="78"
                                Margin="0,0,8,0"
                                Style="{StaticResource SoftActionButtonStyle}"
                                Click="ClearDeletePositionDepartmentSelection_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CloseCircleOutline" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Clear" />
                            </StackPanel>
                        </Button>
                        <ComboBox Grid.Column="2"
                                  x:Name="DeletePositionComboBox"
                                  Height="38"
                                  Margin="0,0,8,0"
                                  VerticalContentAlignment="Center" />
                        <Button Grid.Column="3"
                                Width="78"
                                Margin="0,0,8,0"
                                Style="{StaticResource SoftActionButtonStyle}"
                                Click="ClearDeletePositionSelection_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CloseCircleOutline" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Clear" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="4"
                                Width="120"
                                Style="{StaticResource DangerActionButtonStyle}"
                                Click="DeletePosition_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Delete Position" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="3" Columns="5" Margin="0,0,0,12">
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="Departments" Foreground="#6A7684" />
                    <TextBlock Text="{Binding Departments}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="Positions" Foreground="#6A7684" />
                    <TextBlock Text="{Binding Positions}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="Employees" Foreground="#6A7684" />
                    <TextBlock Text="{Binding Employees}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}" Background="#FFF5F5" BorderBrush="#F7D4D4">
                <StackPanel>
                    <TextBlock Text="No Positions" Foreground="#8A3C3C" />
                    <TextBlock Text="{Binding DepartmentsWithoutPositions}" FontSize="24" FontWeight="Bold" Foreground="#B42318" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,0,0" Background="#FFF9EF" BorderBrush="#F5DEC0">
                <StackPanel>
                    <TextBlock Text="Vacant Positions" Foreground="#8A6131" />
                    <TextBlock Text="{Binding PositionsWithoutEmployees}" FontSize="24" FontWeight="Bold" Foreground="#B86900" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Department Coverage"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                    <DataGrid Grid.Row="1"
                              Margin="0,10,0,0"
                              Style="{StaticResource ModuleDataGridStyle}"
                              ItemsSource="{Binding DepartmentView}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Department"
                                                Binding="{Binding Name}"
                                                Width="2*"
                                                HeaderStyle="{StaticResource ModuleHeaderStyle}"
                                                ElementStyle="{StaticResource ModuleCellTextStyle}" />
                            <DataGridTextColumn Header="Positions"
                                                Binding="{Binding Positions}"
                                                Width="88"
                                                HeaderStyle="{StaticResource ModuleCenteredHeaderStyle}"
                                                ElementStyle="{StaticResource CenterCellTextStyle}" />
                            <DataGridTextColumn Header="Employees"
                                                Binding="{Binding Employees}"
                                                Width="88"
                                                HeaderStyle="{StaticResource ModuleCenteredHeaderStyle}"
                                                ElementStyle="{StaticResource CenterCellTextStyle}" />
                            <DataGridTextColumn Header="Emp/Pos"
                                                Binding="{Binding EmployeesPerPosition, StringFormat={}{0:0.##}}"
                                                Width="88"
                                                HeaderStyle="{StaticResource ModuleCenteredHeaderStyle}"
                                                ElementStyle="{StaticResource CenterCellTextStyle}" />
                            <DataGridTemplateColumn Header="Health" Width="110" HeaderStyle="{StaticResource ModuleCenteredHeaderStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10"
                                                Padding="10,3"
                                                MinWidth="80"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#34A853" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Health}" Value="No Positions">
                                                            <Setter Property="Background" Value="#D93025" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Health}" Value="No Staff">
                                                            <Setter Property="Background" Value="#F9AB00" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Health}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       TextAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Position Allocation"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                    <DataGrid Grid.Row="1"
                              Margin="0,10,0,0"
                              Style="{StaticResource ModuleDataGridStyle}"
                              ItemsSource="{Binding PositionView}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Position"
                                                Binding="{Binding Name}"
                                                Width="1.6*"
                                                HeaderStyle="{StaticResource ModuleHeaderStyle}"
                                                ElementStyle="{StaticResource ModuleCellTextStyle}" />
                            <DataGridTextColumn Header="Department"
                                                Binding="{Binding Department}"
                                                Width="1.6*"
                                                HeaderStyle="{StaticResource ModuleHeaderStyle}"
                                                ElementStyle="{StaticResource ModuleCellTextStyle}" />
                            <DataGridTextColumn Header="Employees"
                                                Binding="{Binding Employees}"
                                                Width="88"
                                                HeaderStyle="{StaticResource ModuleCenteredHeaderStyle}"
                                                ElementStyle="{StaticResource CenterCellTextStyle}" />
                            <DataGridTemplateColumn Header="Status" Width="110" HeaderStyle="{StaticResource ModuleCenteredHeaderStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10"
                                                Padding="10,3"
                                                MinWidth="80"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#34A853" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Vacant">
                                                            <Setter Property="Background" Value="#D93025" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       TextAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="5"
                Margin="0"
                Style="{StaticResource CardStyle}"
                Background="#F6FAFF"
                BorderBrush="#DDE9F7"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Admin Insight" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="{Binding AvgPositionsPerDepartment, StringFormat=Average positions per department: {0:0.##}}" Foreground="#4B5E75" />
                    <TextBlock Text="{Binding AvgEmployeesPerDepartment, StringFormat=Average employees per department: {0:0.##}}" Foreground="#4B5E75" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Priority Actions" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="{Binding DepartmentsWithoutPositions, StringFormat=Departments needing position setup: {0}}" Foreground="#4B5E75" />
                    <TextBlock Text="{Binding PositionsWithoutEmployees, StringFormat=Vacant positions needing assignment: {0}}" Foreground="#4B5E75" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
