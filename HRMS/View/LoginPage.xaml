<Window x:Class="HRMS.View.LoginPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Login"
        Height="760"
        Width="1180"
        MinHeight="760"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{x:Null}"
        AllowsTransparency="True"
        WindowStyle="None"
        Loaded="LoginPage_OnLoaded"
        SizeChanged="LoginPage_OnSizeChanged"
        Style="{StaticResource MaterialDesignWindow}">

    <materialDesign:Card
        UniformCornerRadius="15"
        Background="{DynamicResource MaterialDesignPaper}"
        Margin="25"
        materialDesign:ElevationAssist.Elevation="Dp4">

        <materialDesign:DialogHost CloseOnClickAway="True"
                                   x:Name="DialogHost"
                                   materialDesign:TransitionAssist.DisableTransitions="True">

            <materialDesign:DialogHost.DialogContent>
                <Border Width="460"
                        Padding="20"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#DDE8F6"
                        BorderThickness="1">
                    <Border.Resources>
                        <Style x:Key="DbPopupInputStyle" TargetType="TextBox">
                            <Setter Property="Height" Value="42"/>
                            <Setter Property="BorderBrush" Value="#6C6C6C"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Background" Value="#FFFFFF"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="FontSize" Value="16"/>
                        </Style>
                    </Border.Resources>
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <materialDesign:PackIcon Grid.RowSpan="2"
                                                     Kind="DatabaseCogOutline"
                                                     Width="22"
                                                     Height="22"
                                                     Foreground="#1E4368"
                                                     VerticalAlignment="Top"
                                                     Margin="0,1,10,0"/>

                            <TextBlock Grid.Column="1"
                                       Grid.Row="0"
                                       Text="Database Connection"
                                       FontSize="19"
                                       FontWeight="Bold"
                                       Foreground="#1E4368"
                                       Margin="0,0,0,2"/>

                            <TextBlock x:Name="DbEndpointText"
                                       Grid.Column="1"
                                       Grid.Row="1"
                                       Foreground="#5B6A7A"
                                       FontSize="13"
                                       Visibility="Collapsed"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <RadioButton x:Name="LocalDbRadio"
                                         Content="Local"
                                         FontSize="15"
                                         Margin="0,0,18,0"
                                         Checked="DatabaseModeRadio_OnChecked"/>
                            <RadioButton x:Name="NetworkDbRadio"
                                         Content="Network (LAN)"
                                         FontSize="15"
                                         Margin="0,0,18,0"
                                         Checked="DatabaseModeRadio_OnChecked"/>
                            <RadioButton x:Name="RemoteDbRadio"
                                         Content="Remote"
                                         FontSize="15"
                                         Checked="DatabaseModeRadio_OnChecked"/>
                        </StackPanel>

                        <Border Background="#EAF4FF"
                                BorderBrush="#D6E8FF"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,0,0,12">
                            <TextBlock x:Name="DbModeHintText"
                                       Foreground="#2D5783"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Background="#F7FAFF"
                                BorderBrush="#D8E5F4"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12">
                            <TextBlock Foreground="#5B6A7A"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Text="Detailed HRMS, GGMS, and CRS server credentials are hidden on the login screen. Use this setup only to switch the saved connection preset. Full database management stays inside the admin module after sign-in."/>
                        </Border>

                        <StackPanel Visibility="Collapsed">
                            <TextBlock Text="HRMS Database"
                                       Foreground="#1E4368"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Server / Host" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="DbHostTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0">
                                    <TextBlock Text="Port" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="DbPortTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Database" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="DbNameTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Username" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="DbUsernameTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Password" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="DbPasswordTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="GGMS Shared Database"
                                       Foreground="#1E4368"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,6"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="GGMS Host" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SulopHostTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0">
                                    <TextBlock Text="Port" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SulopPortTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Database" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SulopNameTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Username" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SulopUsernameTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Password" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SulopPasswordTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="CRS Shared Database"
                                       Foreground="#1E4368"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,6"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="CRS Host" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="CrsHostTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0">
                                    <TextBlock Text="Port" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="CrsPortTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Database" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="CrsNameTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Username" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="CrsUsernameTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Password" Foreground="#5B6A7A" FontSize="14" Margin="0,0,0,5"/>
                                    <TextBox x:Name="CrsPasswordTextBox"
                                             Style="{StaticResource DbPopupInputStyle}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Height="40"
                                    FontSize="14"
                                    Margin="0,0,8,0"
                                    Click="TestDatabaseConnectionButton_OnClick"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="DatabaseSearchOutline" Width="16" Height="16" Margin="0,0,5,0"/>
                                    <TextBlock Text="Test All 3"/>
                                </StackPanel>
                            </Button>
                                <Button Grid.Column="1"
                                    Height="40"
                                        FontSize="14"
                                    Foreground="White"
                                    Background="#1E4368"
                                    BorderThickness="0"
                                    Click="SaveDatabaseSettingsButton_OnClick"
                                    Style="{StaticResource MaterialDesignFlatMidBgButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16" Margin="0,0,5,0"/>
                                    <TextBlock Text="Save"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DbStatusText"
                                       Foreground="#4A5B6C"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Text="Not tested"/>
                            <Button Grid.Column="1"
                                    Content="Close"
                                    FontSize="14"
                                    Margin="10,0,0,0"
                                    Padding="10,0"
                                    Click="CloseDbDialogButton_OnClick"
                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </materialDesign:DialogHost.DialogContent>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="IdentityColumn" Width="1.02*" />
                    <ColumnDefinition x:Name="LoginColumn" Width="0.98*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="IdentityPanel"
                        Grid.Column="0"
                        Margin="18"
                        CornerRadius="18"
                        Padding="30"
                        Background="#1E4368">
                    <Viewbox Stretch="Uniform"
                             StretchDirection="DownOnly"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Center">
                        <StackPanel Width="520"
                                    HorizontalAlignment="Center">
                            <Border Padding="10,5"
                                    Background="#2D5783"
                                    BorderBrush="#4E78A2"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShieldCheckOutline"
                                                             Width="15"
                                                             Height="15"
                                                             Margin="0,0,6,0"
                                                             Foreground="#FDE5B4"
                                                             VerticalAlignment="Center" />
                                    <TextBlock Text="HRMS Secure Portal"
                                               Foreground="#FDE5B4"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border Width="188"
                                    Height="188"
                                    Margin="0,24,0,18"
                                    Background="White"
                                    BorderBrush="#D6E2F1"
                                    BorderThickness="1"
                                    CornerRadius="24"
                                    HorizontalAlignment="Center">
                                <Grid Margin="14">
                                    <Image Source="{Binding CompanyLogoPath}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0" />
                                </Grid>
                            </Border>

                            <TextBlock Text="Human Resources Management System"
                                       Foreground="White"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,14,0,0"
                                       Foreground="#DCEAF9"
                                       FontSize="15"
                                       LineHeight="23"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Text="Control employee records, attendance, payroll, recruitment, and document verification from one branded HRMS desktop workspace." />

                            <TextBlock Text="System Identity"
                                       Foreground="#FDE5B4"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,28,0,14"
                                       HorizontalAlignment="Center" />

                            <UniformGrid Columns="2"
                                         Margin="0,0,0,0">
                                <Border Background="#244A73"
                                        BorderBrush="#3C678F"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16"
                                        Margin="0,0,8,8"
                                        MinHeight="102">
                                    <StackPanel>
                                        <TextBlock Text="Company Name"
                                                   Foreground="#CFE2F5"
                                                   FontWeight="SemiBold"
                                                   FontSize="12" />
                                        <TextBlock Text="{Binding CompanyName}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="16"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#244A73"
                                        BorderBrush="#3C678F"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16"
                                        Margin="8,0,0,8"
                                        MinHeight="102">
                                    <StackPanel>
                                        <TextBlock Text="Address / Campus"
                                                   Foreground="#CFE2F5"
                                                   FontWeight="SemiBold"
                                                   FontSize="12" />
                                        <TextBlock Text="{Binding CompanyAddress}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="16"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#244A73"
                                        BorderBrush="#3C678F"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16"
                                        Margin="0,8,8,0"
                                        MinHeight="102">
                                    <StackPanel>
                                        <TextBlock Text="Company Owner"
                                                   Foreground="#CFE2F5"
                                                   FontWeight="SemiBold"
                                                   FontSize="12" />
                                        <TextBlock Text="{Binding CompanyOwner}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="16"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#244A73"
                                        BorderBrush="#3C678F"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16"
                                        Margin="8,8,0,0"
                                        MinHeight="102">
                                    <StackPanel>
                                        <TextBlock Text="Serial Number"
                                                   Foreground="#CFE2F5"
                                                   FontWeight="SemiBold"
                                                   FontSize="12" />
                                        <TextBlock Text="{Binding SerialNumber}"
                                                   Foreground="#FDE5B4"
                                                   FontWeight="Bold"
                                                   FontSize="16"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Margin="0,20,0,0"
                                    Padding="15,13"
                                    Background="#244A73"
                                    BorderBrush="#4E78A2"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="CheckDecagram"
                                                             Width="20"
                                                             Height="20"
                                                             Foreground="#FDE5B4"
                                                             VerticalAlignment="Top"
                                                             Margin="0,0,10,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Landscape Login Workspace"
                                                   Foreground="White"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="Balanced layout for widescreen sign-in and system identity."
                                                   Foreground="#DCEAF9"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Viewbox>
                </Border>

                <Grid Grid.Column="1"
                      Margin="0,0,18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <materialDesign:PopupBox HorizontalAlignment="Right"
                                             Margin="0,20,20,0"
                                             PlacementMode="BottomAndAlignRightEdges"
                                             StaysOpen="False"
                                             Height="25">
                        <StackPanel>
                            <StackPanel Margin="16,10,0,6"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <TextBlock VerticalAlignment="Center" Text="DarkMode" />

                                <ToggleButton Cursor="Hand"
                                              ToolTip="Enable Dark Mode"
                                              Margin="12,0,8,0"
                                              x:Name="themeToggle"
                                              IsChecked="{Binding IsDarkTheme}"
                                              Click="toggleTheme" />
                            </StackPanel>

                            <Button ToolTip="Having Trouble Logging In?"
                                    Margin="0,8,0,0"
                                    Content="Help" />

                            <Button x:Name="btn_exit"
                                    ToolTip="Close Application"
                                    Content="Exit Application"
                                    Click="exitApp" />
                        </StackPanel>
                    </materialDesign:PopupBox>

                    <Border Grid.Row="1"
                            Margin="24,18,10,18"
                            Padding="34,32"
                            Background="{DynamicResource MaterialDesignPaper}"
                            BorderBrush="#E2EAF5"
                            BorderThickness="1"
                            CornerRadius="18">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled" Margin="0,-15,0,-8">
                            <StackPanel MaxWidth="390"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top">
                                <Border Padding="10,5"
                                        Background="#F4F8FE"
                                        BorderBrush="#D8E5F4"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountCheckOutline"
                                                                 Width="15"
                                                                 Height="15"
                                                                 Margin="0,0,6,0"
                                                                 Foreground="#1E4368"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="Welcome Back"
                                                   Foreground="#1E4368"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Margin="0,10,0,4"
                                           HorizontalAlignment="Center"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="#12385C"
                                           Text="log In to HRMS" />

                                <TextBlock HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           FontSize="14"
                                           Foreground="#5B6A7A"
                                           TextWrapping="Wrap"
                                           Text="Use your assigned account credentials to access your HRMS control center." />

                                <Border Margin="0,20,0,0"
                                        Padding="12,10"
                                        Background="#EAF4FF"
                                        CornerRadius="10"
                                        BorderBrush="#B3D4F5"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="AccountKeyOutline"
                                                                     Width="15"
                                                                     Height="15"
                                                                     Foreground="#5B6A7A"
                                                                     Margin="0,0,6,0"
                                                                     VerticalAlignment="Center"/>
                                            <TextBlock FontSize="12"
                                                       Foreground="#5B6A7A"
                                                       FontWeight="SemiBold"
                                                       Text="Credentials" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <materialDesign:PackIcon Kind="ShieldAccountOutline"
                                                                     Width="14"
                                                                     Height="14"
                                                                     Foreground="#1E4368"
                                                                     Margin="0,0,6,0"
                                                                     VerticalAlignment="Center"/>
                                            <TextBlock FontSize="12"
                                                       Foreground="#1E4368">
                                                <Run FontWeight="SemiBold">Admin:</Run>
                                                <Run> admin</Run>
                                                <Run> / </Run>
                                                <Run>admin</Run>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <materialDesign:PackIcon Kind="AccountOutline"
                                                                     Width="14"
                                                                     Height="14"
                                                                     Foreground="#1E4368"
                                                                     Margin="0,0,6,0"
                                                                     VerticalAlignment="Center"/>
                                            <TextBlock FontSize="12"
                                                       Foreground="#1E4368">
                                                <Run FontWeight="SemiBold">Employee:</Run>
                                                <Run> emp1</Run>
                                                <Run> / </Run>
                                                <Run>admin123</Run>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBox Margin="0,22,0,0"
                                         FontSize="15"
                                         x:Name="UsernameTextBox"
                                         TextChanged="UsernameTextBox_OnTextChanged"
                                         KeyDown="UsernameTextBox_OnKeyDown"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Enter Username"
                                         materialDesign:HintAssist.IsFloating="True"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                                <PasswordBox Margin="0,18,0,0"
                                             FontSize="15"
                                             PasswordChanged="PasswordBox_OnPasswordChanged"
                                             KeyDown="PasswordBox_OnKeyDown"
                                             x:Name="PasswordBox"
                                             materialDesign:HintAssist.Hint="Enter Password"
                                             materialDesign:HintAssist.IsFloating="True"
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}" />

                                <TextBlock x:Name="LoginErrorText"
                                           Margin="0,10,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="#D32F2F"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed" />

                                <Button Margin="0,24,0,0"
                                        x:Name="loginBtn"
                                        Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                                        Background="{DynamicResource PrimaryHueMidBrush}"
                                        BorderThickness="0"
                                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                        materialDesign:ElevationAssist.Elevation="Dp0"
                                        Height="50"
                                        materialDesign:ButtonAssist.CornerRadius="10"
                                        FontSize="15"
                                        Command="{Binding LoginCommand}"
                                        Content="LOG IN" />

                                <Button Margin="0,12,0,0"
                                        x:Name="signupBtn"
                                        Foreground="#1F4E79"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        materialDesign:ElevationAssist.Elevation="Dp0"
                                        Height="50"
                                        materialDesign:ButtonAssist.CornerRadius="10"
                                        FontSize="15"
                                        Click="RequestAccessButton_OnClick"
                                        Content="Request Access" />

                                <Border x:Name="ConfigureEntryPanel"
                                    Margin="0,18,0,0"
                                        Padding="14,12"
                                        Background="#F7FAFF"
                                        BorderBrush="#D8E5F4"
                                        BorderThickness="1"
                                    CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Need connection setup? OTP required."
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Foreground="#5B6A7A" />

                                        <Button Grid.Column="1"
                                                Padding="4,2"
                                                Foreground="#1E4368"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                Click="OpenDatabaseDialogButton_OnClick">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ShieldLockOutline"
                                                                         Width="16"
                                                                         Height="16"
                                                                         Margin="0,0,6,0"
                                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="Setup"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </materialDesign:DialogHost>
    </materialDesign:Card>
</Window>
