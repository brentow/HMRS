<UserControl x:Class="HRMS.View.AdjustmentsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             Background="White">

    <UserControl.Resources>
        <Color x:Key="PrimaryColor">#1E4368</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="130" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="Background" Value="#D84343" />
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SuccessActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="Background" Value="#2E9D5B" />
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F2F7FD" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#E3ECF8" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,0,8,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0,10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Left" />
            <Setter Property="TextBlock.VerticalAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="GridCellCenterStyle" TargetType="DataGridCell" BasedOn="{StaticResource GridCellStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridTextLeftStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextAlignment" Value="Left" />
        </Style>

        <Style x:Key="GridTextCenterStyle" TargetType="TextBlock" BasedOn="{StaticResource GridTextLeftStyle}">
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#1E4368" />
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F1FC" />
                    <Setter Property="Foreground" Value="#1E4368" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#D5E3F5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FBFF"/>
        </Style>

        <Style x:Key="FormDatePickerStyle" TargetType="DatePicker" BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Language" Value="en-GB"/>
            <Setter Property="SelectedDateFormat" Value="Short"/>
            <Style.Resources>
                <Style TargetType="{x:Type DatePickerTextBox}">
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="8,0,28,0"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="DateFieldBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="BorderBrush" Value="#D5E3F5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="White" Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="FileDocumentEditOutline" Width="34" Height="32" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,10,0" />
                    <TextBlock Text="{Binding AdjustmentsPageTitle}" FontSize="25" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
                <TextBlock Text="{Binding AdjustmentsPageSubtitle}" Foreground="#5B6A7A" Margin="0,2,0,0" />
            </StackPanel>

            <Button Grid.Column="1"
                    Width="140"
                    Height="42"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Command="{Binding RefreshCommand}"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,8,0" />
                    <TextBlock Text="Refresh" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <Border CornerRadius="14" BorderBrush="#E5EDF7" BorderThickness="1" Padding="14" Margin="6" Background="#FFF5F5">
                <StackPanel>
                    <TextBlock Text="{Binding PendingAdjustmentsCardLabel}" Foreground="#6A7684" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PendingAdjustments}" FontSize="28" FontWeight="Bold" Foreground="#D84343"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="14" BorderBrush="#E5EDF7" BorderThickness="1" Padding="14" Margin="6" Background="#F2FBF5">
                <StackPanel>
                    <TextBlock Text="{Binding ApprovedAdjustmentsCardLabel}" Foreground="#6A7684" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ApprovedAdjustments}" FontSize="28" FontWeight="Bold" Foreground="#2E9D5B"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="14" BorderBrush="#E5EDF7" BorderThickness="1" Padding="14" Margin="6" Background="#FFF5F5">
                <StackPanel>
                    <TextBlock Text="{Binding RejectedAdjustmentsCardLabel}" Foreground="#6A7684" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding RejectedAdjustments}" FontSize="28" FontWeight="Bold" Foreground="#D84343"/>
                </StackPanel>
            </Border>
            <Border CornerRadius="14" BorderBrush="#E5EDF7" BorderThickness="1" Padding="14" Margin="6" Background="#F5FBFF">
                <StackPanel>
                    <TextBlock Text="{Binding FourthAdjustmentsCardLabel}" Foreground="#6A7684" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding FourthAdjustmentsCardValue}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2"
                Margin="6,0,6,12"
                Padding="12"
                BorderBrush="#E5EDF7"
                BorderThickness="1"
                Background="White"
                CornerRadius="12"
                Visibility="{Binding IsEmployeeMode, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="File Adjustment Request"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="0,0,0,10"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Work Date" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Border Style="{StaticResource DateFieldBorderStyle}">
                            <DatePicker Style="{StaticResource FormDatePickerStyle}"
                                        SelectedDate="{Binding NewAdjustmentWorkDate}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Time In" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource FormTextBoxStyle}"
                                 Text="{Binding NewAdjustmentTimeInText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Time Out" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource FormTextBoxStyle}"
                                 Text="{Binding NewAdjustmentTimeOutText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                        <TextBlock Text="Reason" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource FormTextBoxStyle}"
                                 Text="{Binding NewAdjustmentReason, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <Button Grid.Column="4"
                            Margin="0,22,0,0"
                            Height="40"
                            MinWidth="150"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding SubmitAdjustmentRequestCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="SendOutline" Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Submit Request"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="3" Margin="6,0,6,12" Padding="12" BorderBrush="#E5EDF7" BorderThickness="1" Background="White" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F2F7FD" BorderBrush="#E0EAF6" BorderThickness="1" CornerRadius="10" Padding="10,6" Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="#7A8FA5" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="14"
                                 Foreground="#5B6A7A"
                                 Text="{Binding AdjustmentSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center"
                                 materialDesign:HintAssist.Hint="{Binding AdjustmentSearchHint}" />
                    </Grid>
                </Border>

                <ComboBox Grid.Column="1"
                          Height="40"
                          ItemsSource="{Binding AdjustmentStatusFilters}"
                          SelectedItem="{Binding SelectedAdjustmentStatusFilter}" />
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Margin="6,0,6,12"
                Padding="12"
                BorderBrush="#E5EDF7"
                BorderThickness="1"
                Background="#F9FBFF"
                CornerRadius="12"
                Visibility="{Binding IsAdminOrHrMode, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="Selected Request" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Foreground="#5B6A7A" Margin="0,3,0,0" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text">
                                    <Setter.Value>
                                        <MultiBinding StringFormat="ID #{0} | {1} | {2} | {3}">
                                            <Binding Path="SelectedAdjustment.AdjustmentId" />
                                            <Binding Path="SelectedAdjustment.EmployeeNo" />
                                            <Binding Path="SelectedAdjustment.WorkDateText" />
                                            <Binding Path="SelectedAdjustment.Status" />
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAdjustment}" Value="{x:Null}">
                                        <Setter Property="Text" Value="No request selected." />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <TextBox Grid.Row="1"
                         Grid.Column="0"
                         Grid.ColumnSpan="2"
                         Height="40"
                         Margin="0,10,0,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding AdjustmentDecisionReason, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Decision reason (required for reject)" />

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Button Style="{StaticResource SuccessActionButtonStyle}"
                            MinWidth="130"
                            Height="40"
                            Margin="0,0,8,0"
                            Command="{Binding ApproveAdjustmentCommand}"
                            CommandParameter="{Binding SelectedAdjustment}">
                        <TextBlock Text="Approve" />
                    </Button>
                    <Button Style="{StaticResource DangerActionButtonStyle}"
                            MinWidth="130"
                            Height="40"
                            Command="{Binding RejectAdjustmentCommand}"
                            CommandParameter="{Binding SelectedAdjustment}">
                        <TextBlock Text="Reject" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="5" Margin="6,0,6,6" Padding="14" CornerRadius="14" BorderBrush="#E5EDF7" BorderThickness="1" Background="White">
            <DataGrid ItemsSource="{Binding Adjustments}"
                      SelectedItem="{Binding SelectedAdjustment}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="1"
                      BorderBrush="#E3ECF8"
                      RowHeaderWidth="0"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FBFF"
                      HorizontalGridLinesBrush="#E9F0FA"
                      VerticalGridLinesBrush="#E9F0FA"
                      ColumnHeaderHeight="42"
                      RowHeight="50"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.ColumnHeaderStyle>
                    <Style BasedOn="{StaticResource GridHeaderStyle}" TargetType="DataGridColumnHeader" />
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style BasedOn="{StaticResource GridCellStyle}" TargetType="DataGridCell" />
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style BasedOn="{StaticResource GridRowStyle}" TargetType="DataGridRow" />
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Emp No" Binding="{Binding EmployeeNo}" Width="105" ElementStyle="{StaticResource GridTextCenterStyle}" />
                    <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="200" ElementStyle="{StaticResource GridTextLeftStyle}" />
                    <DataGridTextColumn Header="Work Date" Binding="{Binding WorkDateText}" Width="120" ElementStyle="{StaticResource GridTextCenterStyle}" />
                    <DataGridTextColumn Header="Requested In" Binding="{Binding RequestedInText}" Width="110" ElementStyle="{StaticResource GridTextCenterStyle}" />
                    <DataGridTextColumn Header="Requested Out" Binding="{Binding RequestedOutText}" Width="115" ElementStyle="{StaticResource GridTextCenterStyle}" />
                    <DataGridTemplateColumn Header="Status" Width="120">
                        <DataGridTemplateColumn.CellStyle>
                            <Style BasedOn="{StaticResource GridCellCenterStyle}" TargetType="DataGridCell" />
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding StatusBrush}" CornerRadius="8" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="SemiBold" FontSize="11" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="235" ElementStyle="{StaticResource GridTextLeftStyle}" />
                    <DataGridTextColumn Header="Decision Reason" Binding="{Binding DecisionRemarks}" Width="180" ElementStyle="{StaticResource GridTextLeftStyle}" />
                    <DataGridTextColumn Header="Requested At" Binding="{Binding RequestedAtText}" Width="165" ElementStyle="{StaticResource GridTextCenterStyle}" />
                    <DataGridTextColumn Header="Decided At" Binding="{Binding DecidedAtText}" Width="165" ElementStyle="{StaticResource GridTextCenterStyle}" />
                    <DataGridTemplateColumn Header="Action" Width="220">
                        <DataGridTemplateColumn.CellStyle>
                            <Style BasedOn="{StaticResource GridCellCenterStyle}" TargetType="DataGridCell" />
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Visibility="{Binding DataContext.IsAdminOrHrMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
                                        <Button Style="{StaticResource SuccessActionButtonStyle}"
                                                MinWidth="92"
                                                Command="{Binding DataContext.ApproveAdjustmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,6,0">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="CheckBold" Width="13" Height="13" Margin="0,0,6,0" />
                                                <TextBlock Text="Approve" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource DangerActionButtonStyle}"
                                                MinWidth="92"
                                                Command="{Binding DataContext.RejectAdjustmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="CloseThick" Width="12" Height="12" Margin="0,0,6,0" />
                                                <TextBlock Text="Reject" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <Button HorizontalAlignment="Center"
                                            Height="34"
                                            MinWidth="110"
                                            Command="{Binding DataContext.CancelMyAdjustmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding DataContext.IsEmployeeMode, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource DangerActionButtonStyle}">
                                                <Setter Property="IsEnabled" Value="False"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="PENDING">
                                                        <Setter Property="IsEnabled" Value="True"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CloseCircleOutline" Width="12" Height="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="Cancel"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="6" Margin="6,0,6,0" Padding="10,8" BorderBrush="#E5EDF7" BorderThickness="1" Background="#F9FBFF" CornerRadius="10">
            <TextBlock Text="{Binding ActionMessage}" Foreground="{Binding ActionMessageBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
