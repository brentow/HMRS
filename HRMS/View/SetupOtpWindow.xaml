<Window x:Class="HRMS.View.SetupOtpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Database Setup OTP"
        Width="470"
        MinWidth="470"
        MinHeight="470"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F8FC"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid Margin="10">
        <Border Background="White"
                BorderBrush="#D8E6F6"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#F8FBFF"
                        BorderBrush="#D8E6F6"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="36"
                                Height="36"
                                Background="#EAF4FF"
                                CornerRadius="18"
                                VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="ShieldLockOutline"
                                                     Width="18"
                                                     Height="18"
                                                     Foreground="#1E4368"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="10,0,12,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Database Setup OTP"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="#12385C" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="Verify your email before changing database setup."
                                       FontSize="11.5"
                                       Foreground="#5B6A7A"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Column="2"
                                Width="88"
                                Height="54"
                                Background="Transparent"
                                VerticalAlignment="Center">
                            <Image Source="/Images/ePRIME_logo.png"
                                   Stretch="Uniform"
                                   StretchDirection="DownOnly"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,8,0,0"
                        Background="#F7FBFF"
                        BorderBrush="#D8E6F6"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0"
                                    Grid.ColumnSpan="2">
                            <TextBlock Text="Email"
                                       FontSize="11.5"
                                       FontWeight="SemiBold"
                                       Foreground="#4B627B" />
                            <TextBlock Margin="0,3,0,0"
                                       Text="Enter the email address that should receive the OTP."
                                       FontSize="11.5"
                                       Foreground="#5B6A7A"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Height="40"
                                Margin="0,8,8,0"
                                Background="White"
                                BorderBrush="#AFC3DA"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,0">
                            <TextBox x:Name="EmailAddressTextBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="13"
                                     Foreground="#173B5E"
                                     VerticalContentAlignment="Center"
                                     TextChanged="EmailAddressTextBox_OnTextChanged"
                                     KeyDown="EmailAddressTextBox_OnKeyDown" />
                        </Border>

                        <Button Grid.Row="1"
                                Grid.Column="1"
                                x:Name="SendOtpButton"
                                Height="40"
                                MinWidth="106"
                                Margin="0,8,0,0"
                                Padding="12,0"
                                Click="SendOtpButton_OnClick"
                                Foreground="White"
                                Background="#1E5A92"
                                BorderThickness="0"
                                Style="{StaticResource MaterialDesignFlatMidBgButton}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="EmailFastOutline"
                                                         Width="14"
                                                         Height="14"
                                                         Margin="0,0,5,0" />
                                <TextBlock Text="Send OTP"
                                           FontSize="12.5"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>

                        <Border Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Margin="0,8,0,0"
                                Background="#EAF4FF"
                                BorderBrush="#D4E6FB"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="9">
                            <StackPanel>
                                <TextBlock Text="Delivery summary"
                                           FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="#4B627B" />
                                <TextBlock x:Name="DestinationSummaryText"
                                           Margin="0,3,0,0"
                                           FontSize="12.5"
                                           FontWeight="Bold"
                                           Foreground="#1E4368"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,8,0,0"
                        Background="White"
                        BorderBrush="#D8E6F6"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Grid.ColumnSpan="2">
                            <TextBlock Text="OTP Code"
                                       FontSize="11.5"
                                       FontWeight="SemiBold"
                                       Foreground="#4B627B" />
                            <TextBlock Margin="0,3,0,0"
                                       Text="Check your inbox, then enter the code."
                                       FontSize="11.5"
                                       Foreground="#5B6A7A"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Height="40"
                                Margin="0,8,8,0"
                                Background="White"
                                BorderBrush="#AFC3DA"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,0">
                            <TextBox x:Name="OtpCodeTextBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     MaxLength="8"
                                     FontSize="16"
                                     FontWeight="Bold"
                                     Foreground="#173B5E"
                                     TextAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     PreviewTextInput="OtpCodeTextBox_OnPreviewTextInput"
                                     KeyDown="OtpCodeTextBox_OnKeyDown" />
                        </Border>

                        <Button Grid.Row="1"
                                Grid.Column="1"
                                x:Name="VerifyButton"
                                Height="40"
                                MinWidth="106"
                                Margin="0,8,0,0"
                                Padding="12,0"
                                Click="VerifyButton_OnClick"
                                Foreground="White"
                                Background="#12385C"
                                BorderThickness="0"
                                Style="{StaticResource MaterialDesignFlatMidBgButton}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ShieldCheckOutline"
                                                         Width="14"
                                                         Height="14"
                                                         Margin="0,0,5,0" />
                                <TextBlock Text="Verify OTP"
                                           FontSize="12.5"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        x:Name="ConfigHelpPanel"
                        Margin="0,8,0,0"
                        Background="#FFF8E6"
                        BorderBrush="#F2D18C"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Brevo sender setup is incomplete"
                                       FontSize="11.5"
                                       FontWeight="SemiBold"
                                       Foreground="#735A15" />
                            <TextBlock x:Name="ConfigMessageText"
                                       Margin="0,5,0,0"
                                       FontSize="10.5"
                                       Foreground="#8A6A1F"
                                       TextWrapping="Wrap"
                                       LineHeight="14" />
                            <TextBlock x:Name="ConfigPathText"
                                       Margin="0,6,0,0"
                                       FontSize="10"
                                       Foreground="#41576D"
                                       TextWrapping="Wrap"
                                       LineHeight="13" />
                            <Button x:Name="OpenConfigButton"
                                    HorizontalAlignment="Left"
                                    Margin="0,6,0,0"
                                    Padding="8,2"
                                    Click="OpenConfigButton_OnClick"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileDocumentEditOutline"
                                                             Width="13"
                                                             Height="13"
                                                             Margin="0,0,4,0" />
                                    <TextBlock Text="Open Config"
                                               FontSize="11.5" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        x:Name="StatusPanel"
                        Margin="0,8,0,0"
                        Background="#EFF6FF"
                        BorderBrush="#D6E8FF"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="StatusText"
                                   VerticalAlignment="Center"
                                   FontSize="11.5"
                                   FontWeight="SemiBold"
                                   Foreground="#35516E"
                                    TextWrapping="Wrap"
                                    Text="Enter your email address, then click Send OTP." />

                        <Button Grid.Column="1"
                                x:Name="CancelButton"
                                Margin="8,0,0,0"
                                Padding="8,2"
                                Click="CancelButton_OnClick"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <TextBlock Text="Cancel"
                                       FontSize="11.5" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
