<Window x:Class="HRMS.View.BeneficiaryChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Change Password"
        Height="500"
        MinHeight="460"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="LockOutline"
                                         Width="32"
                                         Height="32"
                                         Foreground="#D84343"
                                         VerticalAlignment="Center"
                                         Margin="0,0,12,0"/>
                <TextBlock Text="Change Your Password"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#1E4368"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="You are required to change your temporary password before proceeding."
                       FontSize="13"
                       Foreground="#5B6A7A"
                       Margin="44,8,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Current/Temporary Password (Read-only) -->
        <TextBlock Grid.Row="1"
                   Text="Temporary Password"
                   Foreground="#4A5B6C"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6"/>

        <Border Grid.Row="2"
                Background="#F0F4F8"
                BorderBrush="#D6E8FF"
                BorderThickness="1"
                CornerRadius="4"
                Height="42"
                Margin="0,0,0,16">
            <TextBlock x:Name="TemporaryPasswordText"
                       Foreground="#2D5783"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Padding="12,0"
                       FontFamily="Consolas,Courier New"/>
        </Border>

        <!-- New Password -->
        <TextBlock Grid.Row="3"
                   Text="New Password"
                   Foreground="#4A5B6C"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6"/>

        <PasswordBox x:Name="NewPasswordBox"
                     Grid.Row="4"
                     Height="42"
                     Padding="12,0"
                     BorderBrush="#C0C0C0"
                     BorderThickness="1"
                     VerticalContentAlignment="Center"
                     Foreground="#000000"
                     Margin="0,0,0,16"/>

        <!-- Confirm Password -->
        <TextBlock Grid.Row="5"
                   Text="Confirm Password"
                   Foreground="#4A5B6C"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6"/>

        <PasswordBox x:Name="ConfirmPasswordBox"
                     Grid.Row="6"
                     Height="42"
                     Padding="12,0"
                     BorderBrush="#C0C0C0"
                     BorderThickness="1"
                     VerticalContentAlignment="Center"
                     Foreground="#000000"
                     Margin="0,0,0,12"/>

        <!-- Message Text -->
        <TextBlock x:Name="MessageText"
                   Grid.Row="7"
                   Foreground="#5B6A7A"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="ChangePasswordButton"
                    Content="Change Password"
                    Width="140"
                    Height="38"
                    Foreground="White"
                    Background="#2E9D5B"
                    BorderThickness="0"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Margin="0,0,12,0"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="4"/>

            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="100"
                    Height="38"
                    Foreground="#4A5B6C"
                    Background="#E8EEF5"
                    BorderThickness="0"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="4"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
