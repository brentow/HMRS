<UserControl x:Class="HRMS.View.ReportsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             Loaded="UserControl_Loaded"
             Background="White">
    <UserControl.Resources>
        <Color x:Key="PrimaryColor">#1E4368</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileChartOutline"
                                             Width="28"
                                             Height="28"
                                             Margin="0,0,8,0"
                                             Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="Reports"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
                <TextBlock Margin="0,2,0,0"
                           Foreground="#5B6A7A"
                           Text="Centralized HRMS reports with clean PDF and Excel export." />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Width="190"
                        Height="38"
                        Margin="10,0,8,0"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="15" Height="15" Margin="0,0,6,0" />
                        <TextBlock Text="Back to Dashboard" />
                    </StackPanel>
                </Button>

                <Button Width="130"
                        Height="38"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="RefreshButton_OnClick">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Refresh" Width="15" Height="15" Margin="0,0,6,0" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,10"
                Padding="10"
                Background="#F8FBFF"
                BorderBrush="#DBE7F4"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Category" Foreground="#5B6A7A" Margin="0,0,0,4" />
                <TextBlock Grid.Column="1" Text="Report" Foreground="#5B6A7A" Margin="0,0,0,4" />
                <TextBlock Grid.Column="2" Text="Date From" Foreground="#5B6A7A" Margin="0,0,0,4" />
                <TextBlock Grid.Column="3" Text="Date To" Foreground="#5B6A7A" Margin="0,0,0,4" />

                <ComboBox x:Name="CategoryComboBox"
                          Grid.Row="1"
                          Margin="0,0,10,0"
                          Height="36"
                          SelectionChanged="CategoryComboBox_OnSelectionChanged"
                          DisplayMemberPath="CategoryName" />

                <ComboBox x:Name="ReportComboBox"
                          Grid.Column="1"
                          Grid.Row="1"
                          Margin="0,0,10,0"
                          Height="36"
                          SelectionChanged="ReportComboBox_OnSelectionChanged"
                          DisplayMemberPath="ReportName" />

                <DatePicker x:Name="DateFromPicker"
                            Grid.Column="2"
                            Grid.Row="1"
                            Margin="0,0,10,0"
                            Height="36"
                            SelectedDateFormat="Short" />

                <DatePicker x:Name="DateToPicker"
                            Grid.Column="3"
                            Grid.Row="1"
                            Margin="0,0,10,0"
                            Height="36"
                            SelectedDateFormat="Short" />

                <Button Grid.Column="4"
                        Grid.Row="1"
                        Width="120"
                        Height="36"
                        Background="#2B5E92"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="LoadReportButton_OnClick">
                    Load Report
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,10"
                Padding="10"
                Background="#F9FCFF"
                BorderBrush="#DBE7F4"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>
                <TextBlock x:Name="SelectedReportTitleText"
                           Text="No report selected."
                           Foreground="#1E4368"
                           FontWeight="SemiBold"
                           FontSize="14" />
                <TextBlock x:Name="SelectedReportDescriptionText"
                           Margin="0,2,0,0"
                           Text="Choose a category and report, then click Load Report."
                           Foreground="#5B6A7A"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <DataGrid x:Name="ReportDataGrid"
                  Grid.Row="3"
                  Margin="0,0,0,10"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#DBE7F4"
                  BorderThickness="1"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="#F9FBFF"
                  AlternationCount="2" />

        <Border Grid.Row="4"
                Padding="10"
                Background="#F8FBFF"
                BorderBrush="#DBE7F4"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Ready."
                               Foreground="#4A5B6C"
                               FontWeight="SemiBold" />
                    <TextBlock Text="  |  " Foreground="#9AAFC8" Margin="4,0" />
                    <TextBlock x:Name="RowsCountTextBlock"
                               Text="Rows: 0"
                               Foreground="#4A5B6C" />
                </StackPanel>

                <Button Grid.Column="1"
                        Width="128"
                        Height="36"
                        Margin="10,0,0,0"
                        Background="#EAF2FB"
                        Foreground="#1E4368"
                        BorderBrush="#D1E3F7"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        Click="ExportExcelButton_OnClick">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="FileExcelBox" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Export Excel" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Width="120"
                        Height="36"
                        Margin="10,0,0,0"
                        Background="#F0F6FF"
                        Foreground="#1E4368"
                        BorderBrush="#D1E3F7"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        Click="ExportPdfButton_OnClick">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="FilePdfBox" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Export PDF" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="3"
                        Width="94"
                        Height="36"
                        Margin="10,0,0,0"
                        Background="#2B5E92"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="LoadReportButton_OnClick">
                    Reload
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
