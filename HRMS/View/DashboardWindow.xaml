<Window x:Class="HRMS.View.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:scottPlot="clr-namespace:ScottPlot;assembly=ScottPlot.WPF"
        xmlns:local="clr-namespace:HRMS.View"
        mc:Ignorable="d"
        Title="HRMS Dashboard"
        WindowStartupLocation="CenterScreen"
        Height="823"
        Width="1289"
        Background="White">

    <Window.Resources>
        <Color x:Key="PrimaryColor">#1E4368</Color>
        <Color x:Key="LightColor">#CBE9FE</Color>
        <Color x:Key="AccentColor">#FDBD55</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="LightBrush" Color="{StaticResource LightColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="#F7FAFC" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="BorderBrush" Value="#E5EDF7" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14 12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Margin" Value="0,3,0,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="6,2" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D5783" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#23456C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarNavIconStyle" TargetType="{x:Type materialDesign:PackIcon}">
            <Setter Property="Width" Value="21" />
            <Setter Property="Height" Value="21" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="SidebarNavTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Quick action buttons: keep text centered and readable -->
        <Style x:Key="QuickActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50" />
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EmployeeSnapshotCardStyle" TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="MinHeight" Value="104" />
        </Style>

        <Style x:Key="EmployeeSnapshotValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="EmployeeSnapshotLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5F6E80" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="MinHeight" Value="20" />
        </Style>

        <Style x:Key="DashboardMetroTileStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardCompactTileStyle" TargetType="Button" BasedOn="{StaticResource DashboardMetroTileStyle}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="1" />
        </Style>

        <Style x:Key="DashboardPanelTileStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#1E4368" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReferenceDashboardTileStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2B5AA8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TileSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="1"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileSurface" Property="Opacity" Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TileSurface" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TileSurface" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReferenceDashboardMiniTileStyle" TargetType="Button" BasedOn="{StaticResource ReferenceDashboardTileStyle}">
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="4,0,4,0" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="NavSelectableButtonStyleLocal" BasedOn="{StaticResource NavButtonStyle}" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="SubNavButtonStyle" BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="16,10,12,10" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="NotificationItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent" CornerRadius="8" Padding="10,8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F3F8FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E8F1FD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavColumn" Width="270" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left navigation -->
        <Border x:Name="SidebarHost" Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <Grid x:Name="NavStack" Margin="18,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="NavHeaderPanel" Grid.Row="0" VerticalAlignment="Center" Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="72"
                            Height="72"
                            Background="White"
                            BorderBrush="#D6E2F1"
                            BorderThickness="1"
                            CornerRadius="18">
                        <Grid Margin="6">
                            <Image Source="{Binding CompanyLogoPath}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0" />
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="{Binding CompanyAbbreviation}"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding CompanyName}"
                                   Foreground="#EAF2FB"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,0,0" />
                        <Border Margin="0,8,0,0"
                                Padding="8,5"
                                Background="#2D5783"
                                BorderBrush="#4E78A2"
                                BorderThickness="1"
                                CornerRadius="10"
                                HorizontalAlignment="Left"
                                MaxWidth="205"
                                ToolTip="{Binding SerialNumber}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="CardAccountDetailsOutline"
                                                         Width="14"
                                                         Height="14"
                                                         Margin="0,0,6,0"
                                                         Foreground="#FDE5B4"
                                                         VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SerialNumber}"
                                           Foreground="#FDE5B4"
                                           FontSize="9.5"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="ModulesLabel" Grid.Row="1" Text="Modules" Foreground="#EAF2FB" FontWeight="Bold" Margin="4,0,0,8" />

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel VerticalAlignment="Top">

                        <Button x:Name="DashboardNavButton"
                                Click="DashboardNavButton_OnClick">
                            <Button.Style>
                                <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDashboardVisible}" Value="True">
                                            <Setter Property="Background" Value="#2D5783"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="ViewDashboardOutline" Style="{StaticResource SidebarNavIconStyle}" />
                                <TextBlock Text="Dashboard" Tag="NavLabel" Style="{StaticResource SidebarNavTextStyle}" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="EmployeeProfileNavButton"
                                Click="EmployeeProfileNavButton_OnClick"
                                Visibility="Collapsed">
                            <Button.Style>
                                <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUsersVisible}" Value="True">
                                            <Setter Property="Background" Value="#2D5783"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="AccountCircleOutline" Style="{StaticResource SidebarNavIconStyle}" />
                                <TextBlock Text="My Profile" Tag="NavLabel" Style="{StaticResource SidebarNavTextStyle}" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="EmployeeDepartmentPositionNavButton"
                                Click="EmployeeDepartmentPositionNavButton_OnClick"
                                Visibility="Collapsed">
                            <Button.Style>
                                <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEmployeesVisible}" Value="True">
                                            <Setter Property="Background" Value="#2D5783"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="Domain" Style="{StaticResource SidebarNavIconStyle}" />
                                <TextBlock Text="My Department / Position" Tag="NavLabel" Style="{StaticResource SidebarNavTextStyle}" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="EmployeesNavButton"
                                Click="EmployeesNavButton_OnClick">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="EmployeeManagementMenu"
                                             Placement="Right">
                                    <MenuItem x:Name="EmployeeManagementEmployeesMenuItem"
                                              Header="Employees"
                                              Click="EmployeeManagementEmployeesMenuItem_OnClick" />
                                    <MenuItem x:Name="EmployeeManagementDepartmentsMenuItem"
                                              Header="Departments &amp; Positions"
                                              Click="EmployeeManagementDepartmentsMenuItem_OnClick" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <Button.Style>
                                <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEmployeesVisible}" Value="True">
                                            <Setter Property="Background" Value="#2D5783"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDepartmentsVisible}" Value="True">
                                            <Setter Property="Background" Value="#2D5783"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="AccountGroup" Style="{StaticResource SidebarNavIconStyle}" />
                                <TextBlock Grid.Column="1" Text="Employee Management" Tag="NavLabel" Style="{StaticResource SidebarNavTextStyle}" />
                                <materialDesign:PackIcon x:Name="EmployeesNavChevronIcon"
                                                         Grid.Column="2"
                                                         Kind="ChevronDown"
                                                         Width="18"
                                                         Height="18"
                                                         Foreground="#D7E7F8"
                                                         VerticalAlignment="Center" />
                            </Grid>
                        </Button>

                        <Border x:Name="EmployeeManagementSubmenuPanel"
                                Visibility="Collapsed"
                                Margin="14,0,0,6"
                                Padding="8"
                                Background="#183A5C"
                                CornerRadius="10">
                            <StackPanel>
                                <Button x:Name="EmployeesSubNavButton"
                                        Click="EmployeeManagementEmployeesMenuItem_OnClick">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SubNavButtonStyle}" TargetType="Button">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEmployeesVisible}" Value="True">
                                                    <Setter Property="Background" Value="#2D5783"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="AccountGroup" Width="18" Height="18" Margin="0,0,10,0" Foreground="White" VerticalAlignment="Center" />
                                        <TextBlock Text="Employees" Tag="NavLabel" Style="{StaticResource SidebarNavTextStyle}" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="DepartmentsNavButton"
                                        Click="DepartmentsNavButton_OnClick">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SubNavButtonStyle}" TargetType="Button">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDepartmentsVisible}" Value="True">
                                                    <Setter Property="Background" Value="#2D5783"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Domain" Width="18" Height="18" Margin="0,0,10,0" Foreground="White" VerticalAlignment="Center" />
                                        <TextBlock Text="Departments &amp; Positions" Tag="NavLabel" Style="{StaticResource SidebarNavTextStyle}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Button x:Name="AttendanceNavButton"
                                Click="AttendanceNavButton_OnClick">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="AttendanceNavigationMenu"
                                             Placement="Right">
                                    <MenuItem x:Name="AttendanceMenuItem"
                                              Header="Attendance"
                                              Click="AttendanceMenuItem_OnClick" />
                                    <MenuItem x:Name="TravelOrderMenuItem"
                                              Header="Travel Order"
                                              Click="TravelOrderNavButton_OnClick" />
                                    <MenuItem x:Name="HolidaysMenuItem"
                                              Header="Holidays"
                                              Click="HolidaysNavButton_OnClick" />
                                    <MenuItem x:Name="AttendanceLogsMenuItem"
                                              Header="Attendance Logs"
                                              Click="AttendanceLogsMenuItem_OnClick" />
                                    <MenuItem x:Name="AdjustmentsMenuItem"
                                              Header="Adjustments"
                                              Click="AdjustmentsMenuItem_OnClick" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <Button.Style>
                                <Style BasedOn="{StaticResource NavSelectableButtonStyleLocal}" TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAttendanceVisible}" Value="True">
                                            <Setter Property="Background" Value="#2D5783"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="ClockOutline" Style="{StaticResource SidebarNavIconStyle}" />
                                <TextBlock x:Name="AttendanceNavLabelText" Grid.Column="1" Text="Attendance" Tag="NavLabel" Style="{StaticResource SidebarNavTextStyle}" />
                                <materialDesign:PackIcon x:Name="AttendanceNavChevronIcon"
                                                         Grid.Column="2"
                                                         Kind="ChevronDown"
                                                         Width="18"
                                                         Height="18"
                                                         Foreground="#D7E7F8"
                                                         VerticalAlignment="Center" />
                            </Grid>
                        </Button>

                        <Border x:Name="AttendanceSubmenuPanel"
                                Visibility="Collapsed"
                                Margin="14,0,0,6"
                                Padding="8"
                                Background="#183A5C"
                                CornerRadius="10">
                            <StackPanel>
                                <Button x:Name="AttendanceSubNavButton"
                                        Click="AttendanceMenuItem_OnClick">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SubNavButtonStyle}" TargetType="Button">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAttendanceVisible}" Value="True">
                                                    <Setter Property="Background" Value="#2D5783"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="ClockOutline" Width="18" Height="18" Margin="0,0,10,0" Foreground="White" VerticalAlignment="Center" />
                                        <TextBlock Text="Attendance" Tag="NavLabel" Style="{StaticResource SidebarNavTextStyle}" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="TravelOrderNavButton"
                                        Click="TravelOrderNavButton_OnClick">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SubNavButtonStyle}" TargetType="Button">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAttendanceVisible}" Value="True">
                                                    <Setter Property="Background" Value="#2D5783"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="FileEditOutline" Width="18" Height="18" Margin="0,0,10,0" Foreground="White" VerticalAlignment="Center" />
                                        <TextBlock Text="Travel Order" Tag="NavLabel" Style="{StaticResource SidebarNavTextStyle}" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="HolidaysNavButton"
                                        Click="HolidaysNavButton_OnClick">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SubNavButtonStyle}" TargetType="Button">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAttendanceVisible}" Value="True">
                                                    <Setter Property="Background" Value="#2D5783"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="CalendarMonthOutline" Width="18" Height="18" Margin="0,0,10,0" Foreground="White" VerticalAlignment="Center" />
                                        <TextBlock Text="Holidays" Tag="NavLabel" Style="{StaticResource SidebarNavTextStyle}" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="AttendanceLogsNavButton"
                                        Click="AttendanceLogsNavButton_OnClick">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SubNavButtonStyle}" TargetType="Button">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAttendanceLogsVisible}" Value="True">
                                                    <Setter Property="Background" Value="#2D5783"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="ClipboardTextOutline" Width="18" Height="18" Margin="0,0,10,0" Foreground="White" VerticalAlignment="Center" />
                                        <TextBlock Text="Attendance Logs" Tag="NavLabel" Style="{StaticResource SidebarNavTextStyle}" />
                                    </StackPanel>
                                </Button>

                                <Button x:Name="AdjustmentsNavButton"
                                        Click="AdjustmentsNavButton_OnClick">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource SubNavButtonStyle}" TargetType="Button">
