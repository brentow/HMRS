<UserControl x:Class="HRMS.View.DocumentVerificationWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1240"
             Background="White">
    <UserControl.Resources>
        <Color x:Key="PrimaryColor">#1E4368</Color>
        <Color x:Key="SuccessColor">#2E9D5B</Color>
        <Color x:Key="WarningColor">#D9B53B</Color>
        <Color x:Key="ErrorColor">#D84343</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
        <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
        <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5EDF7" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F2F7FD" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,0,10,0" />
            <Setter Property="Height" Value="40" />
            <Setter Property="BorderBrush" Value="#E3ECF8" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="GridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0,10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Foreground" Value="#1E4368" />
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F1FC" />
                    <Setter Property="Foreground" Value="#1E4368" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="BorderBrush" Value="#D6E1F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#F7FAFF" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="BorderBrush" Value="#D6E1F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#F7FAFF" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="DateFieldBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="#F7FAFF" />
            <Setter Property="BorderBrush" Value="#D6E1F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="EmployeeGridTextStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="WrapGridTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ClipboardCheckOutline"
                                             Width="34"
                                             Height="32"
                                             Margin="0,0,10,0"
                                             Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="System Verifier"
                               FontSize="25"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
                <TextBlock Margin="0,2,0,0"
                           Foreground="#5B6A7A"
                           Text="Track employee document compliance, verification, and expiring requirements." />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Width="190"
                        Height="42"
                        Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16" Margin="0,0,8,0" />
                        <TextBlock Text="Back to Dashboard" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Width="140"
                        Height="42"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,8,0" />
                        <TextBlock Text="Refresh" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="6,0" Style="{StaticResource CardStyle}" Background="#F5FBFF">
                <StackPanel>
                    <TextBlock Text="Employees" Foreground="#6A7684" />
                    <TextBlock Text="{Binding TotalEmployees}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="6,0" Style="{StaticResource CardStyle}" Background="#F2FBF5">
                <StackPanel>
                    <TextBlock Text="Complete" Foreground="#6A7684" />
                    <TextBlock Text="{Binding CompleteEmployees}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Margin="6,0" Style="{StaticResource CardStyle}" Background="#FFF8EC">
                <StackPanel>
                    <TextBlock Text="Partial" Foreground="#6A7684" />
                    <TextBlock Text="{Binding PartialEmployees}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Margin="6,0" Style="{StaticResource CardStyle}" Background="#FFF4F4">
                <StackPanel>
                    <TextBlock Text="Incomplete" Foreground="#6A7684" />
                    <TextBlock Text="{Binding IncompleteEmployees}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Margin="6,0" Style="{StaticResource CardStyle}" Background="#F7FBFF">
                <TextBlock Text="{Binding ActionMessage}"
                           Foreground="{Binding ActionMessageBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="6,0,10,0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Employees"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" />
                        <Border Margin="0,10,0,0"
                                Padding="10,6"
                                Background="#F2F7FD"
                                BorderBrush="#E0EAF6"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Magnify"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0"
                                                         Foreground="#7A8FA5"
                                                         VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="14"
                                         Foreground="#5B6A7A"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Search employee name" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Employees}"
                              SelectedItem="{Binding SelectedEmployee}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              ColumnHeaderStyle="{StaticResource HeaderStyle}"
                              CellStyle="{StaticResource GridCellStyle}"
                              RowStyle="{StaticResource GridRowStyle}"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding EmployeeName}"
                                                Width="*"
                                                ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                            <DataGridTextColumn Header="Progress"
                                                Binding="{Binding ProgressText, Mode=OneWay}"
                                                Width="90"
                                                ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Margin="0,0,6,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,2,0">
                    <Border Margin="0,0,0,10" Style="{StaticResource CardStyle}" Background="#F7FBFF">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedEmployeeTitle}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding SelectedEmployeeSubtitle}"
                                   Foreground="#5B6A7A"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,10" Style="{StaticResource CardStyle}">
                        <TabControl MinHeight="320">
                        <TabItem Header="Tier 1">
                            <DataGrid ItemsSource="{Binding Tier1Documents}"
                                      SelectedItem="{Binding SelectedDocument}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      ColumnHeaderStyle="{StaticResource HeaderStyle}"
                                      CellStyle="{StaticResource GridCellStyle}"
                                      RowStyle="{StaticResource GridRowStyle}"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      MinHeight="250"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding DocumentCode}" Width="78" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                    <DataGridTextColumn Header="Document" Binding="{Binding DocumentName}" Width="*" ElementStyle="{StaticResource WrapGridTextStyle}" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusLabel, Mode=OneWay}" Width="120" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                    <DataGridTextColumn Header="Submitted" Binding="{Binding SubmittedDate, StringFormat={}{0:MMM dd, yyyy}}" Width="118" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                    <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat={}{0:MMM dd, yyyy}}" Width="118" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Tier 2">
                            <DataGrid ItemsSource="{Binding Tier2Documents}"
                                      SelectedItem="{Binding SelectedDocument}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      ColumnHeaderStyle="{StaticResource HeaderStyle}"
                                      CellStyle="{StaticResource GridCellStyle}"
                                      RowStyle="{StaticResource GridRowStyle}"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      MinHeight="250"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding DocumentCode}" Width="78" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                    <DataGridTextColumn Header="Document" Binding="{Binding DocumentName}" Width="*" ElementStyle="{StaticResource WrapGridTextStyle}" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusLabel, Mode=OneWay}" Width="120" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                    <DataGridTextColumn Header="Submitted" Binding="{Binding SubmittedDate, StringFormat={}{0:MMM dd, yyyy}}" Width="118" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                    <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat={}{0:MMM dd, yyyy}}" Width="118" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Tier 3">
                            <DataGrid ItemsSource="{Binding Tier3Documents}"
                                      SelectedItem="{Binding SelectedDocument}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      ColumnHeaderStyle="{StaticResource HeaderStyle}"
                                      CellStyle="{StaticResource GridCellStyle}"
                                      RowStyle="{StaticResource GridRowStyle}"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      MinHeight="250"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding DocumentCode}" Width="78" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                    <DataGridTextColumn Header="Document" Binding="{Binding DocumentName}" Width="*" ElementStyle="{StaticResource WrapGridTextStyle}" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusLabel, Mode=OneWay}" Width="120" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                    <DataGridTextColumn Header="Submitted" Binding="{Binding SubmittedDate, StringFormat={}{0:MMM dd, yyyy}}" Width="118" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                    <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat={}{0:MMM dd, yyyy}}" Width="118" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Tier 4">
                            <DataGrid ItemsSource="{Binding Tier4Documents}"
                                      SelectedItem="{Binding SelectedDocument}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      ColumnHeaderStyle="{StaticResource HeaderStyle}"
                                      CellStyle="{StaticResource GridCellStyle}"
                                      RowStyle="{StaticResource GridRowStyle}"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      MinHeight="250"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding DocumentCode}" Width="78" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                    <DataGridTextColumn Header="Document" Binding="{Binding DocumentName}" Width="*" ElementStyle="{StaticResource WrapGridTextStyle}" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusLabel, Mode=OneWay}" Width="120" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                    <DataGridTextColumn Header="Submitted" Binding="{Binding SubmittedDate, StringFormat={}{0:MMM dd, yyyy}}" Width="118" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                    <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat={}{0:MMM dd, yyyy}}" Width="118" ElementStyle="{StaticResource EmployeeGridTextStyle}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        </TabControl>
                    </Border>

                    <Border Margin="0,0,0,10" Style="{StaticResource CardStyle}" Background="#F9FBFF">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedDocumentTitle}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="{StaticResource PrimaryBrush}" />

                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Status" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <ComboBox ItemsSource="{Binding StatusOptions}"
                                          SelectedItem="{Binding SelectedDocumentStatus}"
                                          Style="{StaticResource ComboBoxStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Submitted" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <Border Style="{StaticResource DateFieldBorderStyle}">
                                    <DatePicker BorderThickness="0"
                                                Padding="8,0"
                                                Background="Transparent"
                                                Language="en-GB"
                                                SelectedDateFormat="Short"
                                                SelectedDate="{Binding SelectedSubmittedDate}" />
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="Expiry" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <Border Style="{StaticResource DateFieldBorderStyle}">
                                    <DatePicker BorderThickness="0"
                                                Padding="8,0"
                                                Background="Transparent"
                                                Language="en-GB"
                                                SelectedDateFormat="Short"
                                                SelectedDate="{Binding SelectedExpiryDate}" />
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="10,0,0,0">
                                <TextBlock Text="Verified" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <Border Style="{StaticResource DateFieldBorderStyle}">
                                    <DatePicker BorderThickness="0"
                                                Padding="8,0"
                                                Background="Transparent"
                                                Language="en-GB"
                                                SelectedDateFormat="Short"
                                                SelectedDate="{Binding SelectedVerifiedDate}" />
                                </Border>
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Grid.ColumnSpan="3"
                                    Margin="0,12,10,0"
                                    Padding="12,10"
                                    Background="White"
                                    BorderBrush="#D6E1F0"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Text="Uploaded File"
                                               Foreground="#5B6A7A"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedDocumentAttachmentText}"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="1"
                                        Grid.Column="3"
                                        Margin="10,12,0,0"
                                        Orientation="Vertical">
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,0,0,8"
                                        MinWidth="148"
                                        Visibility="{Binding SelectedDocumentHasAttachment, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding OpenAttachmentCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="OpenInNew" Width="15" Height="15" Margin="0,0,6,0" />
                                        <TextBlock Text="Open File" />
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        MinWidth="148"
                                        Command="{Binding SaveDocumentCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="15" Height="15" Margin="0,0,6,0" />
                                        <TextBlock Text="Save" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" MinHeight="220">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Expiring Within 30 Days"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,8" />

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ExpiringDocuments}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  ColumnHeaderStyle="{StaticResource HeaderStyle}"
                                  CellStyle="{StaticResource GridCellStyle}"
                                  RowStyle="{StaticResource GridRowStyle}"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MinHeight="150"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Emp No" Binding="{Binding EmployeeNo}" Width="95" />
                                <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="1.8*" />
                                <DataGridTextColumn Header="Document" Binding="{Binding DocumentName}" Width="2*" />
                                <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat={}{0:MMM dd, yyyy}}" Width="120" />
                                <DataGridTextColumn Header="Days Left" Binding="{Binding DaysRemaining, Mode=OneWay}" Width="90" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="3" Margin="6,12,6,0" Style="{StaticResource CardStyle}" Background="#F9FBFF">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="1.6*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Waived Reason" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource InputStyle}"
                             Text="{Binding SelectedWaivedReason, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Remarks" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBox MinHeight="38"
                             Padding="10,8"
                             BorderBrush="#D6E1F0"
                             BorderThickness="1"
                             Background="#F7FAFF"
                             Foreground="{StaticResource PrimaryBrush}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Text="{Binding SelectedRemarks, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
