<Window x:Class="HRMS.View.BiometricDeviceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Biometric Device"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Width="750"
        Height="520"
        Background="White">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1E4368" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#2E9D5B" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: Reader status + Detect/Register buttons -->
        <Border Grid.Row="0" Padding="12" Background="#F8FBFF" BorderBrush="#E5EDF7" BorderThickness="1" CornerRadius="10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="ReaderStatusTitle"
                               Text="No connected fingerprint reader"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#D84343" />
                    <TextBlock x:Name="ReaderStatusText"
                               Margin="0,4,0,0"
                               Foreground="#4A5B6C"
                               TextWrapping="Wrap"
                               Text="Click Detect Reader to scan for connected devices." />
                    <TextBlock x:Name="ReaderGuidanceText"
                               Margin="0,4,0,0"
                               Foreground="#6E7C8C"
                               TextWrapping="Wrap"
                               Text="Plug in the U.are.U 4500 reader and click Detect Reader." />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <Button Content="Detect Reader"
                            Width="160" Height="38"
                            Margin="0,0,0,8"
                            Background="{StaticResource PrimaryBrush}"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Click="DetectReader_Click" />
                    <Button x:Name="RegisterReaderButton"
                            Content="Register Reader"
                            Width="160" Height="38"
                            Background="{StaticResource SuccessBrush}"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            IsEnabled="False"
                            Click="RegisterReader_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Add device form -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Device name" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="Serial no." Foreground="#5B6A7A" FontWeight="SemiBold" Margin="8,0,0,4" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Location" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="8,0,0,4" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="IP address" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="8,0,0,4" />
            <TextBlock Grid.Row="0" Grid.Column="4" Text="Active" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="8,0,0,4" />

            <TextBox x:Name="DeviceNameBox" Grid.Row="1" Grid.Column="0" Height="36" />
            <TextBox x:Name="SerialNoBox" Grid.Row="1" Grid.Column="1" Height="36" Margin="8,0,0,0" />
            <TextBox x:Name="LocationBox" Grid.Row="1" Grid.Column="2" Height="36" Margin="8,0,0,0" />
            <TextBox x:Name="IpAddressBox" Grid.Row="1" Grid.Column="3" Height="36" Margin="8,0,0,0" />
            <CheckBox x:Name="IsActiveCheck" Grid.Row="1" Grid.Column="4" Height="36" VerticalAlignment="Center" Margin="8,0,0,0" IsChecked="True" />
            <Button Grid.Row="1" Grid.Column="5"
                    Content="Add Device"
                    Height="36" MinWidth="100"
                    Margin="8,0,0,0"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="AddDevice_Click" />
        </Grid>

        <!-- Device list -->
        <TextBlock Grid.Row="2" Text="Registered Devices" Foreground="#5B6A7A" FontWeight="SemiBold" Margin="0,8,0,4" />
        <DataGrid x:Name="DevicesGrid"
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E9F0FA"
                  AlternatingRowBackground="#F8FBFF">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Device" Binding="{Binding DeviceName}" Width="1.6*" />
                <DataGridTextColumn Header="Serial" Binding="{Binding SerialNo}" Width="1.1*" />
                <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="1.2*" />
                <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="1*" />
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="0.8*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status + Close -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Foreground="#2E9D5B" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" />
            <Button Grid.Column="1" Content="Close" Width="90" Height="36" Background="#EAF2FB" Foreground="{StaticResource PrimaryBrush}" BorderThickness="0" Click="Close_Click" />
        </Grid>
    </Grid>
</Window>
