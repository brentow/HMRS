<UserControl x:Class="HRMS.View.TransactionsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             Loaded="UserControl_Loaded"
             Background="White">
    <UserControl.Resources>
        <Color x:Key="PrimaryColor">#1E4368</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />

        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="BorderBrush" Value="#DBE7F4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#F9FCFF" />
            <Setter Property="Margin" Value="4" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="SwapHorizontalBold"
                                             Width="28"
                                             Height="28"
                                             Margin="0,0,8,0"
                                             Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="Transactions"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
                <TextBlock Margin="0,2,0,0"
                           Foreground="#5B6A7A"
                           Text="Live activity from your HRMS modules based on system audit logs." />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Width="190"
                        Height="38"
                        Margin="10,0,8,0"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Back to Dashboard" />
                    </StackPanel>
                </Button>

                <Button Width="132"
                        Height="38"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="RefreshButton_OnClick">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,10">
            <Border Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Text="Total" Foreground="#5F6F83" />
                    <TextBlock x:Name="TotalCountText"
                               Text="0"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SummaryCardStyle}" Background="#F2FBF5">
                <StackPanel>
                    <TextBlock Text="Success" Foreground="#5F6F83" />
                    <TextBlock x:Name="SuccessCountText"
                               Text="0"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#2E9D5B" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SummaryCardStyle}" Background="#FFF8ED">
                <StackPanel>
                    <TextBlock Text="Denied" Foreground="#5F6F83" />
                    <TextBlock x:Name="DeniedCountText"
                               Text="0"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#B9831A" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SummaryCardStyle}" Background="#FFF5F5">
                <StackPanel>
                    <TextBlock Text="Failed" Foreground="#5F6F83" />
                    <TextBlock x:Name="FailedCountText"
                               Text="0"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#D84343" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SummaryCardStyle}" Background="#F3F5FE">
                <StackPanel>
                    <TextBlock Text="Today" Foreground="#5F6F83" />
                    <TextBlock x:Name="TodayCountText"
                               Text="0"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2"
                Margin="4,0,4,10"
                Padding="10"
                Background="#F8FBFF"
                BorderBrush="#DBE7F4"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchTextBox"
                         Height="38"
                         Margin="0,0,10,0"
                         VerticalContentAlignment="Center"
                         KeyDown="SearchTextBox_OnKeyDown"
                         ToolTip="Search by reference, action, module, user, or details." />

                <ComboBox x:Name="StatusFilterComboBox"
                          Grid.Column="1"
                          Height="38"
                          Margin="0,0,10,0"
                          SelectedIndex="0"
                          SelectionChanged="StatusFilterComboBox_OnSelectionChanged">
                    <ComboBoxItem Content="All Statuses" Tag="ALL" />
                    <ComboBoxItem Content="Success" Tag="SUCCESS" />
                    <ComboBoxItem Content="Denied" Tag="DENIED" />
                    <ComboBoxItem Content="Failed" Tag="FAILED" />
                </ComboBox>

                <Button Grid.Column="2"
                        Width="100"
                        Height="38"
                        Background="#2B5E92"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="ApplyFiltersButton_OnClick">
                    Apply
                </Button>
            </Grid>
        </Border>

        <DataGrid x:Name="TransactionsDataGrid"
                  Grid.Row="3"
                  Margin="4,0,4,10"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#DBE7F4"
                  BorderThickness="1"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="#F9FBFF"
                  AlternationCount="2">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F1F7FF" />
                    <Setter Property="Foreground" Value="#1E4368" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Height" Value="40" />
                    <Setter Property="BorderBrush" Value="#DBE7F4" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Reference" Width="120" Binding="{Binding ReferenceNo}" />
                <DataGridTextColumn Header="Date / Time" Width="170" Binding="{Binding DateTimeText}" />
                <DataGridTextColumn Header="Action" Width="200" Binding="{Binding Action}" />
                <DataGridTextColumn Header="Module" Width="150" Binding="{Binding Module}" />
                <DataGridTextColumn Header="Target" Width="150" Binding="{Binding Target}" />
                <DataGridTextColumn Header="Status" Width="100" Binding="{Binding Status}" />
                <DataGridTextColumn Header="User" Width="130" Binding="{Binding PerformedBy}" />
                <DataGridTextColumn Header="Details" Width="*" Binding="{Binding Details}" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4"
                Margin="4,0,4,0"
                Padding="10,6"
                Background="#F8FBFF"
                BorderBrush="#DBE7F4"
                BorderThickness="1"
                CornerRadius="10">
            <TextBlock x:Name="StatusTextBlock"
                       Text="Ready."
                       Foreground="#4A5B6C"
                       FontWeight="SemiBold" />
        </Border>
    </Grid>
</UserControl>
