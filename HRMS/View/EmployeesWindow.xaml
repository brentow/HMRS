<UserControl x:Class="HRMS.View.EmployeesWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:HRMS.View"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             Background="White">

    <UserControl.Resources>
        <Color x:Key="PrimaryColor">#1E4368</Color>
        <Color x:Key="LightColor">#CBE9FE</Color>
        <Color x:Key="AccentColor">#FDBD55</Color>
        <local:GovernmentIdMaskConverter x:Key="GovernmentIdMaskConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="LightBrush" Color="{StaticResource LightColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5EDF7" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="MinHeight" Value="90" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="44" />
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.93" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
            <Setter Property="Background" Value="#EAF2FB" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D5E3F5" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5B6A7A" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="FieldBoxStyle" TargetType="Control">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Height" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="DateFieldBoxStyle" TargetType="DatePicker" BasedOn="{StaticResource FieldBoxStyle}">
            <Setter Property="Height" Value="38" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode, RelativeSource={RelativeSource AncestorType={x:Type local:EmployeesWindow}}}" Value="True">
                    <Setter Property="IsHitTestVisible" Value="True" />
                    <Setter Property="Focusable" Value="True" />
                </DataTrigger>
            </Style.Triggers>
            <Style.Resources>
                <Style TargetType="{x:Type DatePickerTextBox}">
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Padding" Value="8,0,8,0" />
                </Style>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="HorizontalAlignment" Value="Right" />
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="ReadOnlyFieldBoxStyle" TargetType="TextBox" BasedOn="{StaticResource FieldBoxStyle}">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsReadOnlyCaretVisible" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Arrow" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode, RelativeSource={RelativeSource AncestorType={x:Type local:EmployeesWindow}}}" Value="True">
                    <Setter Property="IsReadOnly" Value="False" />
                    <Setter Property="IsReadOnlyCaretVisible" Value="True" />
                    <Setter Property="Focusable" Value="True" />
                    <Setter Property="Cursor" Value="IBeam" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetailSectionCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="#FBFDFF" />
            <Setter Property="BorderBrush" Value="#D9E6F4" />
        </Style>

        <Style x:Key="DetailFieldCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D8E4F1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="MinHeight" Value="82" />
        </Style>

        <Style x:Key="DetailSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="DetailSectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7C90" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <Style x:Key="DetailFieldTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7C90" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="DetailFieldValueTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ReadOnlyFieldBoxStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DetailFieldComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource FieldBoxStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DetailFieldDatePickerStyle" TargetType="DatePicker" BasedOn="{StaticResource DateFieldBoxStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Style.Resources>
                <Style TargetType="{x:Type DatePickerTextBox}">
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Style>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="HorizontalAlignment" Value="Right" />
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="DetailFieldValueTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

    </UserControl.Resources>

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="AccountGroupOutline"
                                             Width="36"
                                             Height="33"
                                             Foreground="{StaticResource PrimaryBrush}"
                                             Margin="0,0,10,0" />
                    <TextBlock x:Name="PageTitleText"
                               Text="Employees"
                               FontSize="25"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
                <TextBlock x:Name="PageSubtitleText"
                           Text="Employee masterlist, profile details, salary/appointment, and government IDs"
                           Foreground="#5B6A7A"
                           Margin="0,2,0,0" />
            </StackPanel>

            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="BackToDashboardButton"
                        Grid.Column="0"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Margin="0,0,8,0"
                        Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="18" Height="18" Margin="0,0,8,0" />
                        <TextBlock Text="Back to Dashboard" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button x:Name="SearchEmployeeButton"
                        Grid.Column="1"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Margin="8,0,8,0"
                        Click="SearchEmployeeButton_OnClick">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Margin="0,0,8,0" />
                        <TextBlock Text="Search Employee" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Popup x:Name="EmployeeSearchPopup"
                       Grid.Column="1"
                       PlacementTarget="{Binding ElementName=SearchEmployeeButton}"
                       Placement="Bottom"
                       VerticalOffset="8"
                       AllowsTransparency="True"
                       StaysOpen="False"
                       PopupAnimation="Fade"
                       Opened="EmployeeSearchPopup_OnOpened">
                    <Border Width="360"
                            Background="White"
                            BorderBrush="#D9E6F4"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Search Employee"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Width="28"
                                        Height="28"
                                        Padding="0"
                                        BorderThickness="0"
                                        Background="#F2F5FA"
                                        Click="CloseEmployeeSearchButton_OnClick"
                                        ToolTip="Close">
                                    <materialDesign:PackIcon Kind="Close" Width="15" Height="15" Foreground="#6A7684" />
                                </Button>
                            </Grid>
                            <Border Background="#F2F7FD"
                                    BorderBrush="#E0EAF6"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="Magnify"
                                                             Width="18"
                                                             Height="18"
                                                             Foreground="#7A8FA5"
                                                             Margin="0,0,8,0"
                                                             VerticalAlignment="Center" />
                                    <TextBox x:Name="EmployeeSearchTextBox"
                                             Grid.Column="1"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             FontSize="14"
                                             Foreground="#5B6A7A"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalContentAlignment="Center"
                                             KeyDown="EmployeeSearchTextBox_OnKeyDown"
                                             materialDesign:HintAssist.Hint="Search employee name" />
                                </Grid>
                            </Border>
                            <ListBox x:Name="EmployeeSearchResultsListBox"
                                     ItemsSource="{Binding EmployeeSearchResults}"
                                     SelectionChanged="EmployeeSearchResultsListBox_OnSelectionChanged"
                                     MaxHeight="230"
                                     Margin="0,10,0,0"
                                     BorderBrush="#E0EAF6"
                                     BorderThickness="1"
                                     Background="White"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=EmployeeSearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EmployeeSearchResults.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="10,8" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Cursor" Value="Hand" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="AccountCircleOutline"
                                                                     Width="24"
                                                                     Height="24"
                                                                     Foreground="{StaticResource PrimaryBrush}"
                                                                     Margin="0,2,10,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding EmployeeNo, StringFormat=ID: {0}}"
                                                           FontSize="12"
                                                           Foreground="#5B6A7A"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Position}"
                                                           FontSize="12"
                                                           Foreground="#6A7684"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button x:Name="ClearEmployeeSearchButton"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Height="32"
                                    MinWidth="90"
                                    Padding="10,5"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Right"
                                    Click="ClearEmployeeSearchButton_OnClick">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CloseCircleOutline" Width="16" Height="16" Margin="0,0,6,0" />
                                    <TextBlock Text="Clear" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Popup>
                <Button x:Name="AddEmployeeButton"
                        Grid.Column="2"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Margin="8,0,8,0"
                        Click="AddEmployeeButton_OnClick">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlusOutline" Width="18" Height="18" Margin="0,0,8,0" />
                        <TextBlock Text="Add Employee" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button x:Name="EditProfileButton"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Grid.Column="3"
                        Margin="8,0,0,0"
                        Click="EditProfileButton_OnClick">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon x:Name="EditProfileIcon" Kind="AccountEditOutline" Width="18" Height="18" Margin="0,0,8,0" />
                        <TextBlock x:Name="EditProfileText" Text="Edit Profile" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <Border Style="{StaticResource CardStyle}">
                <Grid x:Name="EmployeeDetailsCard">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="42"
                                Height="42"
                                CornerRadius="21"
                                Background="#EAF2FB"
                                Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="AccountCircle"
                                                     Width="24"
                                                     Height="24"
                                                     Foreground="{StaticResource PrimaryBrush}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedEmployee.Name, TargetNullValue=No Employee Selected, FallbackValue=No Employee Selected}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedEmployee.EmployeeNo, StringFormat=Employee ID: {0}, TargetNullValue=Employee ID: -, FallbackValue=Employee ID: -}"
                                       Foreground="#5B6A7A"
                                       Margin="0,2,0,0" />
                        </StackPanel>

                        <Button x:Name="SaveProfileButton"
                                Grid.Column="2"
                                Visibility="Collapsed"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Height="38"
                                Margin="12,0,0,0"
                                MinWidth="120"
                                Click="SaveProfileButton_OnClick">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSaveOutline" Width="18" Height="18" Margin="0,0,8,0" />
                                <TextBlock Text="Save" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TabControl x:Name="EmployeeDetailsTabs"
                                Grid.Row="1"
                                Background="White"
                                BorderBrush="#DDE8F6"
                                BorderThickness="1"
                                SelectionChanged="EmployeeDetailsTabs_OnSelectionChanged">
                        <TabControl.ItemContainerStyle>
                            <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                                <Setter Property="Padding" Value="10,6" />
                                <Setter Property="MinWidth" Value="0" />
                                <Setter Property="FontSize" Value="13" />
                            </Style>
                        </TabControl.ItemContainerStyle>
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                    <materialDesign:PackIcon Kind="AccountDetailsOutline" Width="16" Height="16" Margin="0,0,6,0" />
                                    <TextBlock Text="Profile" />
                                </StackPanel>
                            </TabItem.Header>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Border Margin="12"
                                        Style="{StaticResource DetailSectionCardStyle}"
                                        Background="#F8FBFF">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="42"
                                                    Height="42"
                                                    CornerRadius="21"
                                                    Background="#DDECFD"
                                                    VerticalAlignment="Top">
                                                <materialDesign:PackIcon Kind="AccountDetailsOutline"
                                                                         Width="22"
                                                                         Height="22"
                                                                         Foreground="{StaticResource PrimaryBrush}"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center" />
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                <TextBlock Text="Profile Details"
                                                           Style="{StaticResource DetailSectionTitleStyle}" />
                                                <TextBlock Text="Core employee information and current assignment."
                                                           Style="{StaticResource DetailSectionSubtitleStyle}" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0"
                                                    Grid.Column="0"
                                                    Margin="0,0,10,12"
                                                    Style="{StaticResource DetailFieldCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Employee No"
                                                               Style="{StaticResource DetailFieldTitleStyle}" />
                                                    <TextBox Text="{Binding SelectedEmployee.EmployeeNo, Mode=TwoWay, TargetNullValue=''}"
                                                             Style="{StaticResource DetailFieldValueTextBoxStyle}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="0"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,12"
                                                    Style="{StaticResource DetailFieldCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Hire Date"
                                                               Style="{StaticResource DetailFieldTitleStyle}" />
                                                    <DatePicker SelectedDate="{Binding SelectedEmployee.HireDate, Mode=TwoWay}"
                                                                Style="{StaticResource DetailFieldDatePickerStyle}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1"
                                                    Grid.Column="0"
                                                    Margin="0,0,10,12"
                                                    Style="{StaticResource DetailFieldCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Full Name"
                                                               Style="{StaticResource DetailFieldTitleStyle}" />
                                                    <TextBox Text="{Binding SelectedEmployee.Name, Mode=TwoWay, TargetNullValue=''}"
                                                             Style="{StaticResource DetailFieldValueTextBoxStyle}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,12"
                                                    Style="{StaticResource DetailFieldCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Status"
                                                               Style="{StaticResource DetailFieldTitleStyle}" />
                                                    <TextBox Text="{Binding SelectedEmployee.Status, Mode=TwoWay, TargetNullValue=''}"
                                                             Style="{StaticResource DetailFieldValueTextBoxStyle}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="2"
                                                    Grid.Column="0"
                                                    Margin="0,0,10,0"
                                                    Style="{StaticResource DetailFieldCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Department"
                                                               Style="{StaticResource DetailFieldTitleStyle}" />
                                                    <Grid>
                                                        <TextBox x:Name="ProfileDepartmentTextBox"
                                                                 Text="{Binding SelectedEmployee.Department, Mode=TwoWay, TargetNullValue=''}"
                                                                 Style="{StaticResource DetailFieldValueTextBoxStyle}" />
                                                        <ComboBox x:Name="ProfileDepartmentComboBox"
                                                                  Visibility="Collapsed"
                                                                  Style="{StaticResource DetailFieldComboBoxStyle}"
                                                                  DisplayMemberPath="Name"
                                                                  SelectedValuePath="Name"
                                                                  SelectionChanged="ProfileDepartmentComboBox_OnSelectionChanged" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="2"
                                                    Grid.Column="1"
                                                    Style="{StaticResource DetailFieldCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Position"
                                                               Style="{StaticResource DetailFieldTitleStyle}" />
                                                    <Grid>
                                                        <TextBox x:Name="ProfilePositionTextBox"
                                                                 Text="{Binding SelectedEmployee.Position, Mode=TwoWay, TargetNullValue=''}"
                                                                 Style="{StaticResource DetailFieldValueTextBoxStyle}" />
                                                        <ComboBox x:Name="ProfilePositionComboBox"
                                                                  Visibility="Collapsed"
                                                                  Style="{StaticResource DetailFieldComboBoxStyle}"
                                                                  DisplayMemberPath="Name"
                                                                  SelectedValuePath="Name"
                                                                  SelectionChanged="ProfilePositionComboBox_OnSelectionChanged" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                    <materialDesign:PackIcon Kind="ClockOutline" Width="16" Height="16" Margin="0,0,6,0" />
                                    <TextBlock Text="Attendance" />
                                </StackPanel>
                            </TabItem.Header>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="12">
                                    <Border Style="{StaticResource DetailSectionCardStyle}"
                                            Background="#F8FBFF"
                                            Margin="0,0,0,12">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="42"
                                                        Height="42"
                                                        CornerRadius="21"
                                                        Background="#DDECFD"
                                                        VerticalAlignment="Top">
                                                    <materialDesign:PackIcon Kind="ClockOutline"
                                                                             Width="22"
                                                                             Height="22"
                                                                             Foreground="{StaticResource PrimaryBrush}"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                    <TextBlock Text="Attendance Drill-Down"
                                                               Style="{StaticResource DetailSectionTitleStyle}" />
                                                    <TextBlock Text="Current month DTR rows and the latest attendance punches for the selected employee."
                                                               Style="{StaticResource DetailSectionSubtitleStyle}" />
                                                </StackPanel>
                                            </Grid>

                                            <Border Background="#EFF6FF"
                                                    BorderBrush="#D7E6F7"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="10"
                                                    Margin="0,0,0,12">
                                                <TextBlock Text="{Binding SelectedEmployeeAttendanceSummary}"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                            </Border>

                                            <TextBlock Text="Current Month DTR"
                                                       Style="{StaticResource DetailSectionTitleStyle}"
                                                       FontSize="15"
                                                       Margin="0,0,0,8" />

                                            <DataGrid ItemsSource="{Binding SelectedEmployeeCurrentMonthAttendance}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      IsReadOnly="True"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      BorderBrush="#E3ECF8"
                                                      BorderThickness="1"
                                                      RowHeaderWidth="0"
                                                      RowBackground="White"
                                                      AlternatingRowBackground="#F8FBFF"
                                                      HorizontalGridLinesBrush="#E9F0FA"
                                                      VerticalGridLinesBrush="#E9F0FA"
                                                      ColumnHeaderHeight="40"
                                                      RowHeight="42"
                                                      Margin="0,0,0,14">
                                                <DataGrid.ColumnHeaderStyle>
                                                    <Style TargetType="DataGridColumnHeader">
                                                        <Setter Property="Background" Value="#F2F7FD" />
                                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                        <Setter Property="BorderBrush" Value="#E3ECF8" />
                                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                        <Setter Property="Padding" Value="8,0,8,0" />
                                                    </Style>
                                                </DataGrid.ColumnHeaderStyle>
                                                <DataGrid.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="Padding" Value="8,0,8,0" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                                    </Style>
                                                </DataGrid.CellStyle>
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Date" Binding="{Binding WorkDateText}" Width="118" />
                                                    <DataGridTextColumn Header="Day" Binding="{Binding DayName}" Width="76" />
                                                    <DataGridTextColumn Header="Time In" Binding="{Binding TimeInText}" Width="96" />
                                                    <DataGridTextColumn Header="Time Out" Binding="{Binding TimeOutText}" Width="96" />
                                                    <DataGridTextColumn Header="Worked" Binding="{Binding WorkedHoursText}" Width="96" />
                                                    <DataGridTextColumn Header="Flag" Binding="{Binding AttendanceFlag}" Width="145" />
                                                    <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="*" />
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock Text="Recent Attendance Logs"
                                                       Style="{StaticResource DetailSectionTitleStyle}"
                                                       FontSize="15"
                                                       Margin="0,0,0,8" />

                                            <DataGrid ItemsSource="{Binding SelectedEmployeeRecentLogs}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      IsReadOnly="True"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      BorderBrush="#E3ECF8"
                                                      BorderThickness="1"
                                                      RowHeaderWidth="0"
                                                      RowBackground="White"
                                                      AlternatingRowBackground="#F8FBFF"
                                                      HorizontalGridLinesBrush="#E9F0FA"
                                                      VerticalGridLinesBrush="#E9F0FA"
                                                      ColumnHeaderHeight="40"
                                                      RowHeight="42">
                                                <DataGrid.ColumnHeaderStyle>
                                                    <Style TargetType="DataGridColumnHeader">
                                                        <Setter Property="Background" Value="#F2F7FD" />
                                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                        <Setter Property="BorderBrush" Value="#E3ECF8" />
                                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                        <Setter Property="Padding" Value="8,0,8,0" />
                                                    </Style>
                                                </DataGrid.ColumnHeaderStyle>
                                                <DataGrid.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="Padding" Value="8,0,8,0" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                                    </Style>
                                                </DataGrid.CellStyle>
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Date" Binding="{Binding LogDateText}" Width="130" />
                                                    <DataGridTextColumn Header="Time" Binding="{Binding LogTimeText}" Width="110" />
                                                    <DataGridTextColumn Header="Type" Binding="{Binding LogType}" Width="110" />
                                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="110" />
                                                    <DataGridTextColumn Header="Device" Binding="{Binding DeviceName}" Width="*" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                    <materialDesign:PackIcon Kind="CashMultiple" Width="16" Height="16" Margin="0,0,6,0" />
                                    <TextBlock Text="Salary / Appt." />
                                </StackPanel>
                            </TabItem.Header>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="12">
                                    <Border Background="#F4F9FF" BorderBrush="#DDE8F6" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="38" Height="38" CornerRadius="19" Background="#DDECFD" VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="CurrencyPhp" Width="20" Height="20" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Monthly Salary" Foreground="#5B6A7A" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding SelectedEmployee.MonthlySalary, StringFormat=PHP {0}, TargetNullValue=PHP 0.00}"
                                                           FontSize="22"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource PrimaryBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Background="#F8FCFF" BorderBrush="#DDE8F6" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="14" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="46"
                                                    Height="46"
                                                    CornerRadius="23"
                                                    Background="#DDECFD"
                                                    VerticalAlignment="Center">
                                                <materialDesign:PackIcon Kind="ClockOutline"
                                                                         Width="22"
                                                                         Height="22"
                                                                         Foreground="{StaticResource PrimaryBrush}"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center" />
                                            </Border>

                                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                    <TextBlock Text="Month"
                                                               Foreground="#5B6A7A"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"
                                                               HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding SelectedEmployee.CurrentMonthLabel, TargetNullValue=--, FallbackValue=--}"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               FontWeight="Bold"
                                                               FontSize="13"
                                                               Margin="0,2,0,0"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                    <TextBlock Text="Worked Days"
                                                               Foreground="#5B6A7A"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"
                                                               HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding SelectedEmployee.CurrentMonthWorkedDays, TargetNullValue=0, FallbackValue=0}"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               FontWeight="Bold"
                                                               FontSize="13"
                                                               Margin="0,2,0,0"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                    <TextBlock Text="Worked Hours"
                                                               Foreground="#5B6A7A"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"
                                                               HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding SelectedEmployee.CurrentMonthWorkedHoursText, TargetNullValue=0 hrs, FallbackValue=0 hrs}"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               FontWeight="Bold"
                                                               FontSize="13"
                                                               Margin="0,2,0,0"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                                    <TextBlock Text="Last DTR"
                                                               Foreground="#5B6A7A"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"
                                                               HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding SelectedEmployee.CurrentMonthLastWorkDateText, TargetNullValue=--, FallbackValue=--}"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               FontWeight="Bold"
                                                               FontSize="13"
                                                               Margin="0,2,0,0"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Background="#FFF9F1" BorderBrush="#F0DFC4" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="38" Height="38" CornerRadius="19" Background="#FCE5BA" VerticalAlignment="Top">
                                                    <materialDesign:PackIcon Kind="ReceiptTextOutline" Width="20" Height="20" Foreground="#A56B00" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock Text="Latest Payroll Snapshot"
                                                               Foreground="#5B6A7A"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SelectedEmployee.LatestPayrollPeriodCode, StringFormat=Period: {0}, TargetNullValue=Period: -, FallbackValue=Period: -}"
                                                               FontSize="18"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0"
                                                        Background="White"
                                                        BorderBrush="#EED7AF"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="14">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                <TextBlock Text="Generated"
                                                                           Foreground="#6A7684"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="12" />
                                                                <TextBlock Text="{Binding SelectedEmployee.LatestPayrollGeneratedText}"
                                                                           Foreground="{StaticResource PrimaryBrush}"
                                                                           FontWeight="Bold"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="Status"
                                                                           Foreground="#6A7684"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="12" />
                                                                <TextBlock Text="{Binding SelectedEmployee.LatestPayrollStatus}"
                                                                           Foreground="{StaticResource PrimaryBrush}"
                                                                           FontWeight="Bold"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Grid>

                                                        <Border Grid.Row="1"
                                                                Height="1"
                                                                Background="#F1E2C8"
                                                                Margin="0,0,0,12" />

                                                        <StackPanel Grid.Row="2" Margin="0,0,0,10">
                                                            <StackPanel Orientation="Horizontal">
                                                                <materialDesign:PackIcon Kind="Receipt" Width="16" Height="16" Margin="0,0,6,0" Foreground="#A56B00" />
                                                                <TextBlock Text="Receipt"
                                                                           Foreground="#A56B00"
                                                                           FontWeight="SemiBold" />
                                                            </StackPanel>
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Text="Earnings"
                                                                       Foreground="{StaticResource PrimaryBrush}"
                                                                       FontSize="16"
                                                                       FontWeight="Bold" />
                                                        </StackPanel>

                                                        <Grid Grid.Row="3" Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Basic Pay" Foreground="#5B6A7A" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding SelectedEmployee.LatestPayrollBasicPayText}"
                                                                       Foreground="{StaticResource PrimaryBrush}"
                                                                       FontWeight="Bold"
                                                                       TextAlignment="Right" />
                                                        </Grid>

                                                        <Grid Grid.Row="4" Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Allowances" Foreground="#5B6A7A" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding SelectedEmployee.LatestPayrollAllowancesText}"
                                                                       Foreground="{StaticResource PrimaryBrush}"
                                                                       FontWeight="Bold"
                                                                       TextAlignment="Right" />
                                                        </Grid>

                                                        <Grid Grid.Row="5" Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Overtime" Foreground="#5B6A7A" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding SelectedEmployee.LatestPayrollOvertimePayText}"
                                                                       Foreground="{StaticResource PrimaryBrush}"
                                                                       FontWeight="Bold"
                                                                       TextAlignment="Right" />
                                                        </Grid>

                                                        <Grid Grid.Row="6" Margin="0,0,0,12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Other Earnings" Foreground="#5B6A7A" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding SelectedEmployee.LatestPayrollOtherEarningsText}"
                                                                       Foreground="{StaticResource PrimaryBrush}"
                                                                       FontWeight="Bold"
                                                                       TextAlignment="Right" />
                                                        </Grid>

                                                        <Border Grid.Row="7"
                                                                Height="1"
                                                                Background="#F1E2C8"
                                                                Margin="0,0,0,12" />

                                                        <Grid Grid.Row="8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Gross Pay"
                                                                       Foreground="{StaticResource PrimaryBrush}"
                                                                       FontWeight="Bold"
                                                                       FontSize="15" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding SelectedEmployee.LatestPayrollGrossPayText}"
                                                                       Foreground="{StaticResource PrimaryBrush}"
                                                                       FontWeight="Bold"
                                                                       FontSize="15"
                                                                       TextAlignment="Right" />
                                                        </Grid>
                                                    </Grid>
                                                </Border>

                                                <Border Grid.Row="1"
                                                        Background="#FFFDF8"
                                                        BorderBrush="#EED7AF"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="14"
                                                        Margin="0,12,0,0">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                                            <StackPanel Orientation="Horizontal">
                                                                <materialDesign:PackIcon Kind="CashMinus" Width="16" Height="16" Margin="0,0,6,0" Foreground="#B9831A" />
                                                                <TextBlock Text="Deductions"
                                                                           Foreground="#B9831A"
                                                                           FontWeight="SemiBold" />
                                                            </StackPanel>
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Text="{Binding SelectedEmployee.LatestPayrollDeductionsTotalText}"
                                                                       Foreground="#B9831A"
                                                                       FontSize="22"
                                                                       FontWeight="Bold"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                                            <Border Margin="0,0,0,8"
                                                                    Padding="10,8"
                                                                    Background="White"
                                                                    BorderBrush="#EED7AF"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <StackPanel>
                                                                    <TextBlock Text="Net Pay"
                                                                               Foreground="#6A7684"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="12" />
                                                                    <TextBlock Text="{Binding SelectedEmployee.LatestPayrollNetPayText}"
                                                                               Foreground="#2E9D5B"
                                                                               FontWeight="Bold"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>

                                                            <Border Padding="10,8"
                                                                    Background="White"
                                                                    BorderBrush="#EED7AF"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <StackPanel>
                                                                    <TextBlock Text="Period Status"
                                                                               Foreground="#6A7684"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="12" />
                                                                    <TextBlock Text="{Binding SelectedEmployee.LatestPayrollStatus}"
                                                                               Foreground="{StaticResource PrimaryBrush}"
                                                                               FontWeight="Bold"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>

                                                        <TextBlock Grid.Row="2"
                                                                   Text="Breakdown"
                                                                   Style="{StaticResource FieldLabelStyle}"
                                                                   Margin="0,0,0,6" />

                                                        <Border Grid.Row="3"
                                                                Background="White"
                                                                BorderBrush="#E6D8BD"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="12">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="*" />
                                                                </Grid.RowDefinitions>

                                                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="110" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="Item"
                                                                               Foreground="#6A7684"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="12" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="Amount"
                                                                               Foreground="#6A7684"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="12"
                                                                               TextAlignment="Right" />
                                                                </Grid>

                                                                <Border Grid.Row="1"
                                                                        Height="1"
                                                                        Background="#F1E2C8"
                                                                        Margin="0,0,0,8" />

                                                                <ItemsControl Grid.Row="2"
                                                                              ItemsSource="{Binding SelectedEmployee.LatestPayrollDeductionLines}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border BorderBrush="#F4E6CB"
                                                                                    BorderThickness="0,0,0,1"
                                                                                    Padding="0,0,0,8"
                                                                                    Margin="0,0,0,8">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="110" />
                                                                                    </Grid.ColumnDefinitions>

                                                                                    <TextBlock Text="{Binding Label}"
                                                                                               Margin="0,0,12,0"
                                                                                               TextWrapping="Wrap">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock">
                                                                                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding HasAmount}" Value="False">
                                                                                                        <Setter Property="Foreground" Value="#6A7684" />
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>

                                                                                    <TextBlock Grid.Column="1"
                                                                                               Text="{Binding Amount}"
                                                                                               Foreground="#B9831A"
                                                                                               FontWeight="SemiBold"
                                                                                               TextAlignment="Right"
                                                                                               VerticalAlignment="Top">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding HasAmount}" Value="False">
                                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                </Grid>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Grid>
                                                        </Border>

                                                        <Border Grid.Row="4"
                                                                Margin="0,12,0,0"
                                                                Padding="10,8"
                                                                Background="#FFF6E5"
                                                                BorderBrush="#EED7AF"
                                                                BorderThickness="1"
                                                                CornerRadius="8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="110" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="Take Home Pay"
                                                                           Foreground="#6A7684"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding SelectedEmployee.LatestPayrollNetPayText}"
                                                                           Foreground="#2E9D5B"
                                                                           FontWeight="Bold"
                                                                           Margin="12,0,0,0"
                                                                           TextAlignment="Right" />
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource DetailSectionCardStyle}"
                                            Background="#FFFBF5"
                                            BorderBrush="#F0DFC4">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="42"
                                                        Height="42"
                                                        CornerRadius="21"
                                                        Background="#FCE5BA"
                                                        VerticalAlignment="Top">
                                                    <materialDesign:PackIcon Kind="CashMultiple"
                                                                             Width="22"
                                                                             Height="22"
                                                                             Foreground="#A56B00"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                    <TextBlock Text="Appointment and Salary Structure"
                                                               Style="{StaticResource DetailSectionTitleStyle}" />
                                                    <TextBlock Text="Current appointment classification, salary step, and plantilla alignment."
                                                               Style="{StaticResource DetailSectionSubtitleStyle}" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0"
                                                        Grid.Column="0"
                                                        Margin="0,0,10,12"
                                                        Style="{StaticResource DetailFieldCardStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="Appointment Type"
                                                                   Style="{StaticResource DetailFieldTitleStyle}" />
                                                        <Grid>
                                                            <TextBox x:Name="SalaryAppointmentTypeTextBox"
                                                                     Text="{Binding SelectedEmployee.AppointmentType, Mode=TwoWay, TargetNullValue=''}"
                                                                     Style="{StaticResource DetailFieldValueTextBoxStyle}" />
                                                            <ComboBox x:Name="SalaryAppointmentTypeComboBox"
                                                                      Visibility="Collapsed"
                                                                      Style="{StaticResource DetailFieldComboBoxStyle}"
                                                                      DisplayMemberPath="Name"
                                                                      SelectedValuePath="Name"
                                                                      SelectionChanged="SalaryAppointmentTypeComboBox_OnSelectionChanged" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Row="0"
                                                        Grid.Column="1"
                                                        Margin="0,0,0,12"
                                                        Style="{StaticResource DetailFieldCardStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="Step"
                                                                   Style="{StaticResource DetailFieldTitleStyle}" />
                                                        <Grid>
                                                            <TextBox x:Name="SalaryStepTextBox"
                                                                     Text="{Binding SelectedEmployee.SalaryStep, Mode=TwoWay, TargetNullValue=''}"
                                                                     Style="{StaticResource DetailFieldValueTextBoxStyle}" />
                                                            <ComboBox x:Name="SalaryStepComboBox"
                                                                      Visibility="Collapsed"
                                                                      Style="{StaticResource DetailFieldComboBoxStyle}"
                                                                      SelectionChanged="SalaryStepComboBox_OnSelectionChanged" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Row="1"
                                                        Grid.Column="0"
                                                        Margin="0,0,10,0"
                                                        Style="{StaticResource DetailFieldCardStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="Salary Grade (SG)"
                                                                   Style="{StaticResource DetailFieldTitleStyle}" />
                                                        <Grid>
                                                            <TextBox x:Name="SalaryGradeTextBox"
                                                                     Text="{Binding SelectedEmployee.SalaryGrade, Mode=TwoWay, TargetNullValue=''}"
                                                                     Style="{StaticResource DetailFieldValueTextBoxStyle}" />
                                                            <ComboBox x:Name="SalaryGradeComboBox"
                                                                      Visibility="Collapsed"
                                                                      Style="{StaticResource DetailFieldComboBoxStyle}"
                                                                      SelectionChanged="SalaryGradeComboBox_OnSelectionChanged" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Row="1"
                                                        Grid.Column="1"
                                                        Style="{StaticResource DetailFieldCardStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="Department / Position"
                                                                   Style="{StaticResource DetailFieldTitleStyle}" />
                                                        <TextBlock Style="{StaticResource DetailFieldValueTextBlockStyle}"
                                                                   TextWrapping="Wrap">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0} / {1}">
                                                                    <Binding Path="SelectedEmployee.Department" TargetNullValue="-" />
                                                                    <Binding Path="SelectedEmployee.Position" TargetNullValue="-" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                            <TextBlock.ToolTip>
                                                                <MultiBinding StringFormat="{}{0} / {1}">
                                                                    <Binding Path="SelectedEmployee.Department" TargetNullValue="-" />
                                                                    <Binding Path="SelectedEmployee.Position" TargetNullValue="-" />
                                                                </MultiBinding>
                                                            </TextBlock.ToolTip>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                    <materialDesign:PackIcon Kind="CardAccountDetailsOutline" Width="16" Height="16" Margin="0,0,6,0" />
                                    <TextBlock Text="Government IDs" />
                                </StackPanel>
                            </TabItem.Header>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Border Margin="12"
                                        Style="{StaticResource DetailSectionCardStyle}"
                                        Background="#FAFCFF">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="42"
                                                    Height="42"
                                                    CornerRadius="21"
                                                    Background="#E7EEF8"
                                                    VerticalAlignment="Top">
                                                <materialDesign:PackIcon Kind="CardAccountDetailsOutline"
                                                                         Width="22"
                                                                         Height="22"
                                                                         Foreground="{StaticResource PrimaryBrush}"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center" />
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                <TextBlock Text="Government IDs"
                                                           Style="{StaticResource DetailSectionTitleStyle}" />
                                                <TextBlock Text="Registered employee numbers for statutory payroll and benefits."
                                                           Style="{StaticResource DetailSectionSubtitleStyle}" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0"
                                                    Grid.Column="0"
                                                    Margin="0,0,10,12"
                                                    Style="{StaticResource DetailFieldCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="TIN No."
                                                               Style="{StaticResource DetailFieldTitleStyle}" />
                                                    <TextBox Style="{StaticResource DetailFieldValueTextBoxStyle}">
                                                        <TextBox.Text>
                                                            <MultiBinding Converter="{StaticResource GovernmentIdMaskConverter}" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                                                                <Binding Path="SelectedEmployee.TinNo" Mode="TwoWay" TargetNullValue="" />
                                                                <Binding RelativeSource="{RelativeSource Self}" Path="IsReadOnly" Mode="OneWay" />
                                                            </MultiBinding>
                                                        </TextBox.Text>
                                                    </TextBox>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="0"
                                                    Grid.Column="1"
                                                    Margin="0,0,0,12"
                                                    Style="{StaticResource DetailFieldCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="PhilHealth No."
                                                               Style="{StaticResource DetailFieldTitleStyle}" />
                                                    <TextBox Style="{StaticResource DetailFieldValueTextBoxStyle}">
                                                        <TextBox.Text>
                                                            <MultiBinding Converter="{StaticResource GovernmentIdMaskConverter}" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                                                                <Binding Path="SelectedEmployee.PhilHealthNo" Mode="TwoWay" TargetNullValue="" />
                                                                <Binding RelativeSource="{RelativeSource Self}" Path="IsReadOnly" Mode="OneWay" />
                                                            </MultiBinding>
                                                        </TextBox.Text>
                                                    </TextBox>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1"
                                                    Grid.Column="0"
                                                    Margin="0,0,10,0"
                                                    Style="{StaticResource DetailFieldCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="GSIS BP No."
                                                               Style="{StaticResource DetailFieldTitleStyle}" />
                                                    <TextBox Style="{StaticResource DetailFieldValueTextBoxStyle}">
                                                        <TextBox.Text>
                                                            <MultiBinding Converter="{StaticResource GovernmentIdMaskConverter}" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                                                                <Binding Path="SelectedEmployee.GsisBpNo" Mode="TwoWay" TargetNullValue="" />
                                                                <Binding RelativeSource="{RelativeSource Self}" Path="IsReadOnly" Mode="OneWay" />
                                                            </MultiBinding>
                                                        </TextBox.Text>
                                                    </TextBox>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1"
                                                    Grid.Column="1"
                                                    Style="{StaticResource DetailFieldCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="PAG-IBIG MID No."
                                                               Style="{StaticResource DetailFieldTitleStyle}" />
                                                    <TextBox Style="{StaticResource DetailFieldValueTextBoxStyle}">
                                                        <TextBox.Text>
                                                            <MultiBinding Converter="{StaticResource GovernmentIdMaskConverter}" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                                                                <Binding Path="SelectedEmployee.PagibigMidNo" Mode="TwoWay" TargetNullValue="" />
                                                                <Binding RelativeSource="{RelativeSource Self}" Path="IsReadOnly" Mode="OneWay" />
                                                            </MultiBinding>
                                                        </TextBox.Text>
                                                    </TextBox>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>

                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="AddEmployeeHost"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Panel.ZIndex="10"
              Background="White">
            <local:AddEmployeeWindow x:Name="AddEmployeeForm"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     EmployeeSaved="AddEmployeeForm_EmployeeSaved"
                                     Cancelled="AddEmployeeForm_Cancelled" />
        </Grid>
    </Grid>
</UserControl>
