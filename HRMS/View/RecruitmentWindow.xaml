<UserControl x:Class="HRMS.View.RecruitmentWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:HRMS.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             Background="White">
    <UserControl.Resources>
        <Color x:Key="PrimaryColor">#1E4368</Color>
        <Color x:Key="LightColor">#CBE9FE</Color>
        <Color x:Key="AccentColor">#FDBD55</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="LightBrush" Color="{StaticResource LightColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5EDF7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="6" />
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.DataContext>
            <vm:RecruitmentViewModel/>
        </Grid.DataContext>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Recruitment" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock Text="Open roles, applicants, and interviews" Foreground="#5B6A7A" />
                    </StackPanel>
                </Grid>

                <UniformGrid Columns="4" Rows="1" Margin="0,0,0,16">
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Job Posts" Foreground="#6A7684"/>
                            <TextBlock Text="{Binding TotalPosts}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Open Posts" Foreground="#6A7684"/>
                            <TextBlock Text="{Binding OpenPosts}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Applicants" Foreground="#6A7684"/>
                            <TextBlock Text="{Binding Applicants}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Interviews" Foreground="#6A7684"/>
                            <TextBlock Text="{Binding Interviews}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Job posts -->
                    <Border Grid.Column="0" Style="{StaticResource StatCardStyle}" Padding="18" Margin="6,6,6,6">
                        <StackPanel>
                            <TextBlock Text="Recent Job Posts" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding JobPosts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:JobPostVm}">
                                        <Border BorderBrush="#E5EDF7" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,6,0,0" Background="#F9FBFF">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                                                    <TextBlock Text="{Binding Department}" Foreground="#5B6A7A" />
                                                    <TextBlock Text="{Binding PostedAt, StringFormat='Posted: {0:MMM dd, yyyy}'}" Foreground="#6A7684" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#CBE9FE" CornerRadius="8" Padding="10,4" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Applicants -->
                    <Border Grid.Column="1" Style="{StaticResource StatCardStyle}" Padding="18" Margin="6,6,6,6">
                        <StackPanel>
                            <TextBlock Text="Recent Applicants" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding RecentApplicants}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ApplicantVm}">
                                        <Border BorderBrush="#E5EDF7" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,6,0,0" Background="#F9FBFF">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                                                    <TextBlock Text="{Binding JobTitle}" Foreground="#5B6A7A" />
                                                    <TextBlock Text="{Binding AppliedAt, StringFormat='Applied: {0:MMM dd, yyyy}'}" Foreground="#6A7684" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#FDBD55" CornerRadius="8" Padding="10,4" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Status}" Foreground="#1E4368" FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
