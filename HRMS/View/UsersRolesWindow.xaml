<UserControl x:Class="HRMS.View.UsersRolesWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:HRMS.ViewModel"
             xmlns:local="clr-namespace:HRMS"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900"
             Background="White">
    <UserControl.Resources>
        <Color x:Key="PrimaryColor">#1E4368</Color>
        <Color x:Key="LightColor">#CBE9FE</Color>
        <Color x:Key="AccentColor">#FDBD55</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="LightBrush" Color="{StaticResource LightColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <local:BooleanToActiveTextConverter x:Key="BooleanToActiveText"/>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5EDF7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        <Style x:Key="PillBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.DataContext>
            <vm:UsersRolesViewModel/>
        </Grid.DataContext>
        <StackPanel Margin="20">
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Users &amp; Roles" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Manage user access and roles across the system." Foreground="#5B6A7A"/>
                </StackPanel>
            </Grid>

            <UniformGrid Columns="4" Rows="1" Margin="0,0,0,14">
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Total Users" Foreground="#6A7684"/>
                        <TextBlock Text="{Binding TotalUsers}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Total Managers" Foreground="#6A7684"/>
                        <TextBlock Text="{Binding ManagerUsers}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Total Roles" Foreground="#6A7684"/>
                        <TextBlock Text="{Binding TotalRoles}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Admins" Foreground="#6A7684"/>
                        <TextBlock Text="{Binding AdminUsers}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource StatCardStyle}" Padding="18">
                <StackPanel>
                    <TextBlock Text="Users" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding Users}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:UserDisplay}">
                                <Border BorderBrush="#E5EDF7" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,6,0,0" Background="#F9FBFF">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1.4*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Username}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                                            <TextBlock Text="{Binding Roles}" Foreground="#5B6A7A" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding DataContext.Roles, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding CurrentRole, Mode=TwoWay}"
                                                  Margin="149,0,10,0"
                                                  Height="28"/>
                                        <Button Grid.Column="2"
                                                Content="Save"
                                                Padding="10,4"
                                                Margin="0,0,10,0"
                                                Background="{StaticResource AccentBrush}"
                                                Foreground="{StaticResource PrimaryBrush}"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.SaveRoleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Border Grid.Column="3"
                                                Style="{StaticResource PillBadge}"
                                                Background="{Binding StatusColor}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding IsActive, Converter={StaticResource BooleanToActiveText}}" Foreground="White" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
