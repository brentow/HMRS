<UserControl x:Class="HRMS.View.TrainingWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:HRMS.ViewModel"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             Background="White">

    <UserControl.Resources>
        <Color x:Key="PrimaryColor">#1E4368</Color>
        <Color x:Key="LightColor">#CBE9FE</Color>
        <Color x:Key="AccentColor">#FDBD55</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="LightBrush" Color="{StaticResource LightColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5EDF7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="6" />
        </Style>

        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Background" Value="{StaticResource LightBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="16" />
        </Style>


        <DataTemplate x:Key="CourseCardTemplate" DataType="{x:Type vm:TrainingCourseSummary}">
            <Border Style="{StaticResource StatCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" />
                            <TextBlock Text="{Binding Provider}" Foreground="#5B6A7A" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Edit"
                                Padding="10,4"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Click="CourseEdit_Click"/>
                    </Grid>
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="{Binding Description}" Foreground="#6A7684" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Hours: " Foreground="#6A7684"/>
                            <TextBlock Text="{Binding Hours}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="   Status: " Foreground="#6A7684" Margin="8,0,0,0"/>
                            <TextBlock Text="{Binding Status}" FontWeight="Bold" Foreground="{Binding StatusColor}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="EnrollmentRowTemplate" DataType="{x:Type vm:TrainingEnrollment}">
            <Grid Margin="0,6" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" SharedSizeGroup="EnrollName" />
                    <ColumnDefinition Width="2.6*" SharedSizeGroup="EnrollCourse" />
                    <ColumnDefinition Width="1.6*" SharedSizeGroup="EnrollDate" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="EnrollStatus" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Employee}" Grid.Column="0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Course}" Grid.Column="1" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <Binding Path="ScheduleDate" StringFormat="{}{0:MMM dd, yyyy}" />
                    </TextBlock.Text>
                </TextBlock>
                <Border Grid.Column="3"
                        Margin="12,0,6,0"
                        Padding="12,4"
                        CornerRadius="10"
                        Background="{Binding StatusColor}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        MinWidth="90">
                    <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="White">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20" Background="White">
                <!-- Header -->
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Training" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock Text="Courses, enrollments, and completions" Foreground="#5B6A7A" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,-4">
                        <Button Content="Add Course"
                                Padding="14,10"
                                Margin="10,0,0,0"
                                Background="{StaticResource PrimaryBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                materialDesign:ButtonAssist.CornerRadius="10" Height="37"
                                Click="AddCourse_Click" />
                        <Button Content="Enroll Employee"
                                Padding="14,10"
                                Margin="10,0,0,0"
                                Background="{StaticResource AccentBrush}"
                                Foreground="{StaticResource PrimaryBrush}"
                                BorderThickness="0"
                                materialDesign:ButtonAssist.CornerRadius="10" Height="38"
                                Click="EnrollEmployee_Click" />
                    </StackPanel>
                </Grid>

                <!-- Filters -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="All"
                            Command="{Binding FilterCommand}"
                            CommandParameter="All">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="All">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Active"
                            Command="{Binding FilterCommand}"
                            CommandParameter="Active">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="Active">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Completed"
                            Command="{Binding FilterCommand}"
                            CommandParameter="Completed">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="Completed">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Scheduled"
                            Command="{Binding FilterCommand}"
                            CommandParameter="Scheduled">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="Scheduled">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Stats cards -->
                <UniformGrid Columns="4" Rows="1" Margin="0,6,0,18">
                    <Border Style="{StaticResource StatCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="42" Height="42" CornerRadius="21" Background="{StaticResource PrimaryBrush}" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8D2;" FontFamily="Segoe Fluent Icons" Foreground="White" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Total Courses" Foreground="#6A7684"/>
                                <TextBlock Text="{Binding TotalCourses}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="42" Height="42" CornerRadius="21" Background="{StaticResource PrimaryBrush}" VerticalAlignment="Center">
                                <TextBlock Text="&#xE930;" FontFamily="Segoe Fluent Icons" Foreground="White" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Active Courses" Foreground="#6A7684"/>
                                <TextBlock Text="{Binding ActiveCourses}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="42" Height="42" CornerRadius="21" Background="{StaticResource AccentBrush}" VerticalAlignment="Center">
                                <TextBlock Text="&#xE13D;" FontFamily="Segoe Fluent Icons" Foreground="{StaticResource PrimaryBrush}" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="Enrollments" Foreground="#6A7684"/>
                                <TextBlock Text="{Binding EnrollmentsToday}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource StatCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="42" Height="42" CornerRadius="21" Background="{StaticResource PrimaryBrush}" VerticalAlignment="Center">
                                <TextBlock Text="&#xE734;" FontFamily="Segoe Fluent Icons" Foreground="White" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Completions" Foreground="#6A7684"/>
                                <TextBlock Text="{Binding Completions}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </UniformGrid>

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="521*" />
                        <ColumnDefinition Width="639*" />
                    </Grid.ColumnDefinitions>

                    <!-- Courses -->
                    <Border Grid.Column="0" Style="{StaticResource StatCardStyle}" Padding="14" Margin="6,6,6,6">
                        <StackPanel>
                            <TextBlock Text="Courses" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                            <ItemsControl ItemsSource="{Binding Courses}" ItemTemplate="{StaticResource CourseCardTemplate}" />
                        </StackPanel>
                    </Border>

                    <!-- Enrollments (table style) -->
                    <Border Grid.Column="1" Style="{StaticResource StatCardStyle}" Padding="14" Margin="6,6,6,6">
                        <StackPanel>
                            <TextBlock Text="Enrollments" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" />
                            <ListView ItemsSource="{Binding Enrollments}"
                                      Margin="0,4,0,0"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      Padding="0"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      HorizontalContentAlignment="Stretch" d:ItemsSource="{d:SampleData ItemCount=5}">
                                <ListView.Resources>
                                    <Style TargetType="{x:Type GridViewColumnHeader}">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#6A7684"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0,0,0,6"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    </Style>
                                    <Style TargetType="{x:Type ListViewItem}">
                                        <Setter Property="Padding" Value="8,8"/>
                                        <Setter Property="Margin" Value="0,4,0,0"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="Height" Value="44"/>
                                    </Style>
                                </ListView.Resources>
                                <ListView.View>
                                    <GridView AllowsColumnReorder="False">
                                        <GridViewColumn Header="Name" Width="125">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Employee}" TextAlignment="Center" HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Course" Width="220">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Course}" TextTrimming="CharacterEllipsis" TextAlignment="Center" HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Date" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextAlignment="Center" HorizontalAlignment="Center" Text="{Binding ScheduleDate, StringFormat=\{0:MMM dd\, yyyy\}}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Status" Width="114">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Padding="12,4"
                                                            CornerRadius="10"
                                                            Background="{Binding StatusColor}"
                                                            HorizontalAlignment="Center"
                                                            MinWidth="90">
                                                        <TextBlock Text="{Binding Status}"
                                                                   Foreground="White"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
