<Window x:Class="HRMS.View.BiometricEnrollmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enroll Biometric"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="560"
        Height="420"
        Background="White">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1E4368" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#2E9D5B" />
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Employee info (auto-filled) -->
        <Border Grid.Row="0" Padding="12" Background="#F8FBFF" BorderBrush="#E5EDF7" BorderThickness="1" CornerRadius="10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Enrolling Biometric For:" Foreground="#5B6A7A" FontWeight="SemiBold" />
                <TextBlock x:Name="EmployeeLabel"
                           Text="(Employee will be set automatically)"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="0,4,0,0" />
                <TextBlock x:Name="BiometricIdLabel"
                           Text="Biometric ID: (auto-generated)"
                           Foreground="#5B6A7A"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- Reader status -->
        <Border Grid.Row="1" Padding="12" Background="#FFFBF0" BorderBrush="#F5E2B5" BorderThickness="1" CornerRadius="10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="ReaderStatusText"
                           Text="Checking biometric reader connection..."
                           FontWeight="SemiBold"
                           Foreground="#B9831A" />
                <TextBlock x:Name="ReaderDetailText"
                           Margin="0,4,0,0"
                           Foreground="#5B6A7A"
                           TextWrapping="Wrap"
                           Text="Please wait..." />
            </StackPanel>
        </Border>

        <!-- Capture progress -->
        <Border Grid.Row="2" Padding="12" Background="#F2FBF5" BorderBrush="#D8EEDD" BorderThickness="1" CornerRadius="10" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="CaptureInstructionText"
                           Text="Place finger on the reader when prompted."
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}" />
                <TextBlock x:Name="CaptureProgressText"
                           Margin="0,6,0,0"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource SuccessBrush}"
                           Text="Waiting..." />
                <TextBlock x:Name="CaptureDetailText"
                           Margin="0,4,0,0"
                           Foreground="#5B6A7A"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Status / result -->
        <TextBlock x:Name="ResultText"
                   Grid.Row="3"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource SuccessBrush}"
                   TextWrapping="Wrap" />

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="StartCaptureButton"
                    Content="Start Capture"
                    Width="130" Height="40"
                    Margin="0,0,8,0"
                    Background="{StaticResource SuccessBrush}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="StartCapture_Click" />
            <Button Content="Close"
                    Width="90" Height="40"
                    Background="#EAF2FB"
                    Foreground="{StaticResource PrimaryBrush}"
                    BorderThickness="0"
                    Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
