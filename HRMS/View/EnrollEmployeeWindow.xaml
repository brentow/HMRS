<Window x:Class="HRMS.View.EnrollEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Enroll Employee"
        Height="399" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="White"
        WindowStyle="None">
    <Grid Margin="16" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Enroll Employee" FontSize="20" FontWeight="Bold" Foreground="#1E4368"/>
            <TextBlock Text="Select an employee and course, then click Enroll."
                       Foreground="#4A5565"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Employee" FontWeight="SemiBold" Foreground="#1E4368"/>
            <ComboBox x:Name="EmployeeBox" Margin="0,4,0,12" DisplayMemberPath="Name" SelectedValuePath="Id"
                      KeyDown="TextBox_KeyDown"/>

            <TextBlock Text="Course" FontWeight="SemiBold" Foreground="#1E4368"/>
            <ComboBox x:Name="CourseBox" Margin="0,4,0,12" DisplayMemberPath="Title" SelectedValuePath="Id"
                      KeyDown="TextBox_KeyDown"/>

            <TextBlock Text="Date" FontWeight="SemiBold" Foreground="#1E4368"/>
            <DatePicker x:Name="DatePicker" Margin="0,4,0,12" SelectedDate="{x:Static sys:DateTime.Today}"
                        KeyDown="TextBox_KeyDown"/>

            <TextBlock Text="Status" FontWeight="SemiBold" Foreground="#1E4368"/>
            <ComboBox x:Name="StatusBox" Margin="0,4,0,0" Height="28" KeyDown="TextBox_KeyDown">
                <ComboBoxItem Content="Enrolled" IsSelected="True"/>
                <ComboBoxItem Content="Scheduled"/>
                <ComboBoxItem Content="Completed"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Enroll"
                    Width="90"
                    Padding="10,6"
                    Background="#1E4368"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    Click="Enroll_Click"/>
            <Button Content="Close"
                    Width="90"
                    Padding="10,6"
                    Background="#FDBD55"
                    Foreground="#1E4368"
                    BorderThickness="0"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
